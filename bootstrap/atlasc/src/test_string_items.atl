import resolver;
import ast;
import array;
import string;
import io;
import fs;
import lexer;
import error;
import token;
import parser;
import span;

fn print_chars(chars: []char) {
    var i = 0;
    while i < chars.len {
        io::print_char(chars[i]);
        i = i + 1;
    }
}

fn main(): int {
    var source: array::Array<char> = array::Array();
    if !fs::read_file("stdlib/string.atl", @source) {
        print_chars("read_fail\n");
        return 1;
    }
    var tokens: array::Array<token::Token> = array::Array();
    var lex_errors: array::Array<error::LexError> = array::Array();
    lexer::tokenize(@source, 0, @tokens, @lex_errors);
    
    var arena = ast::make_empty_arena();
    var parse_errors: array::Array<ast::ParseError> = array::Array();
    var file_info = ast::make_empty_file_info();
    parser::parse_file(@arena, tokens.data, tokens.len, @file_info, @parse_errors);
    
    print_chars("items=");
    io::print(file_info.item_len);
    print_chars("\n");
    
    var i = file_info.item_start;
    while i < file_info.item_start + file_info.item_len {
        var item = (arena).items[i];
        print_chars("kind=");
        io::print(item.kind);
        print_chars(" is_export=");
        io::print(item.is_export);
        print_chars("\n");
        i = i + 1;
    }
    
    return 0;
}

import resolver;
import ast;
import array;
import string;
import io;
import lexer;
import error;
import token;
import parser;

fn print_chars(chars: []char) {
    var i = 0;
    while i < chars.len {
        io::print_char(chars[i]);
        i = i + 1;
    }
}

fn main(): int {
    var source: array::Array<char> = array::Array();
    var s = "fn main(): int { var a = 10; var b = 32; return a + b; }";
    var si = 0;
    while si < s.len {
        source.push(s[si]);
        si = si + 1;
    }
    
    var tokens: array::Array<token::Token> = array::Array();
    var lex_errors: array::Array<error::LexError> = array::Array();
    lexer::tokenize(@source, 0, @tokens, @lex_errors);
    
    print_chars("lex_errors=");
    io::print(lex_errors.len);
    print_chars("\n");
    
    var arena = ast::make_empty_arena();
    var parse_errors: array::Array<ast::ParseError> = array::Array();
    var file_info = ast::make_empty_file_info();
    parser::parse_file(@arena, tokens.data, tokens.len, @file_info, @parse_errors);
    
    print_chars("items=");
    io::print(file_info.item_len);
    print_chars(" parse_errors=");
    io::print(parse_errors.len);
    print_chars("\n");
    
    if file_info.item_len > 0 {
        var item = (arena).items[0];
        if item.kind == 1 {
            var fn_info = (arena).functions[item.function_id];
            var block = (arena).blocks[fn_info.body_block_id];
            print_chars("block stmts=");
            io::print(block.stmt_ref_len);
            print_chars("\n");
        }
    }
    
    return 0;
}

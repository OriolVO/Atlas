import ast; import array; import error; import io; import lexer; import parser; import token;
fn print_chars(chars: []char) { var i = 0; while i < chars.len { io::print_char(chars[i]); i = i + 1; } }
fn main(): int {
    var source: array::Array<char> = array::Array();
    var s = "return 1;";
    var si = 0; while si < s.len { source.push(s[si]); si = si + 1; }
    var tokens: array::Array<token::Token> = array::Array();
    var lex_errors: array::Array<error::LexError> = array::Array();
    lexer::tokenize(@source, 0, @tokens, @lex_errors);
    var arena = ast::make_empty_arena();
    var parse_errors: array::Array<ast::ParseError> = array::Array();
    var stmt_id = -1; var index = 0;
    var ok = parser::parse_first_stmt(@arena, tokens.data, tokens.len, @index, @stmt_id, @parse_errors);
    print_chars("ok="); io::print(ok); print_chars(" errs="); io::print(parse_errors.len); print_chars("\n");
    return 0;
}

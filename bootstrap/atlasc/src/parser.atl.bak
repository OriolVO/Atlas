fn parse_return_stmt_at(
    arena: @ast::Arena,
    tokens: @token::Token?,
    token_count: int,
    index: @int,
    out_stmt: @ast::ReturnStmt,
    errors: @array::Array<ast::ParseError>
): bool {
    if tokens == null or (*index) >= token_count { return fail(errors, 100, 0, 0); }
    if tokens[(*index)].kind != 18 { return fail(errors, 101, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
    var start = token_start(tokens[(*index)]);
    (*index) = (*index) + 1;
    var has_value = false;
    var value_expr_id = -1;
    if (*index) < token_count and tokens[(*index)].kind != 65 {
        has_value = true;
        if !parse_expr_at(arena, tokens, token_count, index, @value_expr_id, errors) { return false; }
    }
    if (*index) >= token_count or tokens[(*index)].kind != 65 {
        if (*index) < token_count { return fail(errors, 102, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
        return fail(errors, 102, start, start);
    }
    (*out_stmt) = ast::make_return_stmt(has_value, value_expr_id, start, token_end(tokens[(*index)]));
    (*index) = (*index) + 1;
    return true;
}

export fn parse_first_stmt(
    arena: @ast::Arena,
    tokens: @token::Token?,
    token_count: int,
    index: @int,
    out_stmt_id: @int,
    errors: @array::Array<ast::ParseError>
): bool {
    if tokens == null or (*index) >= token_count { return fail(errors, 50, 0, 0); }
    var kind = tokens[(*index)].kind;
    if kind == 7 {
        var decl = ast::make_empty_var_decl();
        if !parse_var_decl_at(arena, tokens, token_count, index, @decl, errors) { return false; }
        (*out_stmt_id) = ast::push_stmt(arena, ast::make_var_stmt(decl));
        return true;
    }
    if kind == 8 {
        var decl = ast::make_empty_const_decl();
        if !parse_const_decl_at(arena, tokens, token_count, index, @decl, errors) { return false; }
        (*out_stmt_id) = ast::push_stmt(arena, ast::make_const_stmt(decl));
        return true;
    }
    if kind == 15 {
        var if_stmt = ast::make_empty_if_stmt();
        if !parse_if_stmt_at(arena, tokens, token_count, index, @if_stmt, errors) { return false; }
        (*out_stmt_id) = ast::push_stmt(arena, ast::make_if_only_stmt(if_stmt));
        return true;
    }
    if kind == 17 {
        var while_stmt = ast::make_empty_while_stmt();
        if !parse_while_stmt_at(arena, tokens, token_count, index, @while_stmt, errors) { return false; }
        (*out_stmt_id) = ast::push_stmt(arena, ast::make_while_only_stmt(while_stmt));
        return true;
    }
    if kind == 14 {
        var match_stmt = ast::make_empty_match_stmt();
        if !parse_match_stmt_at(arena, tokens, token_count, index, @match_stmt, errors) { return false; }
        (*out_stmt_id) = ast::push_stmt(arena, ast::make_match_only_stmt(match_stmt));
        return true;
    }
    if kind == 72 {
        var block_id = -1;
        if !parse_block_at(arena, tokens, token_count, index, @block_id, errors) { return false; }
        (*out_stmt_id) = ast::push_stmt(arena, ast::make_block_stmt(block_id, (*arena).blocks[block_id].span));
        return true;
    }
    if kind == 77 {
        var break_stmt = ast::make_empty_stmt();
        if !parse_break_stmt_at(tokens, token_count, index, @break_stmt, errors) { return false; }
        (*out_stmt_id) = ast::push_stmt(arena, break_stmt);
        return true;
    }
    if kind == 78 {
        var continue_stmt = ast::make_empty_stmt();
        if !parse_continue_stmt_at(tokens, token_count, index, @continue_stmt, errors) { return false; }
        (*out_stmt_id) = ast::push_stmt(arena, continue_stmt);
        return true;
    }
    if kind == 70 and (*index) + 2 < token_count and tokens[(*index) + 1].kind == 48 and (tokens[(*index) + 2].kind == 6 or tokens[(*index) + 2].kind == 29) {
        var assign_stmt = ast::make_empty_assign_stmt();
        if !parse_assign_stmt_at(arena, tokens, token_count, index, @assign_stmt, errors) { return false; }
        (*out_stmt_id) = ast::push_stmt(arena, ast::make_assign_only_stmt(assign_stmt));
        return true;
    }
    if kind == 48 {
        var assign_stmt = ast::make_empty_assign_stmt();
        if !parse_assign_stmt_at(arena, tokens, token_count, index, @assign_stmt, errors) { return false; }
        (*out_stmt_id) = ast::push_stmt(arena, ast::make_assign_only_stmt(assign_stmt));
        return true;
    }
    if kind == 18 {
        var return_stmt = ast::make_empty_return_stmt();
        if !parse_return_stmt_at(arena, tokens, token_count, index, @return_stmt, errors) { return false; }
        (*out_stmt_id) = ast::push_stmt(arena, ast::make_return_only_stmt(return_stmt));
        return true;
    }
    if kind == 6 {
        var save = (*index);
        var si = save + 1;
        var is_assign = false;
        while si < token_count and (tokens[si].kind == 68 or tokens[si].kind == 74) {
            if tokens[si].kind == 68 {
                si = si + 1;
                if si < token_count and tokens[si].kind == 6 { si = si + 1; } else { break; }
            } else {
                si = si + 1;
                while si < token_count and tokens[si].kind != 75 { si = si + 1; }
                if si < token_count and tokens[si].kind == 75 { si = si + 1; }
            }
        }
        if si < token_count and tokens[si].kind == 57 { is_assign = true; }

        if is_assign {
            var assign_stmt = ast::make_empty_assign_stmt();
            if !parse_assign_stmt_at(arena, tokens, token_count, index, @assign_stmt, errors) { return false; }
            (*out_stmt_id) = ast::push_stmt(arena, ast::make_assign_only_stmt(assign_stmt));
            return true;
        }
        if (*index) + 1 < token_count and tokens[(*index) + 1].kind == 57 {
            var assign_stmt = ast::make_empty_assign_stmt();
            if !parse_assign_stmt_at(arena, tokens, token_count, index, @assign_stmt, errors) { return false; }
            (*out_stmt_id) = ast::push_stmt(arena, ast::make_assign_only_stmt(assign_stmt));
            return true;
        }
        return parse_expr_stmt_at(arena, tokens, token_count, index, out_stmt_id, errors);
    }
    return fail(errors, 51, token_start(tokens[(*index)]), token_end(tokens[(*index)]));
}

fn parse_param_info_at(tokens: @token::Token?, token_count: int, index: @int, out_param: @ast::ParamInfo, errors: @array::Array<ast::ParseError>): bool {
    if tokens == null or (*index) >= token_count { return fail(errors, 110, 0, 0); }
    if tokens[(*index)].kind != 6 and tokens[(*index)].kind != 29 { return fail(errors, 111, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
    var name_start = token_start(tokens[(*index)]);
    var name_end = token_end(tokens[(*index)]);
    (*index) = (*index) + 1;
    var has_type_hint = false;
    var type_ref = ast::make_empty_type_ref();
    if !parse_type_hint(tokens, token_count, index, @has_type_hint, @type_ref, errors) { return false; }
    (*out_param) = ast::make_param_info(name_start, name_end, has_type_hint, type_ref);
    return true;
}

fn parse_function_at(
    arena: @ast::Arena,
    tokens: @token::Token?,
    token_count: int,
    index: @int,
    out_function_id: @int,
    errors: @array::Array<ast::ParseError>
): bool {
    if tokens == null or (*index) >= token_count { return fail(errors, 120, 0, 0); }
    if tokens[(*index)].kind != 9 { return fail(errors, 121, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
    var start = token_start(tokens[(*index)]);
    (*index) = (*index) + 1;
    if (*index) >= token_count or tokens[(*index)].kind != 6 {
        if (*index) < token_count { return fail(errors, 122, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
        return fail(errors, 122, start, start);
    }
    var name_start = token_start(tokens[(*index)]);
    var name_end = token_end(tokens[(*index)]);
    (*index) = (*index) + 1;

    var generic_param_start = 0;
    var generic_param_len = 0;
    if !parse_generic_params_at(arena, tokens, token_count, index, @generic_param_start, @generic_param_len, errors) { return false; }
    var where_clause_start = 0;
    var where_clause_len = 0;
    if !parse_where_clauses_at(arena, tokens, token_count, index, @where_clause_start, @where_clause_len, errors) { return false; }

    if (*index) < token_count and ((tokens[(*index)].kind >= 46 and tokens[(*index)].kind <= 50) or tokens[(*index)].kind == 74) {
        name_end = token_end(tokens[(*index)]);
        (*index) = (*index) + 1;
        if tokens[(*index) - 1].kind == 74 {
            if (*index) < token_count and tokens[(*index)].kind == 75 {
                name_end = token_end(tokens[(*index)]);
                (*index) = (*index) + 1;
            }
        } else if (*index) < token_count and tokens[(*index)].kind == 57 {
            name_end = token_end(tokens[(*index)]);
            (*index) = (*index) + 1;
        }
    }
    if (*index) >= token_count or tokens[(*index)].kind != 70 {
        if (*index) < token_count { return fail(errors, 123, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
        return fail(errors, 123, start, start);
    }
    (*index) = (*index) + 1;
    var param_start = (*arena).params.len;
    if (*index) < token_count and tokens[(*index)].kind != 71 {
        while true {
            if tokens[(*index)].kind == 67 {
                (*index) = (*index) + 1;
                break;
            }
            var param = ast::make_empty_param_info();
            if !parse_param_info_at(tokens, token_count, index, @param, errors) { return false; }
            ast::push_param(arena, param);
            if (*index) < token_count and tokens[(*index)].kind == 66 {
                (*index) = (*index) + 1;
            } else {
                break;
            }
        }
    }
    if (*index) >= token_count or tokens[(*index)].kind != 71 {
        if (*index) < token_count { return fail(errors, 124, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
        return fail(errors, 124, start, start);
    }
    (*index) = (*index) + 1;
    var has_return_type = false;
    var return_type_ref = ast::make_empty_type_ref();
    if (*index) < token_count and tokens[(*index)].kind == 64 {
        (*index) = (*index) + 1;
        has_return_type = true;
        if !parse_type_ref_direct(tokens, token_count, index, @return_type_ref, errors) {
            return false;
        }
    }
    var body_block_id = -1;
    var end_span = start;
    if (*index) < token_count and tokens[(*index)].kind == 65 {
        end_span = token_end(tokens[(*index)]);
        (*index) = (*index) + 1;
    } else {
        if !parse_block_at(arena, tokens, token_count, index, @body_block_id, errors) { return false; }
        end_span = (*arena).blocks[body_block_id].span.end;
    }
    var function_info = ast::make_function_info(
        name_start,
        name_end,
        param_start,
        (*arena).params.len - param_start,
        has_return_type,
        return_type_ref,
        body_block_id,
        generic_param_start,
        generic_param_len,
        where_clause_start,
        where_clause_len,
        start,
        end_span
    );
    (*out_function_id) = ast::push_function(arena, function_info);
    return true;
}

fn parse_struct_at(
    arena: @ast::Arena,
    tokens: @token::Token?,
    token_count: int,
    index: @int,
    out_struct_id: @int,
    errors: @array::Array<ast::ParseError>
): bool {
    if tokens == null or (*index) >= token_count { return fail(errors, 132, 0, 0); }
    if tokens[(*index)].kind != 10 { return fail(errors, 133, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
    var start = token_start(tokens[(*index)]);
    (*index) = (*index) + 1;
    if (*index) >= token_count or tokens[(*index)].kind != 6 {
        if (*index) < token_count { return fail(errors, 134, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
        return fail(errors, 134, start, start);
    }
    var name_start = token_start(tokens[(*index)]);
    var name_end = token_end(tokens[(*index)]);
    (*index) = (*index) + 1;
    if (*index) >= token_count or tokens[(*index)].kind != 72 {
        if (*index) < token_count { return fail(errors, 135, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
        return fail(errors, 135, start, start);
    }
    (*index) = (*index) + 1;
    var field_start = (*arena).struct_fields.len;
    while (*index) < token_count and tokens[(*index)].kind != 73 {
        if tokens[(*index)].kind != 6 {
            return fail(errors, 136, token_start(tokens[(*index)]), token_end(tokens[(*index)]));
        }
        var field_name_start = token_start(tokens[(*index)]);
        var field_name_end = token_end(tokens[(*index)]);
        var field_start_pos = field_name_start;
        (*index) = (*index) + 1;
        var field_type_ref = ast::make_empty_type_ref();
        if !parse_required_type_ref(tokens, token_count, index, @field_type_ref, errors) {
            return false;
        }
        if (*index) >= token_count or tokens[(*index)].kind != 65 {
            if (*index) < token_count { return fail(errors, 137, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
            return fail(errors, 137, field_start_pos, field_start_pos);
        }
        var field = ast::make_struct_field(field_name_start, field_name_end, field_type_ref, field_start_pos, token_end(tokens[(*index)]));
        ast::push_struct_field(arena, field);
        (*index) = (*index) + 1;
    }
    if (*index) >= token_count or tokens[(*index)].kind != 73 {
        return fail(errors, 138, start, start);
    }
    var struct_info = ast::make_struct_info(name_start, name_end, field_start, (*arena).struct_fields.len - field_start, start, token_end(tokens[(*index)]));
    (*out_struct_id) = ast::push_struct(arena, struct_info);
    (*index) = (*index) + 1;
    return true;
}

fn parse_enum_at(
    arena: @ast::Arena,
    tokens: @token::Token?,
    token_count: int,
    index: @int,
    out_enum_id: @int,
    errors: @array::Array<ast::ParseError>
): bool {
    if tokens == null or (*index) >= token_count { return fail(errors, 139, 0, 0); }
    if tokens[(*index)].kind != 12 { return fail(errors, 140, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
    var start = token_start(tokens[(*index)]);
    (*index) = (*index) + 1;
    if (*index) >= token_count or tokens[(*index)].kind != 6 {
        if (*index) < token_count { return fail(errors, 141, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
        return fail(errors, 141, start, start);
    }
    var name_start = token_start(tokens[(*index)]);
    var name_end = token_end(tokens[(*index)]);
    (*index) = (*index) + 1;
    if (*index) >= token_count or tokens[(*index)].kind != 72 {
        if (*index) < token_count { return fail(errors, 142, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
        return fail(errors, 142, start, start);
    }
    (*index) = (*index) + 1;
    var variant_start = (*arena).enum_variants.len;
    while (*index) < token_count and tokens[(*index)].kind != 73 {
        if tokens[(*index)].kind != 6 {
            return fail(errors, 143, token_start(tokens[(*index)]), token_end(tokens[(*index)]));
        }
        var v_start = token_start(tokens[(*index)]);
        var v_end = token_end(tokens[(*index)]);
        ast::push_enum_variant(arena, ast::make_enum_variant(v_start, v_end, v_start, v_end));
        (*index) = (*index) + 1;
        if (*index) < token_count and tokens[(*index)].kind == 66 {
            (*index) = (*index) + 1;
        } else {
            break;
        }
    }
    if (*index) >= token_count or tokens[(*index)].kind != 73 {
        return fail(errors, 144, start, start);
    }
    var enum_info = ast::make_enum_info(name_start, name_end, variant_start, (*arena).enum_variants.len - variant_start, start, token_end(tokens[(*index)]));
    (*out_enum_id) = ast::push_enum(arena, enum_info);
    (*index) = (*index) + 1;
    return true;
}

fn parse_choice_at(
    arena: @ast::Arena,
    tokens: @token::Token?,
    token_count: int,
    index: @int,
    out_choice_id: @int,
    errors: @array::Array<ast::ParseError>
): bool {
    if tokens == null or (*index) >= token_count { return fail(errors, 145, 0, 0); }
    if tokens[(*index)].kind != 13 { return fail(errors, 146, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
    var start = token_start(tokens[(*index)]);
    (*index) = (*index) + 1;
    if (*index) >= token_count or tokens[(*index)].kind != 6 {
        if (*index) < token_count { return fail(errors, 147, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
        return fail(errors, 147, start, start);
    }
    var name_start = token_start(tokens[(*index)]);
    var name_end = token_end(tokens[(*index)]);
    (*index) = (*index) + 1;
    if (*index) >= token_count or tokens[(*index)].kind != 72 {
        if (*index) < token_count { return fail(errors, 148, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
        return fail(errors, 148, start, start);
    }
    (*index) = (*index) + 1;
    var variant_start = (*arena).choice_variants.len;
    while (*index) < token_count and tokens[(*index)].kind != 73 {
        if tokens[(*index)].kind != 6 {
            return fail(errors, 149, token_start(tokens[(*index)]), token_end(tokens[(*index)]));
        }
        var v_start = token_start(tokens[(*index)]);
        var v_end = token_end(tokens[(*index)]);
        (*index) = (*index) + 1;
        var has_payload = false;
        var payload_type_ref = ast::make_empty_type_ref();
        if (*index) < token_count and tokens[(*index)].kind == 70 {
            (*index) = (*index) + 1;
            has_payload = true;
            if !parse_type_ref_direct(tokens, token_count, index, @payload_type_ref, errors) {
                return false;
            }
            if (*index) >= token_count or tokens[(*index)].kind != 71 {
                return fail(errors, 151, v_start, v_end);
            }
            (*index) = (*index) + 1;
        }
        ast::push_choice_variant(arena, ast::make_choice_variant(v_start, v_end, has_payload, payload_type_ref, v_start, v_end));
        if (*index) < token_count and tokens[(*index)].kind == 66 {
            (*index) = (*index) + 1;
        } else {
            break;
        }
    }
    if (*index) >= token_count or tokens[(*index)].kind != 73 {
        return fail(errors, 152, start, start);
    }
    var choice_info = ast::make_choice_info(name_start, name_end, variant_start, (*arena).choice_variants.len - variant_start, start, token_end(tokens[(*index)]));
    (*out_choice_id) = ast::push_choice(arena, choice_info);
    (*index) = (*index) + 1;
    return true;
}

fn parse_import_at(
    arena: @ast::Arena,
    tokens: @token::Token?,
    token_count: int,
    index: @int,
    out_import_id: @int,
    errors: @array::Array<ast::ParseError>
): bool {
    if tokens == null or (*index) >= token_count { return fail(errors, 153, 0, 0); }
    if tokens[(*index)].kind != 19 { return fail(errors, 154, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
    var start = token_start(tokens[(*index)]);
    (*index) = (*index) + 1;
    if (*index) >= token_count or tokens[(*index)].kind != 6 {
        if (*index) < token_count { return fail(errors, 155, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
        return fail(errors, 155, start, start);
    }
    var name_start = token_start(tokens[(*index)]);
    var name_end = token_end(tokens[(*index)]);
    (*index) = (*index) + 1;
    if (*index) >= token_count or tokens[(*index)].kind != 65 {
        if (*index) < token_count { return fail(errors, 156, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
        return fail(errors, 156, start, start);
    }
    (*out_import_id) = ast::push_import(arena, ast::make_import_info(name_start, name_end, start, token_end(tokens[(*index)])));
    (*index) = (*index) + 1;
    return true;
}


fn parse_generic_params_at(
    arena: @ast::Arena,
    tokens: @token::Token?,
    token_count: int,
    index: @int,
    out_start: @int,
    out_len: @int,
    errors: @array::Array<ast::ParseError>
): bool {
    (*out_start) = (*arena).generic_params.len;
    (*out_len) = 0;
    if tokens[(*index)].kind != 55 { return true; } // '<'
    (*index) = (*index) + 1;
    while (*index) < token_count and tokens[(*index)].kind != 56 { // '>'
        if tokens[(*index)].kind != 6 { return fail(errors, 170, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
        var name_span = span::make(token_start(tokens[(*index)]), token_end(tokens[(*index)]));
        (*index) = (*index) + 1;
        var p = ast::GenericParam { name_span: name_span, span: name_span };
        ast::push_generic_param(arena, p);
        (*out_len) = (*out_len) + 1;
        if tokens[(*index)].kind == 66 { // ','
            (*index) = (*index) + 1;
        } else {
            break;
        }
    }
    if (*index) >= token_count or tokens[(*index)].kind != 56 {
        if (*index) < token_count { return fail(errors, 171, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
        return fail(errors, 171, 0, 0);
    }
    (*index) = (*index) + 1;
    return true;
}

fn parse_where_clauses_at(
    arena: @ast::Arena,
    tokens: @token::Token?,
    token_count: int,
    index: @int,
    out_start: @int,
    out_len: @int,
    errors: @array::Array<ast::ParseError>
): bool {
    (*out_start) = (*arena).where_clauses.len;
    (*out_len) = 0;
    while (*index) < token_count and tokens[(*index)].kind == 23 { // 'where'
        var clause_start = token_start(tokens[(*index)]);
        (*index) = (*index) + 1;
        if tokens[(*index)].kind != 6 { return fail(errors, 172, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
        var target_span = span::make(token_start(tokens[(*index)]), token_end(tokens[(*index)]));
        (*index) = (*index) + 1;
        if tokens[(*index)].kind != 64 { return fail(errors, 173, token_start(tokens[(*index)]), token_end(tokens[(*index)])); } // ':'
        (*index) = (*index) + 1;
        
        var sig_start = (*arena).constraint_signatures.len;
        var sig_len = 0;
        while (*index) < token_count {
            if tokens[(*index)].kind != 6 { return fail(errors, 174, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
            var name_span = span::make(token_start(tokens[(*index)]), token_end(tokens[(*index)]));
            (*index) = (*index) + 1;
            
            var param_start = 0; var param_len = 0;
            if tokens[(*index)].kind == 70 { // '('
                (*index) = (*index) + 1;
                while (*index) < token_count and tokens[(*index)].kind != 71 {
                    (*index) = (*index) + 1;
                }
                if (*index) < token_count { (*index) = (*index) + 1; }
            }
            
            var has_ret = false;
            var ret_type = ast::make_empty_type_ref();
            if tokens[(*index)].kind == 69 { // '=>'
                (*index) = (*index) + 1;
                has_ret = true;
                if !parse_type_ref_direct(tokens, token_count, index, @ret_type, errors) { return false; }
            }
            
            var sig = ast::ConstraintSignature {
                name_span: name_span,
                param_start: param_start,
                param_len: param_len,
                has_return_type: has_ret,
                return_type_ref: ret_type,
                span: name_span
            };
            ast::push_constraint_signature(arena, sig);
            sig_len = sig_len + 1;
            
            if tokens[(*index)].kind == 66 { // ','
                (*index) = (*index) + 1;
            } else {
                break;
            }
        }
        
        var clause = ast::WhereClause {
            target_span: target_span,
            constraint_start: sig_start,
            constraint_len: sig_len,
            span: span::make(clause_start, token_end(tokens[(*index)-1]))
        };
        ast::push_where_clause(arena, clause);
        (*out_len) = (*out_len) + 1;
    }
    return true;
}

fn parse_class_at(
    arena: @ast::Arena,
    tokens: @token::Token?,
    token_count: int,
    index: @int,
    out_class_id: @int,
    errors: @array::Array<ast::ParseError>
): bool {
    var start = token_start(tokens[(*index)]);
    (*index) = (*index) + 1; // 'class'
    
    if tokens[(*index)].kind != 6 { return fail(errors, 180, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
    var name_span = span::make(token_start(tokens[(*index)]), token_end(tokens[(*index)]));
    (*index) = (*index) + 1;
    
    var generic_start = 0; var generic_len = 0;
    if !parse_generic_params_at(arena, tokens, token_count, index, @generic_start, @generic_len, errors) { return false; }
    
    var where_start = 0; var where_len = 0;
    if !parse_where_clauses_at(arena, tokens, token_count, index, @where_start, @where_len, errors) { return false; }
    
    if tokens[(*index)].kind != 72 { return fail(errors, 181, token_start(tokens[(*index)]), token_end(tokens[(*index)])); } // '{'
    (*index) = (*index) + 1;
    
    var field_start = (*arena).class_fields.len; var field_len = 0;
    var method_start = (*arena).class_methods.len; var method_len = 0;
    var struct_start = (*arena).class_structs.len; var struct_len = 0;
    
    while (*index) < token_count and tokens[(*index)].kind != 73 { // '}'
        var visibility = 0; // private
        if tokens[(*index)].kind == 21 { // 'public'
            visibility = 1;
            (*index) = (*index) + 1;
        } else if tokens[(*index)].kind == 22 { // 'private'
            visibility = 0;
            (*index) = (*index) + 1;
        }
        
        if tokens[(*index)].kind == 9 { // 'fn'
            var fn_id = -1;
            if !parse_function_at(arena, tokens, token_count, index, @fn_id, errors) { return false; }
            var method = ast::ClassMethod { visibility: visibility, function_id: fn_id, span: (*arena).functions[fn_id].span };
            ast::push_class_method(arena, method);
            method_len = method_len + 1;
        } else if tokens[(*index)].kind == 10 { // 'struct'
            var st_id = -1;
            if !parse_struct_at(arena, tokens, token_count, index, @st_id, errors) { return false; }
            var c_struct = ast::ClassStruct { visibility: visibility, struct_id: st_id, span: (*arena).structs[st_id].span };
            ast::push_class_struct(arena, c_struct);
            struct_len = struct_len + 1;
        } else { // field
            var is_const = false;
            if tokens[(*index)].kind == 8 { // 'const'
                is_const = true;
                (*index) = (*index) + 1;
            }
            if tokens[(*index)].kind != 6 { return fail(errors, 182, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
            var f_name = span::make(token_start(tokens[(*index)]), token_end(tokens[(*index)]));
            (*index) = (*index) + 1;
            if tokens[(*index)].kind != 64 { return fail(errors, 183, token_start(tokens[(*index)]), token_end(tokens[(*index)])); } // ':'
            (*index) = (*index) + 1;
            var f_type = ast::make_empty_type_ref();
            if !parse_type_ref_direct(tokens, token_count, index, @f_type, errors) { return false; }
            if tokens[(*index)].kind != 65 { return fail(errors, 184, token_start(tokens[(*index)]), token_end(tokens[(*index)])); } // ';'
            (*index) = (*index) + 1;
            
            var field = ast::ClassField { visibility: visibility, is_const: is_const, name_span: f_name, type_ref: f_type, span: f_name };
            ast::push_class_field(arena, field);
            field_len = field_len + 1;
        }
    }
    
    if (*index) >= token_count or tokens[(*index)].kind != 73 { return fail(errors, 185, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
    var end = token_end(tokens[(*index)]);
    (*index) = (*index) + 1;
    
    var class_info = ast::ClassInfo {
        name_span: name_span,
        generic_param_start: generic_start,
        generic_param_len: generic_len,
        where_clause_start: where_start,
        where_clause_len: where_len,
        field_start: field_start,
        field_len: field_len,
        method_start: method_start,
        method_len: method_len,
        struct_start: struct_start,
        struct_len: struct_len,
        span: span::make(start, end)
    };
    (*out_class_id) = ast::push_class(arena, class_info);
    return true;
}

export fn parse_first_item(
    arena: @ast::Arena,
    tokens: @token::Token?,
    token_count: int,
    index: @int,
    out_item_id: @int,
    errors: @array::Array<ast::ParseError>
): bool {
    if tokens == null or (*index) >= token_count { return fail(errors, 130, 0, 0); }
    var is_export = false;
    if tokens[(*index)].kind == 20 {
        is_export = true;
        (*index) = (*index) + 1;
    }
    var is_extern = false;
    if tokens[(*index)].kind == 28 {
        is_extern = true;
        (*index) = (*index) + 1;
        if (*index) < token_count and tokens[(*index)].kind == 5 {
            (*index) = (*index) + 1;
        }
    }
    if (*index) >= token_count { return fail(errors, 130, 0, 0); }
    
    if tokens[(*index)].kind == 11 { // 'class'
        var class_id = -1;
        if !parse_class_at(arena, tokens, token_count, index, @class_id, errors) { return false; }
        var class_info = (*arena).classes[class_id];
        (*out_item_id) = ast::push_item(arena, ast::make_class_item(class_id, is_export, class_info.span));
        return true;
    }
    if tokens[(*index)].kind == 9 {
        var function_id = -1;
        if !parse_function_at(arena, tokens, token_count, index, @function_id, errors) { return false; }
        var function_info = (*arena).functions[function_id];
        (*out_item_id) = ast::push_item(arena, ast::make_function_item(function_id, is_export, function_info.span));
        return true;
    }
    if tokens[(*index)].kind == 10 {
        var struct_id = -1;
        if !parse_struct_at(arena, tokens, token_count, index, @struct_id, errors) { return false; }
        var struct_info = (*arena).structs[struct_id];
        (*out_item_id) = ast::push_item(arena, ast::make_struct_item(struct_id, is_export, struct_info.span));
        return true;
    }
    if tokens[(*index)].kind == 12 {
        var enum_id = -1;
        if !parse_enum_at(arena, tokens, token_count, index, @enum_id, errors) { return false; }
        var enum_info = (*arena).enums[enum_id];
        (*out_item_id) = ast::push_item(arena, ast::make_enum_item(enum_id, is_export, enum_info.span));
        return true;
    }
    if tokens[(*index)].kind == 13 {
        var choice_id = -1;
        if !parse_choice_at(arena, tokens, token_count, index, @choice_id, errors) { return false; }
        var choice_info = (*arena).choices[choice_id];
        (*out_item_id) = ast::push_item(arena, ast::make_choice_item(choice_id, is_export, choice_info.span));
        return true;
    }
    if tokens[(*index)].kind == 19 {
        var import_id = -1;
        if !parse_import_at(arena, tokens, token_count, index, @import_id, errors) { return false; }
        var import_info = (*arena).imports[import_id];
        (*out_item_id) = ast::push_item(arena, ast::make_import_item(import_id, is_export, import_info.span));
        return true;
    }
    return fail(errors, 131, token_start(tokens[(*index)]), token_end(tokens[(*index)]));
}

export fn parse_file(
    arena: @ast::Arena,
    tokens: @token::Token?,
    token_count: int,
    out_file: @ast::FileInfo,
    errors: @array::Array<ast::ParseError>
): bool {
    if tokens == null { return fail(errors, 140, 0, 0); }
    if token_count == 0 {
        (*out_file) = ast::make_file_info(0, 0, 0, 0);
        return true;
    }
    var item_start = (*arena).items.len;
    var index = 0;
    var start = token_start(tokens[0]);
    var end = start;
    while index < token_count and tokens[index].kind != 76 {
        var item_id = -1;
        if !parse_first_item(arena, tokens, token_count, @index, @item_id, errors) { return false; }
        end = (*arena).items[item_id].span.end;
    }
    if index < token_count {
        end = token_end(tokens[index]);
    }
    (*out_file) = ast::make_file_info(item_start, (*arena).items.len - item_start, start, end);
    return true;
}

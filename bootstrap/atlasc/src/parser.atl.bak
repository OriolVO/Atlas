        var binding_start = 0;
        var binding_end = 0;
        if (*index) < token_count and tokens[(*index)].kind == 70 {
            (*index) = (*index) + 1;
            has_binding = true;
            if (*index) >= token_count or tokens[(*index)].kind != 6 {
                if (*index) < token_count { return fail(errors, 109, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
                return fail(errors, 109, variant_start, variant_end);
            }
            binding_start = token_start(tokens[(*index)]);
            binding_end = token_end(tokens[(*index)]);
            (*index) = (*index) + 1;
            if (*index) >= token_count or tokens[(*index)].kind != 71 {
                if (*index) < token_count { return fail(errors, 110, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
                return fail(errors, 110, binding_start, binding_end);
            }
            (*index) = (*index) + 1;
        }
        if (*index) >= token_count or tokens[(*index)].kind != 69 {
            if (*index) < token_count { return fail(errors, 111, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
            return fail(errors, 111, variant_start, variant_end);
        }
        (*index) = (*index) + 1;
        var block_id = -1;
        if !parse_block_at(arena, tokens, token_count, index, @block_id, errors) { return false; }
        var arm = ast::make_match_arm(type_start, type_end, variant_start, variant_end, has_binding, binding_start, binding_end, block_id, type_start, (*arena).blocks[block_id].span.end);
        ast::push_match_arm(arena, arm);
        }
    }
    if (*index) >= token_count or tokens[(*index)].kind != 73 {
        return fail(errors, 112, start, start);
    }
    var end = token_end(tokens[(*index)]);
    (*index) = (*index) + 1;
    if (*index) >= token_count or tokens[(*index)].kind != 65 {
        if (*index) < token_count { return fail(errors, 113, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
        return fail(errors, 113, end, end);
    }
    end = token_end(tokens[(*index)]);
    (*index) = (*index) + 1;
    (*out_stmt) = ast::make_match_stmt(value_expr_id, arm_start, (*arena).match_arms.len - arm_start, start, end);
    return true;
}

fn parse_break_stmt_at(tokens: @token::Token?, token_count: int, index: @int, out_stmt: @ast::Stmt, errors: @array::Array<ast::ParseError>): bool {
    if tokens == null or (*index) >= token_count { return fail(errors, 80, 0, 0); }
    if tokens[(*index)].kind != 77 { return fail(errors, 81, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }

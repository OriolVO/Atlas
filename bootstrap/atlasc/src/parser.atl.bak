import array;
import ast;
import span;
import token;

fn fail(errors: @array::Array<ast::ParseError>, kind: int, start: int, end: int): bool {
    errors.push(ast::make_parse_error(kind, start, end));
    return false;
}

fn token_start(tok: token::Token): int {
    return tok.span.start;
}

fn token_end(tok: token::Token): int {
    return tok.span.end;
}

fn parse_expr_at(
    arena: @ast::Arena,
    tokens: @token::Token?,
    token_count: int,
    index: @int,
    out_expr_id: @int,
    errors: @array::Array<ast::ParseError>
): bool {
    return parse_or_expr(arena, tokens, token_count, index, out_expr_id, errors);
}

fn parse_call_args(
    arena: @ast::Arena,
    tokens: @token::Token?,
    token_count: int,
    index: @int,
    out_child_start: @int,
    out_child_len: @int,
    errors: @array::Array<ast::ParseError>
): bool {
    var args: array::Array<int> = array::Array();
    if tokens == null {
        return fail(errors, 14, 0, 0);
    }
    if (*index) < token_count and tokens[(*index)].kind != 71 {
        while true {
            var arg_id = -1;
            if !parse_expr_at(arena, tokens, token_count, index, @arg_id, errors) {
                return false;
            }
            args.push(arg_id);
            if (*index) < token_count and tokens[(*index)].kind == 66 {
                (*index) = (*index) + 1;
            } else {
                break;
            }
        }
    }
    if (*index) >= token_count or tokens[(*index)].kind != 71 {
        if (*index) < token_count {
            return fail(errors, 15, token_start(tokens[(*index)]), token_end(tokens[(*index)]));
        }
        return fail(errors, 15, 0, 0);
    }
    (*out_child_len) = args.len;
    (*out_child_start) = ast::append_expr_refs(arena, @args);
    return true;
}

fn parse_atomic_expr(
    arena: @ast::Arena,
    tokens: @token::Token?,
    token_count: int,
    index: @int,
    out_expr_id: @int,
    errors: @array::Array<ast::ParseError>
): bool {
    if tokens == null or (*index) >= token_count {
        return fail(errors, 10, 0, 0);
    }
    var tok = tokens[(*index)];
    if tok.kind == 6 {
        var name_start = token_start(tok);
        var name_end = token_end(tok);
        (*index) = (*index) + 1;
        if (*index) < token_count and tokens[(*index)].kind == 55 {
            var save_idx = (*index);
            (*index) = (*index) + 1;
            var target_type = ast::make_empty_type_ref();
            if !parse_type_ref_direct(tokens, token_count, index, @target_type, errors) {
                (*index) = save_idx;
            } else if (*index) >= token_count or tokens[(*index)].kind != 56 {
                (*index) = save_idx;
            } else {
                (*index) = (*index) + 1;
                if (*index) >= token_count or tokens[(*index)].kind != 70 {
                    (*index) = save_idx;
                } else {
                    (*index) = (*index) + 1;
                    var inner_id = -1;
                    if !parse_expr_at(arena, tokens, token_count, index, @inner_id, errors) { return false; }
                    if (*index) >= token_count or tokens[(*index)].kind != 71 {
                        return fail(errors, 19, name_start, name_start);
                    }
                    var end = token_end(tokens[(*index)]);
                    (*index) = (*index) + 1;
                    (*out_expr_id) = inner_id;
                    return true;
                }
            }
        }
        if (*index) < token_count and tokens[(*index)].kind == 63 {
            var start = name_start;
            (*index) = (*index) + 1;
            if (*index) >= token_count or tokens[(*index)].kind != 6 {
                if (*index) < token_count {
                    return fail(errors, 19, token_start(tokens[(*index)]), token_end(tokens[(*index)]));
                }
                return fail(errors, 19, start, start);
            }
            var variant_start = token_start(tokens[(*index)]);
            var variant_end = token_end(tokens[(*index)]);
            (*index) = (*index) + 1;
            if (*index) < token_count and tokens[(*index)].kind == 55 {
                var depth = 1;
                (*index) = (*index) + 1;
                while (*index) < token_count and depth > 0 {
                    if tokens[(*index)].kind == 55 { depth = depth + 1; }
                    else if tokens[(*index)].kind == 56 { depth = depth - 1; }
                    (*index) = (*index) + 1;
                }
            }
            var child_start = 0;
            var child_len = 0;
            var end = variant_end;
            if (*index) < token_count and tokens[(*index)].kind == 70 {
                (*index) = (*index) + 1;
                if !parse_call_args(arena, tokens, token_count, index, @child_start, @child_len, errors) {
                    return false;
                }
                end = token_end(tokens[(*index)]);
                (*index) = (*index) + 1;
            }
            (*out_expr_id) = ast::push_expr(arena, ast::make_variant_expr(name_start, name_end, variant_start, variant_end, child_start, child_len, start, end));
            return true;
        }
        if (*index) + 2 < token_count and tokens[(*index)].kind == 72 and tokens[(*index) + 1].kind == 6 and tokens[(*index) + 2].kind == 64 {
            var start = name_start;
            (*index) = (*index) + 1;
            var field_names: array::Array<span::Span> = array::Array();
            var field_values: array::Array<int> = array::Array();
            if (*index) < token_count and tokens[(*index)].kind != 73 {
                while true {
                    if (*index) >= token_count or tokens[(*index)].kind != 6 {
                        if (*index) < token_count {
                            return fail(errors, 17, token_start(tokens[(*index)]), token_end(tokens[(*index)]));
                        }
                        return fail(errors, 17, start, start);
                    }
                    var field_name = span::make(token_start(tokens[(*index)]), token_end(tokens[(*index)]));
                    (*index) = (*index) + 1;
                    if (*index) >= token_count or tokens[(*index)].kind != 64 {
                        if (*index) < token_count {
                            return fail(errors, 17, token_start(tokens[(*index)]), token_end(tokens[(*index)]));
                        }
                        return fail(errors, 17, field_name.start, field_name.end);
                    }
                    (*index) = (*index) + 1;
                    var value_id = -1;
                    if !parse_expr_at(arena, tokens, token_count, index, @value_id, errors) {
                        return false;
                    }
                    field_names.push(field_name);
                    field_values.push(value_id);
                    if (*index) < token_count and tokens[(*index)].kind == 66 {
                        (*index) = (*index) + 1;
                    } else {
                        break;
                    }
                }
            }
            if (*index) >= token_count or tokens[(*index)].kind != 73 {
                if (*index) < token_count {
                    return fail(errors, 18, token_start(tokens[(*index)]), token_end(tokens[(*index)]));
                }
                return fail(errors, 18, start, start);
            }
            var name_ref_start = ast::append_name_refs(arena, @field_names);
            var child_start = ast::append_expr_refs(arena, @field_values);
            var expr = ast::make_struct_literal_expr(name_start, name_end, name_ref_start, child_start, field_values.len, start, token_end(tokens[(*index)]));
            (*out_expr_id) = ast::push_expr(arena, expr);
            (*index) = (*index) + 1;
            return true;
        }
        if (*index) < token_count and tokens[(*index)].kind == 70 {
            var start = name_start;
            (*index) = (*index) + 1;
            var child_start = 0;
            var child_len = 0;
            if !parse_call_args(arena, tokens, token_count, index, @child_start, @child_len, errors) {
                return false;
            }
            var expr = ast::make_call_expr(name_start, name_end, child_start, child_len, start, token_end(tokens[(*index)]));
            (*out_expr_id) = ast::push_expr(arena, expr);
            (*index) = (*index) + 1;
            return true;
        }
        (*out_expr_id) = ast::push_expr(arena, ast::make_name_expr(name_start, name_end));
        return true;
    }
    if tok.kind == 1 {
        (*out_expr_id) = ast::push_expr(arena, ast::make_int_expr(tok.int_value, token_start(tok), token_end(tok)));
        (*index) = (*index) + 1;
        return true;
    }
    if tok.kind == 2 {
        (*out_expr_id) = ast::push_expr(arena, ast::make_float_expr(token_start(tok), token_end(tok)));
        (*index) = (*index) + 1;
        return true;
    }
    if tok.kind == 3 {
        (*out_expr_id) = ast::push_expr(arena, ast::make_bool_expr(tok.bool_value, token_start(tok), token_end(tok)));
        (*index) = (*index) + 1;
        return true;
    }
    if tok.kind == 4 {
        (*out_expr_id) = ast::push_expr(arena, ast::make_char_expr(tok.char_value, token_start(tok), token_end(tok)));
        (*index) = (*index) + 1;
        return true;
    }
    if tok.kind == 5 {
        (*out_expr_id) = ast::push_expr(arena, ast::make_string_expr(token_start(tok), token_end(tok)));
        (*index) = (*index) + 1;
        return true;
    }
    if tok.kind == 29 or tok.kind == 30 {
        (*out_expr_id) = ast::push_expr(arena, ast::make_name_expr(token_start(tok), token_end(tok)));
        (*index) = (*index) + 1;
        return true;
    }
    if tok.kind == 70 {
        var start = token_start(tok);
        (*index) = (*index) + 1;
        var inner_id = -1;
        if !parse_expr_at(arena, tokens, token_count, index, @inner_id, errors) {
            return false;
        }
        if (*index) >= token_count or tokens[(*index)].kind != 71 {
            if (*index) < token_count {
                return fail(errors, 13, token_start(tokens[(*index)]), token_end(tokens[(*index)]));
            }
            return fail(errors, 13, start, start);
        }
        var refs: array::Array<int> = array::Array();
        refs.push(inner_id);
        var child_start = ast::append_expr_refs(arena, @refs);
        var expr = ast::make_group_expr(child_start, 1, start, token_end(tokens[(*index)]));
        (*out_expr_id) = ast::push_expr(arena, expr);
        (*index) = (*index) + 1;
        return true;
    }
    return fail(errors, 11, token_start(tok), token_end(tok));
}

fn parse_unary_expr(
    arena: @ast::Arena,
    tokens: @token::Token?,
    token_count: int,
    index: @int,
    out_expr_id: @int,
    errors: @array::Array<ast::ParseError>
): bool {
    if tokens != null and (*index) < token_count {
        var tok = tokens[(*index)];
        if tok.kind == 47 or tok.kind == 58 or tok.kind == 27 or tok.kind == 48 or tok.kind == 61 {
            var op_kind = tok.kind;
            var start = token_start(tok);
            (*index) = (*index) + 1;
            var rhs_id = -1;
            if !parse_unary_expr(arena, tokens, token_count, index, @rhs_id, errors) {
                return false;
            }
            var rhs_expr = (*arena).exprs[rhs_id];
            var refs: array::Array<int> = array::Array();
            refs.push(rhs_id);
            var child_start = ast::append_expr_refs(arena, @refs);
            (*out_expr_id) = ast::push_expr(arena, ast::make_binary_expr(op_kind, child_start, 1, start, rhs_expr.span.end));
            return true;
        }
    }
    return parse_primary_expr(arena, tokens, token_count, index, out_expr_id, errors);
}

fn parse_primary_expr(
    arena: @ast::Arena,
    tokens: @token::Token?,
    token_count: int,
    index: @int,
    out_expr_id: @int,
    errors: @array::Array<ast::ParseError>
): bool {
    if !parse_atomic_expr(arena, tokens, token_count, index, out_expr_id, errors) {
        return false;
    }
    if tokens == null {
        return true;
    }
    while true {
        if (*index) < token_count and tokens[(*index)].kind == 68 {
            var base_id = (*out_expr_id);
            var base_expr = (*arena).exprs[base_id];
            (*index) = (*index) + 1;
            if (*index) >= token_count or tokens[(*index)].kind != 6 {
                if (*index) < token_count { return fail(errors, 16, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
                return fail(errors, 16, base_expr.span.end, base_expr.span.end);
            }
            var member_start = token_start(tokens[(*index)]);
            var member_end = token_end(tokens[(*index)]);
            (*index) = (*index) + 1;
            if (*index) < token_count and tokens[(*index)].kind == 55 {
                var depth = 1;
                (*index) = (*index) + 1;
                while (*index) < token_count and depth > 0 {
                    if tokens[(*index)].kind == 55 { depth = depth + 1; }
                    else if tokens[(*index)].kind == 56 { depth = depth - 1; }
                    (*index) = (*index) + 1;
                }
            }
            var refs: array::Array<int> = array::Array();
            refs.push(base_id);
            var child_start = ast::append_expr_refs(arena, @refs);
            (*out_expr_id) = ast::push_expr(arena, ast::make_member_expr(member_start, member_end, child_start, 1, base_expr.span.start, member_end));
        } else if (*index) < token_count and tokens[(*index)].kind == 74 {
            var base_id = (*out_expr_id);
            var base_expr = (*arena).exprs[base_id];
            (*index) = (*index) + 1;
            var idx_expr_id = -1;
            if !parse_expr_at(arena, tokens, token_count, index, @idx_expr_id, errors) { return false; }
            if (*index) >= token_count or tokens[(*index)].kind != 75 {
                if (*index) < token_count { return fail(errors, 16, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
                return fail(errors, 16, base_expr.span.end, base_expr.span.end);
            }
            (*index) = (*index) + 1;
            var refs: array::Array<int> = array::Array();
            refs.push(base_id);
            refs.push(idx_expr_id);
            var child_start = ast::append_expr_refs(arena, @refs);
            (*out_expr_id) = ast::push_expr(arena, ast::make_member_expr(0, 0, child_start, 2, base_expr.span.start, token_end(tokens[(*index) - 1])));
        } else if (*index) < token_count and tokens[(*index)].kind == 63 {
            var base_id = (*out_expr_id);
            var base_expr = (*arena).exprs[base_id];
            (*index) = (*index) + 1;
            if (*index) >= token_count or tokens[(*index)].kind != 6 {
                if (*index) < token_count { return fail(errors, 19, token_start(tokens[(*index)]), token_end(tokens[(*index)])); }
                return fail(errors, 19, base_expr.span.end, base_expr.span.end);
            }
            var variant_start = token_start(tokens[(*index)]);
            var variant_end = token_end(tokens[(*index)]);
            (*index) = (*index) + 1;
            if (*index) < token_count and tokens[(*index)].kind == 55 {
                var depth = 1;
                (*index) = (*index) + 1;
                while (*index) < token_count and depth > 0 {
                    if tokens[(*index)].kind == 55 { depth = depth + 1; }
                    else if tokens[(*index)].kind == 56 { depth = depth - 1; }
                    (*index) = (*index) + 1;
                }
            }
            var child_start = 0;
            var child_len = 0;
            var end = variant_end;
            if (*index) < token_count and tokens[(*index)].kind == 70 {
                (*index) = (*index) + 1;
                if !parse_call_args(arena, tokens, token_count, index, @child_start, @child_len, errors) { return false; }
                end = token_end(tokens[(*index)]);
                (*index) = (*index) + 1;
            }
            var refs: array::Array<int> = array::Array();
            refs.push(base_id);
            var ref_start = ast::append_expr_refs(arena, @refs);
            (*out_expr_id) = ast::push_expr(arena, ast::make_variant_expr(base_expr.span.start, base_expr.span.end, variant_start, variant_end, child_start, child_len, base_expr.span.start, end));
        } else if (*index) < token_count and tokens[(*index)].kind == 70 {
            var base_id = (*out_expr_id);
            var base_expr = (*arena).exprs[base_id];
            (*index) = (*index) + 1;
            var child_start = 0;
            var child_len = 0;
            if !parse_call_args(arena, tokens, token_count, index, @child_start, @child_len, errors) { return false; }
            var end = token_end(tokens[(*index)]);
            (*index) = (*index) + 1;
            var callee_start = base_expr.span.start;
            if base_expr.kind == 9 { callee_start = base_expr.name_span.start; }
            var callee_end = base_expr.span.end;
            if base_expr.kind == 9 { callee_end = base_expr.name_span.end; }
            var expr = ast::make_call_expr(callee_start, callee_end, child_start, child_len, base_expr.span.start, end);
            (*out_expr_id) = ast::push_expr(arena, expr);
        } else {
            break;
        }
    }
    if (*index) < token_count and tokens[(*index)].kind == 62 {
        var base_id = (*out_expr_id);
        var base_expr = (*arena).exprs[base_id];
        var start = token_start(tokens[(*index)]);
        (*index) = (*index) + 1;
        var refs: array::Array<int> = array::Array();
        refs.push(base_id);
        var child_start = ast::append_expr_refs(arena, @refs);
        (*out_expr_id) = ast::push_expr(arena, ast::make_binary_expr(62, child_start, 1, base_expr.span.start, start));
    }
    return true;
}

fn parse_mul_expr(
    arena: @ast::Arena,
    tokens: @token::Token?,
    token_count: int,
    index: @int,
    out_expr_id: @int,
    errors: @array::Array<ast::ParseError>
): bool {
    var lhs_id = -1;
    if !parse_unary_expr(arena, tokens, token_count, index, @lhs_id, errors) {
        return false;
    }
    while (*index) < token_count and (tokens[(*index)].kind == 48 or tokens[(*index)].kind == 49 or tokens[(*index)].kind == 50) {
        var op_kind = tokens[(*index)].kind;
        (*index) = (*index) + 1;
        var rhs_id = -1;
        if !parse_unary_expr(arena, tokens, token_count, index, @rhs_id, errors) {
            return false;
        }
        var refs: array::Array<int> = array::Array();
        refs.push(lhs_id);
        refs.push(rhs_id);
        var child_start = ast::append_expr_refs(arena, @refs);
        var lhs_expr = (*arena).exprs[lhs_id];
        var rhs_expr = (*arena).exprs[rhs_id];
        lhs_id = ast::push_expr(arena, ast::make_binary_expr(op_kind, child_start, 2, lhs_expr.span.start, rhs_expr.span.end));
    }
    (*out_expr_id) = lhs_id;
    return true;
}

fn parse_add_expr(
    arena: @ast::Arena,
    tokens: @token::Token?,
    token_count: int,
    index: @int,
    out_expr_id: @int,
    errors: @array::Array<ast::ParseError>
): bool {
    var lhs_id = -1;
    if !parse_mul_expr(arena, tokens, token_count, index, @lhs_id, errors) {
        return false;
    }
    while (*index) < token_count and (tokens[(*index)].kind == 46 or tokens[(*index)].kind == 47) {
        var op_kind = tokens[(*index)].kind;
        (*index) = (*index) + 1;
        var rhs_id = -1;
        if !parse_mul_expr(arena, tokens, token_count, index, @rhs_id, errors) {
            return false;
        }
        var refs: array::Array<int> = array::Array();
        refs.push(lhs_id);
        refs.push(rhs_id);
        var child_start = ast::append_expr_refs(arena, @refs);
        var lhs_expr = (*arena).exprs[lhs_id];
        var rhs_expr = (*arena).exprs[rhs_id];
        lhs_id = ast::push_expr(arena, ast::make_binary_expr(op_kind, child_start, 2, lhs_expr.span.start, rhs_expr.span.end));
    }
    (*out_expr_id) = lhs_id;
    return true;
}

fn parse_compare_expr(
    arena: @ast::Arena,
    tokens: @token::Token?,
    token_count: int,
    index: @int,
    out_expr_id: @int,
    errors: @array::Array<ast::ParseError>
): bool {
    var lhs_id = -1;
    if !parse_add_expr(arena, tokens, token_count, index, @lhs_id, errors) {
        return false;
    }
    while (*index) < token_count and (tokens[(*index)].kind == 51 or tokens[(*index)].kind == 52 or tokens[(*index)].kind == 53 or tokens[(*index)].kind == 54 or tokens[(*index)].kind == 55 or tokens[(*index)].kind == 56) {
        var op_kind = tokens[(*index)].kind;
        (*index) = (*index) + 1;
        var rhs_id = -1;
        if !parse_add_expr(arena, tokens, token_count, index, @rhs_id, errors) {
            return false;
        }
        var refs: array::Array<int> = array::Array();
        refs.push(lhs_id);
        refs.push(rhs_id);
        var child_start = ast::append_expr_refs(arena, @refs);
        var lhs_expr = (*arena).exprs[lhs_id];
        var rhs_expr = (*arena).exprs[rhs_id];
        lhs_id = ast::push_expr(arena, ast::make_binary_expr(op_kind, child_start, 2, lhs_expr.span.start, rhs_expr.span.end));
    }
    (*out_expr_id) = lhs_id;
    return true;
}

fn parse_and_expr(
    arena: @ast::Arena,
    tokens: @token::Token?,
    token_count: int,
    index: @int,
    out_expr_id: @int,
    errors: @array::Array<ast::ParseError>
): bool {
    var lhs_id = -1;
    if !parse_compare_expr(arena, tokens, token_count, index, @lhs_id, errors) {
        return false;
    }
    while (*index) < token_count and (tokens[(*index)].kind == 59 or tokens[(*index)].kind == 25) {
        var op_kind = tokens[(*index)].kind;
        (*index) = (*index) + 1;
        var rhs_id = -1;
        if !parse_compare_expr(arena, tokens, token_count, index, @rhs_id, errors) {
            return false;
        }
        var refs: array::Array<int> = array::Array();
        refs.push(lhs_id);
        refs.push(rhs_id);
        var child_start = ast::append_expr_refs(arena, @refs);
        var lhs_expr = (*arena).exprs[lhs_id];
        var rhs_expr = (*arena).exprs[rhs_id];
        lhs_id = ast::push_expr(arena, ast::make_binary_expr(op_kind, child_start, 2, lhs_expr.span.start, rhs_expr.span.end));
    }
    (*out_expr_id) = lhs_id;
    return true;
}

fn parse_or_expr(
    arena: @ast::Arena,
    tokens: @token::Token?,
    token_count: int,
    index: @int,
    out_expr_id: @int,
    errors: @array::Array<ast::ParseError>
): bool {
    var lhs_id = -1;
    if !parse_and_expr(arena, tokens, token_count, index, @lhs_id, errors) {
        return false;
    }
    while (*index) < token_count and (tokens[(*index)].kind == 60 or tokens[(*index)].kind == 26) {
        var op_kind = tokens[(*index)].kind;
        (*index) = (*index) + 1;
        var rhs_id = -1;
        if !parse_and_expr(arena, tokens, token_count, index, @rhs_id, errors) {
            return false;
        }
        var refs: array::Array<int> = array::Array();
        refs.push(lhs_id);
        refs.push(rhs_id);
        var child_start = ast::append_expr_refs(arena, @refs);
        var lhs_expr = (*arena).exprs[lhs_id];
        var rhs_expr = (*arena).exprs[rhs_id];
        lhs_id = ast::push_expr(arena, ast::make_binary_expr(op_kind, child_start, 2, lhs_expr.span.start, rhs_expr.span.end));
    }
    (*out_expr_id) = lhs_id;
    return true;
}

fn is_type_token_kind(kind: int): bool {
    return kind == 6 or (kind >= 31 and kind <= 45);
}


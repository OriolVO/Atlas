import resolver;
import ast;
import array;
import string;
import io;
import lexer;
import error;
import token;
import parser;

fn print_chars(chars: []char) {
    var i = 0;
    while i < chars.len {
        io::print_char(chars[i]);
        i = i + 1;
    }
}

fn main(): int {
    var source: array::Array<char> = array::Array();
    source.push('v');
    source.push('a');
    source.push('r');
    source.push(' ');
    source.push('b');
    source.push(' ');
    source.push('=');
    source.push(' ');
    source.push('3');
    source.push('2');
    source.push(';');
    
    var tokens: array::Array<token::Token> = array::Array();
    var lex_errors: array::Array<error::LexError> = array::Array();
    lexer::tokenize(@source, 0, @tokens, @lex_errors);
    
    print_chars("lex_errors=");
    io::print(lex_errors.len);
    print_chars("\n");
    
    var arena = ast::make_empty_arena();
    var parse_errors: array::Array<ast::ParseError> = array::Array();
    var stmt_id = -1;
    var index = 0;
    
    if !parser::parse_first_stmt(@arena, tokens.data, tokens.len, @index, @stmt_id, @parse_errors) {
        print_chars("PARSE_FAIL\n");
        return 1;
    }
    
    print_chars("OK index=");
    io::print(index);
    print_chars("\n");
    return 0;
}

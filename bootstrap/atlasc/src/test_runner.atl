import ast;
import array;
import error;
import io;
import lexer;
import llvm_codegen.native;
import parser;
import span;
import string;
import resolver;
import semantic;
import token;

fn main(): int {
    var arena = ast::make_empty_arena();
    var src: array::Array<char> = array::Array();
    var modules: array::Array<resolver::ModuleInterface> = array::Array();
    var errors: array::Array<ast::ParseError> = array::Array();
    
    var path = string::String::from("bootstrap/atlasc/src/test_input.atl");
    if !resolver::load_and_resolve(@path, @arena, @src, @modules, @errors) {
        io::print_char('P');
        return 0;
    }
    
    var proj = resolver::Project { arena: @arena, source: @src, modules: @modules, prelude_count: 0 };
    resolver::resolve_names(@proj, @errors);
    
    var total_semantic_errors = 0;
    var mi = 0;
    while mi < modules.len {
        var summary = semantic::make_empty_summary();
        var sem_errs: array::Array<semantic::SemanticError> = array::Array();
        semantic::analyze_file(@proj, arena.file_infos[modules[mi].file_info_id], @summary, @sem_errs);
        if sem_errs.len > 0 or errors.len > 0 {
            io::print_char('M'); io::print_char('O'); io::print_char('D');
            var name_sp = modules[mi].name_span;
            if name_sp.start != name_sp.end {
                var ni = name_sp.start;
                while ni < name_sp.end {
                    io::print_char((*proj.source).data[ni]);
                    ni = ni + 1;
                }
            } else {
                io::print_char('?');
            }
            io::print_char('\n');
        }
        var err_i = 0;
        while err_i < sem_errs.len {
            io::print_char('E'); io::print_char('R'); io::print_char('R');
            io::print(sem_errs[err_i].kind);
            io::print_char(' '); io::print_char('\'');
            var span_i = sem_errs[err_i].span.start;
            while span_i < sem_errs[err_i].span.end {
                io::print_char((*proj.source).data[span_i]);
                span_i = span_i + 1;
            }
            io::print_char('\''); io::print_char('\n');
            err_i = err_i + 1;
        }
        total_semantic_errors = total_semantic_errors + sem_errs.len;
        mi = mi + 1;
    }
    
    if total_semantic_errors > 0 {
        io::print_char('S');
        return 0;
    }
    
    var cg = llvm_codegen.native::make_empty_codegen();
    llvm_codegen.native::generate(@cg, @proj);
    
    var ci = 0;
    while ci < cg.output.len { io::print_char(cg.output.data[ci]); ci = ci + 1; }
    
    return 0;
}
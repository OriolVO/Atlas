        var op = expr.op_kind;
        var r = next_temp(g);
        var aty = lhs_ty;

        if op == 46 or op == 49 or op == 50 {
            if !is_unary and try_emit_overloaded_binary_op(g, p, op, r, lhs_reg, rhs_reg, source) {
                return r;
            }
            var opstr = "add";
            if op == 49 { opstr = "sdiv"; }
            if op == 50 { opstr = "srem"; }
            var arith_ty = get_last(g);
            if arith_ty == semantic::type_float() or arith_ty == semantic::type_float64() {
                if op == 46 { opstr = "fadd"; }
                if op == 49 { opstr = "fdiv"; }
                if op == 50 { opstr = "frem"; }
            }
            emit_binop(g, r, opstr, arith_ty, lhs_reg, rhs_reg, p);
            set_last(g, arith_ty);
            return r;
        }
        if op == 47 {
            var arith_ty = get_last(g);
            if is_unary {
                emit_binop_with_zero(g, r, "sub", lhs_reg, p);
            } else {
                var opstr = "sub";
                if arith_ty == semantic::type_float() or arith_ty == semantic::type_float64() { opstr = "fsub"; }
                emit_binop(g, r, opstr, arith_ty, lhs_reg, rhs_reg, p);
            }
            set_last(g, arith_ty);
            return r;
        }
        if op == 48 {
            if is_unary {
                var ptr_ty = get_last(g);
                if semantic::is_pointer_type(ptr_ty) {
                    var target_ty = semantic::type_dereference(ptr_ty);
                    var r = next_temp(g);
                    push_temp(g, r);
                    emit(g, "= load ");
                    if target_ty >= 4000 {
                        var ci2 = target_ty - 4000;
                        if ci2 < (*(*p).arena).classes.len {
                            emit(g, "%class.");
                            var cls = (*(*p).arena).classes[ci2];
                            var ni8 = cls.name_span.start;
                            while ni8 < cls.name_span.end {
                                (*g).output.push((*(*p).source).data[ni8]);
                                ni8 = ni8 + 1;
                            }
                        } else { emit(g, "i64"); }
                    } else if target_ty >= 3000 {
                        var ci3 = target_ty - 3000;
                        if ci3 < (*(*p).arena).choices.len {
                            emit(g, "%choice.");
                            var ch2 = (*(*p).arena).choices[ci3];
                            var ni9 = ch2.name_span.start;
                            while ni9 < ch2.name_span.end {
                                (*g).output.push((*(*p).source).data[ni9]);
                                ni9 = ni9 + 1;
                            }
                        } else { emit(g, "i64"); }
                    } else if target_ty >= 1000 {
                        var si = target_ty - 1000;
                        if si < (*(*p).arena).structs.len {
                            emit(g, "%struct.");
                            var st = (*(*p).arena).structs[si];
                            var ni10 = st.name_span.start;
                            while ni10 < st.name_span.end {
                                (*g).output.push((*(*p).source).data[ni10]);
                                ni10 = ni10 + 1;
                            }
                        } else { emit(g, "i64"); }
                    } else { emit_type(g, target_ty, p); }
                    emit(g, ", ptr ");
                    push_reg(g, lhs_reg);
                    newline(g);
                    set_last(g, target_ty);
                    return r;
                }
                return lhs_reg;
            }
            var arith_ty = get_last(g);
            var opstr = "mul";
            if arith_ty == semantic::type_float() or arith_ty == semantic::type_float64() { opstr = "fmul"; }
            emit_binop(g, r, opstr, arith_ty, lhs_reg, rhs_reg, p);
            set_last(g, arith_ty);
            return r;
        }
        if op == 61 { return lhs_reg; }
        if op == 62 {
            var tag_reg = next_temp(g);
            emit(g, "    ");
            push_temp(g, tag_reg);
            emit(g, "= extractvalue ");
            emit_type(g, lhs_ty, p);
            emit(g, " ");
            push_reg(g, lhs_reg);
            emit(g, ", 0");
            newline(g);
            var zero_reg = next_temp(g);
            emit(g, "    ");
            push_temp(g, zero_reg);
            emit(g, "= add i64 0, 0");
            newline(g);
            var is_ok_reg = next_temp(g);
            emit_icmp(g, is_ok_reg, "eq", semantic::type_int(), tag_reg, zero_reg, p);
            var ok_label = next_label(g);
            var err_label = next_label(g);
            var end_label = next_label(g);
            emit_cond_br(g, is_ok_reg, ok_label, err_label);

            (*g).block_terminated = false;
            emit_label(g, ok_label);
            var payload_reg = next_temp(g);
            emit(g, "    ");
            push_temp(g, payload_reg);
            emit(g, "= extractvalue ");
            emit_type(g, lhs_ty, p);
            emit(g, " ");
            push_reg(g, lhs_reg);
            emit(g, ", 1");
            newline(g);
            emit_br(g, end_label);

            (*g).block_terminated = false;
            emit_label(g, err_label);
            var save_ret = (*g).fn_return_type;
            (*g).fn_return_type = lhs_ty;
            emit_ret(g, lhs_reg, lhs_ty, p);
            (*g).fn_return_type = save_ret;

            (*g).block_terminated = false;
            emit_label(g, end_label);
            var propagated_ty = semantic::type_int();
            if semantic::is_choice_type(lhs_ty) {
                var propagated_choice = (*(*p).arena).choices[lhs_ty - 3000];
                if propagated_choice.variant_len > 0 {
                    var propagated_variant = (*(*p).arena).choice_variants[propagated_choice.variant_start];
                    if propagated_variant.has_payload {
                        var propagated_errors: array::Array<semantic::SemanticError> = array::Array();
                        var propagated_summary = semantic::make_empty_summary();
                        propagated_ty = semantic::resolve_type_ref(p, propagated_variant.payload_type_ref, @propagated_errors, @propagated_summary);
                    }
                }
            }
            set_last(g, propagated_ty);
            return payload_reg;
        }
        if op == 74 {
            var base_ty = get_last(g);
            if base_ty >= 4000 and !is_unary {
                if try_emit_overloaded_binary_op(g, p, 74, r, lhs_reg, rhs_reg, source) {
                    return r;
                }
            }
            var ptr_reg = lhs_reg;
            var idx_reg = rhs_reg;
            var elem_ptr = next_temp(g);
            emit_gep(g, elem_ptr, base_ty, p, ptr_reg, 0, 0);
            var loaded = next_temp(g);
            emit_load_typed(g, loaded, elem_ptr, base_ty, p);
            set_last(g, base_ty);
            return loaded;
        }
        if op == 55 or op == 56 or op == 53 or op == 54 {
            var cmp = "slt";
            if op == 55 { cmp = "slt"; }
            if op == 56 { cmp = "sgt"; }
            if op == 53 { cmp = "sle"; }
            if op == 54 { cmp = "sge"; }
            var cmp_ty = get_last(g);

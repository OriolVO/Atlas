                emit_icmp(g, r, cmp, aty, lhs_reg, rhs_reg, p);
            }
            set_last(g, semantic::type_bool());
            return r;
        }
        if op == 51 {
            var cmp_ty = get_last(g);
            if cmp_ty == semantic::type_float() or cmp_ty == semantic::type_float64() {
                emit_fcmp(g, r, "oeq", cmp_ty, lhs_reg, rhs_reg, p);
            } else {
                emit_icmp(g, r, "eq", aty, lhs_reg, rhs_reg, p);
            }
            set_last(g, semantic::type_bool());
            return r;
        }
        if op == 52 {
            var cmp_ty = get_last(g);
            if cmp_ty == semantic::type_float() or cmp_ty == semantic::type_float64() {
                emit_fcmp(g, r, "one", cmp_ty, lhs_reg, rhs_reg, p);
            } else {
                emit_icmp(g, r, "ne", aty, lhs_reg, rhs_reg, p);
            }
            set_last(g, semantic::type_bool());
            return r;
        }
        if op == 25 or op == 59 {
            if is_unary { return lhs_reg; }
            var and_r = next_temp(g);
            emit_binop(g, and_r, "and", semantic::type_bool(), lhs_reg, rhs_reg, p);
            set_last(g, semantic::type_bool());
            return and_r;
        }
        if op == 26 or op == 60 {
            if is_unary { return lhs_reg; }
            var or_r = next_temp(g);
            emit_binop(g, or_r, "or", semantic::type_bool(), lhs_reg, rhs_reg, p);
            set_last(g, semantic::type_bool());
            return or_r;
        }
        if op == 27 or op == 58 {
            set_last(g, semantic::type_bool());
            var xor_r = next_temp(g);
            var tru_reg = next_temp(g);
            emit(g, "    ");
            push_temp(g, tru_reg);
            emit(g, "= add i1 0, true");
            newline(g);
            emit(g, "    ");
            push_temp(g, xor_r);
            emit(g, "= xor i1 ");
            push_reg(g, lhs_reg);
            emit(g, ", true");
            newline(g);
            return xor_r;
        }

        return r;
    }

    if expr.kind == 6 {
        var callee_name_arr: array::Array<char> = array::Array();
        var si = expr.callee_span.start;
        while si < expr.callee_span.end {
            callee_name_arr.push((*(*p).source).data[si]);
            si = si + 1;
        }

        var param_regs: array::Array<int> = array::Array();
        var param_tys: array::Array<int> = array::Array();
        var j = 0;
        while j < expr.child_len {
            var arg_reg = codegen_expr(g, p, (*(*p).arena).expr_refs[expr.child_start + j], source);
            param_regs.push(arg_reg);
            param_tys.push(get_last(g));
            j = j + 1;
        }

        var ret_reg = -1;
        if param_regs.len > 0 or true {
            ret_reg = next_temp(g);
        }
        var fn_chars: array::Array<char> = array::Array();
        var csi = expr.callee_span.start;
        var csi_end = expr.callee_span.end;
        while csi < csi_end {
            if csi < csi_end - 1 and (*(*p).source).data[csi] == ':' and (*(*p).source).data[csi + 1] == ':' {
                fn_chars.push('.');
                csi = csi + 2;
            } else {
                fn_chars.push((*(*p).source).data[csi]);
                csi = csi + 1;
            }
        }
        var is_ctor = false;
        var ctor_class_id = -1;
        var is_choice_ctor = false;
        var choice_id = -1;
        var variant_id = -1;

        var double_colon_idx = -1;
        var ci_char = expr.callee_span.start;
        while ci_char < expr.callee_span.end - 1 {
            if (*(*p).source).data[ci_char] == ':' and (*(*p).source).data[ci_char + 1] == ':' {
                double_colon_idx = ci_char;
                ci_char = ci_char + 2;
            } else {
                ci_char = ci_char + 1;
            }
        }

        if double_colon_idx >= 0 {
            var choice_span = last_segment(span::make(expr.callee_span.start, double_colon_idx), source);
            var variant_span = span::make(double_colon_idx + 2, expr.callee_span.end);
            var ch_i = 0;
            while ch_i < (*(*p).arena).choices.len {
                var ch = (*(*p).arena).choices[ch_i];
                if semantic::name_equals((*(*p).source).data, ch.name_span, choice_span) {
                    var v_i = 0;
                    while v_i < ch.variant_len {
                        var v = (*(*p).arena).choice_variants[ch.variant_start + v_i];
                        if semantic::name_equals((*(*p).source).data, v.name_span, variant_span) {
                            is_choice_ctor = true;
                            choice_id = ch_i;
                            variant_id = v_i;
                            break;
                        }
                        v_i = v_i + 1;
                    }
                }
                if is_choice_ctor { break; }
                ch_i = ch_i + 1;
            }
        }

        if is_choice_ctor {
            var choice_ty = 3000 + choice_id;
            var tag_reg = next_temp(g);
            emit(g, "    ");
            push_temp(g, tag_reg);
            emit(g, "= insertvalue ");
            emit_type(g, choice_ty, p);
            emit(g, " undef, i64 ");
            emit_int(g, variant_id);
            emit(g, ", 0");
            newline(g);
            var result_reg = tag_reg;
            if param_regs.len > 0 {
                var payload_reg = param_regs[0];
                result_reg = next_temp(g);
                emit(g, "    ");
                push_temp(g, result_reg);
                emit(g, "= insertvalue ");
                emit_type(g, choice_ty, p);
                emit(g, " ");
                push_reg(g, tag_reg);
                emit(g, ", ");
                emit_type(g, param_tys[0], p);
                emit(g, " ");
                push_reg(g, payload_reg);
                emit(g, ", 1");
                newline(g);
            }
            set_last(g, choice_ty);
            return result_reg;
        }

        var positional_struct_id = -1;
        var positional_candidate = last_segment(expr.callee_span, source);
        var positional_struct_i = 0;
        while positional_struct_i < (*(*p).arena).structs.len {
            var positional_struct = (*(*p).arena).structs[positional_struct_i];
            if semantic::name_equals(source.data, positional_struct.name_span, positional_candidate) {
                positional_struct_id = positional_struct_i;
                break;
            }
            positional_struct_i = positional_struct_i + 1;
        }
        if positional_struct_id >= 0 {
            var positional_ty = 1000 + positional_struct_id;
            var positional_value = -1;
            var positional_i = 0;
            while positional_i < param_regs.len {
                var inserted = next_temp(g);
                emit(g, "    ");
                push_temp(g, inserted);
                emit(g, "= insertvalue ");
                emit_type(g, positional_ty, p);
                emit(g, " ");
                if positional_value < 0 {
                    emit(g, "undef");
                } else {
                    push_reg(g, positional_value);
                }
                emit(g, ", ");
                emit_type(g, param_tys[positional_i], p);
                emit(g, " ");
                push_reg(g, param_regs[positional_i]);
                emit(g, ", ");
                emit_int(g, positional_i);
                newline(g);
                positional_value = inserted;
                positional_i = positional_i + 1;
            }
            if positional_value < 0 {
                positional_value = next_temp(g);
                emit(g, "    ");
                push_temp(g, positional_value);
                emit(g, "= insertvalue ");
                emit_type(g, positional_ty, p);
                emit(g, " undef, i64 0, 0");
                newline(g);
            }
            set_last(g, positional_ty);
            return positional_value;
        }

        var ci = 0;
        var constructor_candidate = last_segment(expr.callee_span, source);
        while ci < (*(*p).arena).classes.len {
            var cl = (*(*p).arena).classes[ci];
            if semantic::name_equals((*(*p).source).data, cl.name_span, constructor_candidate) {
                is_ctor = true;
                ctor_class_id = ci;
                break;
            }
            ci = ci + 1;
        }
        if is_ctor {
            if class_name_is(p, 4000 + ctor_class_id, "HashMap") {
                var map_ty = 4000 + ctor_class_id;
                var map_alloca = next_temp(g);
                emit_alloca_typed(g, map_alloca, map_ty, p);
                emit_default_store(g, map_alloca, map_ty, p);
                var malloc_size = next_temp(g);
                emit(g, "    "); push_temp(g, malloc_size); emit(g, "= add i64 0, 8192"); newline(g);
                var malloc_name: array::Array<char> = array::Array();
                malloc_name.push('m'); malloc_name.push('a'); malloc_name.push('l'); malloc_name.push('l'); malloc_name.push('o'); malloc_name.push('c');
                var malloc_regs: array::Array<int> = array::Array();
                var malloc_tys: array::Array<int> = array::Array();
                malloc_regs.push(malloc_size);
                malloc_tys.push(semantic::type_int());
                var map_data = next_temp(g);
                emit_call(g, map_data, malloc_name.data, malloc_name.len, semantic::type_pointer(semantic::type_char(), false), @malloc_regs, @malloc_tys, p);
                var map_entries = next_temp(g);
                emit_gep(g, map_entries, map_ty, p, map_alloca, 0, 0);
                var map_data_field = next_temp(g);
                emit_gep(g, map_data_field, find_named_class_type(p, "Array"), p, map_entries, 0, 0);
                emit_store_typed(g, map_data, map_data_field, semantic::type_pointer(semantic::type_int(), false), p);
                var map_result = next_temp(g);
                emit_load_typed(g, map_result, map_alloca, map_ty, p);
                set_last(g, map_ty);
                return map_result;
            }
            var ctor_chars: array::Array<char> = array::Array();
            var ctor_name = (*(*p).arena).classes[ctor_class_id].name_span;
            var ctor_name_i = ctor_name.start;
            while ctor_name_i < ctor_name.end {
                ctor_chars.push(source.data[ctor_name_i]);
                ctor_name_i = ctor_name_i + 1;
            }
            ctor_chars.push('.');
            ctor_chars.push('i'); ctor_chars.push('n'); ctor_chars.push('i'); ctor_chars.push('t');
            var alloca_reg = next_temp(g);
            emit_alloca_typed(g, alloca_reg, 4000 + ctor_class_id, p);
            emit_default_store(g, alloca_reg, 4000 + ctor_class_id, p);
            var new_regs: array::Array<int> = array::Array();
            var new_tys: array::Array<int> = array::Array();
            new_regs.push(alloca_reg);
            new_tys.push(semantic::type_pointer(4000 + ctor_class_id, false));
            var j2 = 0;
            while j2 < param_regs.len {
                new_regs.push(param_regs[j2]);
                new_tys.push(param_tys[j2]);
                j2 = j2 + 1;
            }
            var ignore_reg = next_temp(g);
            emit_call(g, ignore_reg, ctor_chars.data, ctor_chars.len, semantic::type_void(), @new_regs, @new_tys, p);
            var result_reg = next_temp(g);
            emit_load_typed(g, result_reg, alloca_reg, 4000 + ctor_class_id, p);
            set_last(g, 4000 + ctor_class_id);
            return result_reg;
        } else {
            var call_ret_ty = semantic::type_int();
            var direct_fn_id = find_function_for_codegen(p, expr.callee_span);
            if direct_fn_id >= 0 {
                var direct_info = (*(*p).arena).functions[direct_fn_id];
                if double_colon_idx >= 0 {
                    var qualified_owner = span::make(expr.callee_span.start, double_colon_idx);
                    var qualified_owner_name = last_segment(qualified_owner, source);
                    var owner_is_class = false;
                    var owner_class_id = -1;
                    var owner_i = 0;
                    while owner_i < (*(*p).arena).classes.len {
                        if semantic::name_equals(source.data, (*(*p).arena).classes[owner_i].name_span, qualified_owner_name) {
                            owner_is_class = true;
                            owner_class_id = owner_i;
                            break;
                        }
                        owner_i = owner_i + 1;
                    }
                    fn_chars.len = 0;
                    if owner_is_class {
                        var owner_class_name = (*(*p).arena).classes[owner_class_id].name_span;
                        var owner_name_i = owner_class_name.start;
                        while owner_name_i < owner_class_name.end {
                            fn_chars.push(source.data[owner_name_i]);
                            owner_name_i = owner_name_i + 1;
                        }
                        fn_chars.push('.');
                    }
                    var direct_name_i = direct_info.name_span.start;
                    while direct_name_i < direct_info.name_span.end {
                        fn_chars.push(source.data[direct_name_i]);
                        direct_name_i = direct_name_i + 1;
                    }
                }
                if direct_info.has_return_type {
                    var direct_errors: array::Array<semantic::SemanticError> = array::Array();
                    var direct_summary = semantic::make_empty_summary();
                    call_ret_ty = semantic::resolve_type_ref(p, direct_info.return_type_ref, @direct_errors, @direct_summary);
                } else {
                    call_ret_ty = semantic::type_void();
                }
            }
            if direct_fn_id >= 0 {
                var generic_direct_info = (*(*p).arena).functions[direct_fn_id];
                if generic_direct_info.generic_param_len > 0 and

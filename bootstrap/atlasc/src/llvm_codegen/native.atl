import array;
import ast;
import monomorphizer;
import resolver;
import semantic;
import span;
import string;
import token;

export struct Codegen {
    output: array::Array<char>;
    temp_counter: int;
    label_counter: int;
    str_counter: int;
    fn_is_main: bool;
    fn_return_type: int;
    block_terminated: bool;
    last_type: int;
    current_fn_id: int;
    local_count: int;
    local_name_base: int;
    local_reg_base: int;
    local_type_base: int;
    loop_break: int;
    loop_continue: int;
    scope_depth: int;
    scope_saved_counts: array::Array<int>;
    cleanup_regs: array::Array<int>;
    cleanup_classes: array::Array<int>;
    cleanup_depths: array::Array<int>;
    string_globals: array::Array<char>;
}

export fn make_empty_codegen(): Codegen {
    return Codegen {
        output: array::Array(),
        temp_counter: 0,
        label_counter: 0,
        str_counter: 0,
        fn_is_main: false,
        fn_return_type: semantic::type_unknown(),
        block_terminated: false,
        last_type: semantic::type_int(),
        current_fn_id: -1,
        local_count: 0,
        local_name_base: 0,
        local_reg_base: 0,
        local_type_base: 0,
        loop_break: -1,
        loop_continue: -1,
        scope_depth: 0,
        scope_saved_counts: array::Array(),
        cleanup_regs: array::Array(),
        cleanup_classes: array::Array(),
        cleanup_depths: array::Array(),
        string_globals: array::Array()
    };
}

fn emit(g: @Codegen, text: []char) {
    var i = 0;
    while i < text.len {
        (*g).output.push(text[i]);
        i = i + 1;
    }
}

fn emit_str(g: @Codegen, s: string::String) {
    var i = 0;
    while i < s.len {
        (*g).output.push(s.data[i]);
        i = i + 1;
    }
}

fn newline(g: @Codegen) {
    (*g).output.push('\n');
}

fn next_temp(g: @Codegen): int {
    var t = (*g).temp_counter;
    (*g).temp_counter = t + 1;
    return t;
}

fn next_label(g: @Codegen): int {
    var t = (*g).label_counter;
    (*g).label_counter = t + 1;
    return t;
}

fn push_temp(g: @Codegen, temp: int) {
    emit(g, "%tmp");
    emit_int(g, temp);
    emit(g, " ");
}

fn push_reg(g: @Codegen, reg: int) {
    emit(g, "%tmp");
    emit_int(g, reg);
}

fn llvm_type(ty: int): []char {
    if ty == semantic::type_int() { return "i64"; }
    if ty == semantic::type_bool() { return "i1"; }
    if ty == semantic::type_char() { return "i8"; }
    if ty == semantic::type_float() { return "double"; }
    if ty == semantic::type_float32() { return "float"; }
    if ty == semantic::type_float64() { return "double"; }
    if ty == semantic::type_int8() or ty == semantic::type_uint8() { return "i8"; }
    if ty == semantic::type_int16() or ty == semantic::type_uint16() { return "i16"; }
    if ty == semantic::type_int32() or ty == semantic::type_uint32() { return "i32"; }
    if ty == semantic::type_int64() or ty == semantic::type_uint64() { return "i64"; }
    if ty == semantic::type_uint() { return "i64"; }
    if ty == semantic::type_void() { return "void"; }
    return "i64";
}

fn push_label(g: @Codegen, prefix: []char, num: int) {
    emit(g, prefix);
    emit_int(g, num);
}


fn llvm_type_str(ty: int, p: @resolver::Project, out: @array::Array<char>) {
    if ty >= 1000 and ty < 2000 {
        var si = ty - 1000;
        if si < (*(*p).arena).structs.len {
            emit_chars(out, "%struct.");
            emit_name(out, p, (*(*p).arena).structs[si].name_span);
            return;
        }
    }
    if ty >= 4000 {
        var ci = ty - 4000;
        if ci < (*(*p).arena).classes.len {
            emit_chars(out, "%class.");
            emit_name(out, p, (*(*p).arena).classes[ci].name_span);
            return;
        }
    }
    if ty >= 3000 {
        var ci = ty - 3000;
        if ci < (*(*p).arena).choices.len {
            emit_chars(out, "%choice.");
            emit_name(out, p, (*(*p).arena).choices[ci].name_span);
            return;
        }
    }
    if semantic::is_slice_type(ty) {
        emit_chars(out, "{ ptr, i64 }");
        return;
    }
    if ty == semantic::type_string_literal() {
        emit_chars(out, "{ ptr, i64 }");
        return;
    }
    if semantic::is_pointer_type(ty) {
        llvm_type_str(semantic::type_dereference(ty), p, out);
        emit_chars(out, "*");
        return;
    }
    var base = llvm_type(ty);
    var i = 0;
    while i < base.len {
        (*out).push(base[i]);
        i = i + 1;
    }
}

fn emit_name(out: @array::Array<char>, p: @resolver::Project, name_span: span::Span) {
    var i = name_span.start;
    while i < name_span.end {
        (*out).push((*(*p).source).data[i]);
        i = i + 1;
    }
}

fn emit_chars(out: @array::Array<char>, s: []char) {
    var i = 0;
    while i < s.len {
        (*out).push(s[i]);
        i = i + 1;
    }
}


fn emit_str_buf(buf: @array::Array<char>, text: []char) {
    var i = 0;
    while i < text.len {
        (*buf).push(text[i]);
        i = i + 1;
    }
}

fn emit_int_buf(buf: @array::Array<char>, value: int) {
    var digits: array::Array<int> = array::Array();
    var n = value;
    if n < 0 { n = -n; }
    if n == 0 { digits.push(0); }
    while n > 0 {
        var d = n % 10;
        digits.push(d);
        n = n / 10;
    }
    var i = digits.len - 1;
    while i >= 0 {
        var ch = cast<char>(cast<int>('0') + digits[i]);
        (*buf).push(ch);
        i = i - 1;
    }
}

fn emit_type(g: @Codegen, ty: int, p: @resolver::Project) {
    var buf: array::Array<char> = array::Array();
    llvm_type_str(ty, p, @buf);
    var i = 0;
    while i < buf.len {
        (*g).output.push(buf[i]);
        i = i + 1;
    }
}

fn emit_store_typed(g: @Codegen, src_reg: int, dst_reg: int, ty: int, p: @resolver::Project) {
    emit(g, "    store ");
    emit_type(g, ty, p);
    emit(g, " ");
    push_reg(g, src_reg);
    emit(g, ", ");
    emit_type(g, ty, p);
    emit(g, "* ");
    push_reg(g, dst_reg);
    newline(g);
}

fn emit_load_typed(g: @Codegen, dest_reg: int, src_reg: int, ty: int, p: @resolver::Project) {
    push_temp(g, dest_reg);
    emit(g, "= load ");
    emit_type(g, ty, p);
    emit(g, ", ");
    emit_type(g, ty, p);
    emit(g, "* ");
    push_reg(g, src_reg);
    newline(g);
}

fn emit_alloca_typed(g: @Codegen, dest_reg: int, ty: int, p: @resolver::Project) {
    push_temp(g, dest_reg);
    emit(g, "= alloca ");
    emit_type(g, ty, p);
    newline(g);
}

fn emit_gep(g: @Codegen, dest_reg: int, base_ty: int, p: @resolver::Project, base_reg: int, index0: int, index1: int) {
    push_temp(g, dest_reg);
    emit(g, "= getelementptr inbounds ");
    emit_type(g, base_ty, p);
    emit(g, ", ");
    emit_type(g, base_ty, p);
    emit(g, "* ");
    push_reg(g, base_reg);
    emit(g, ", i32 ");
    emit_int(g, index0);
    emit(g, ", i32 ");
    emit_int(g, index1);
    newline(g);
}

fn emit_insertvalue(g: @Codegen, dest_reg: int, base_ty: int, p: @resolver::Project, base_reg: int, val_reg: int, idx: int, agg_ty: int) {
    push_temp(g, dest_reg);
    emit(g, "= insertvalue ");
    emit_type(g, agg_ty, p);
    emit(g, " ");
    push_reg(g, base_reg);
    emit(g, ", ");
    emit_type(g, base_ty, p);
    emit(g, " ");
    push_reg(g, val_reg);
    emit(g, ", ");
    emit_int(g, idx);
    newline(g);
}

fn emit_aggregate_decl(g: @Codegen, p: @resolver::Project, name: []char, fields: @array::Array<int>) {
    emit(g, name);
    emit(g, " = type { ");
    var f = 0;
    while f < fields.len {
        if f > 0 { emit(g, ", "); }
        emit_type(g, fields[f], p);
        f = f + 1;
    }
    emit(g, " }");
    newline(g);
}

fn emit_aggregate_types(g: @Codegen, p: @resolver::Project) {
    var s = 0;
    while s < (*(*p).arena).structs.len {
        var si = (*(*p).arena).structs[s];
        emit(g, "%struct.");
        emit_name(@(*g).output, p, si.name_span);
        emit(g, " = type { ");
        var f = 0;
        while f < si.field_len {
            if f > 0 { emit(g, ", "); }
            var field = (*(*p).arena).struct_fields[si.field_start + f];
            var fty = resolve_type_simple(p, field.type_ref);
            emit_type(g, fty, p);
            f = f + 1;
        }
        emit(g, " }");
        newline(g);
        s = s + 1;
    }

    var c = 0;
    while c < (*(*p).arena).classes.len {
        var ci = (*(*p).arena).classes[c];
        emit(g, "%class.");
        emit_name(@(*g).output, p, ci.name_span);
        emit(g, " = type { ");
        var f = 0;
        while f < ci.field_len {
            if f > 0 { emit(g, ", "); }
            var field = (*(*p).arena).class_fields[ci.field_start + f];
            var fty = resolve_type_simple(p, field.type_ref);
            emit_type(g, fty, p);
            f = f + 1;
        }
        emit(g, " }");
        newline(g);
        c = c + 1;
    }

    var ch = 0;
    while ch < (*(*p).arena).choices.len {
        var chi = (*(*p).arena).choices[ch];
        emit(g, "%choice.");
        emit_name(@(*g).output, p, chi.name_span);
        emit(g, " = type { i64, i64 }");
        newline(g);
        ch = ch + 1;
    }
    newline(g);
}

fn emit_chr(g: @Codegen, s: []char) {
    var i = 0;
    while i < s.len {
        (*g).output.push(s[i]);
        i = i + 1;
    }
}

fn struct_llvm_type_name(g: @Codegen, p: @resolver::Project, ty: int): int {
    if ty >= 1000 and ty < 2000 { return ty - 1000; }
    if ty >= 4000 { return ty - 3900; }
    return -1;
}

fn resolve_type_simple(p: @resolver::Project, type_ref: ast::TypeRef): int {
    if type_ref.token_kind == 31 { return semantic::type_int(); }
    if type_ref.token_kind == 44 { return semantic::type_bool(); }
    if type_ref.token_kind == 45 { return semantic::type_char(); }
    if type_ref.token_kind == 41 { return semantic::type_float(); }
    if type_ref.token_kind == 42 { return semantic::type_float32(); }
    if type_ref.token_kind == 43 { return semantic::type_float64(); }
    if type_ref.token_kind == 0 { return semantic::type_unknown(); }
    if type_ref.token_kind == 3 { return semantic::type_null(); }
    if type_ref.token_kind == 61 {
        var inner = resolve_inner_pointer_type(p, type_ref);
        return semantic::type_pointer(inner, false);
    }
    if type_ref.token_kind == 62 {
        var inner = resolve_inner_pointer_type(p, type_ref);
        return semantic::type_pointer(inner, true);
    }
    if type_ref.token_kind == 6 {
        if type_ref.resolved_def_id >= 0 and type_ref.resolved_def_id < (*(*p).arena).items.len {
            var item = (*(*p).arena).items[type_ref.resolved_def_id];
            if item.kind == 2 { return 1000 + item.struct_id; }
            if item.kind == 3 { return 2000 + item.enum_id; }
            if item.kind == 4 { return 3000 + item.choice_id; }
            if item.kind == 6 { return 4000 + item.class_id; }
        }
        return semantic::type_int();
    }
    if type_ref.token_kind == 1 { return semantic::type_pointer(semantic::type_int(), false); }
    if type_ref.token_kind == 2 { return semantic::type_pointer(semantic::type_int(), true); }
    return semantic::type_int();
}

fn resolve_inner_pointer_type(p: @resolver::Project, type_ref: ast::TypeRef): int {
    if type_ref.resolved_def_id >= 0 and type_ref.resolved_def_id < (*(*p).arena).items.len {
        var item = (*(*p).arena).items[type_ref.resolved_def_id];
        if item.kind == 2 { return 1000 + item.struct_id; }
        if item.kind == 3 { return 2000 + item.enum_id; }
        if item.kind == 4 { return 3000 + item.choice_id; }
        if item.kind == 6 { return 4000 + item.class_id; }
    }
    return semantic::type_int();
}

fn emit_aggregate_type(g: @Codegen, p: @resolver::Project, name: []char, fields: @array::Array<int>) {
    emit(g, name);
    emit(g, " = type { ");
    var f = 0;
    while f < fields.len {
        if f > 0 { emit(g, ", "); }
        var ft: array::Array<char> = array::Array();
        llvm_type_str(fields[f], p, @ft);
        var fi = 0;
        while fi < ft.len { (*g).output.push(ft[fi]); fi = fi + 1; }
        f = f + 1;
    }
    emit(g, " }");
    newline(g);
}

fn llvm_ty_string(ty: []char, out: @array::Array<char>) {
    var i = 0;
    while i < ty.len {
        (*out).push(ty[i]);
        i = i + 1;
    }
}

fn emit_int(g: @Codegen, value: int) {
    if value == 0 {
        emit(g, "0");
        return;
    }
    var negative = value < 0;
    if negative { value = -value; }
    var digits: array::Array<char> = array::Array();
    while value > 0 {
        var d = value % 10;
        digits.push(cast<char>(cast<int>('0') + d));
        value = value / 10;
    }
    if negative { emit(g, "-"); }
    var i = digits.len - 1;
    while i >= 0 {
        (*g).output.push(digits[i]);
        i = i - 1;
    }
}

fn emit_zero(g: @Codegen, ty: int) {
    if ty == semantic::type_float() or ty == semantic::type_float64() {
        emit(g, "0.0");
    } else if ty == semantic::type_float32() {
        emit(g, "0.0");
    } else if ty == semantic::type_bool() {
        emit(g, "false");
    } else if semantic::is_pointer_type(ty) {
        emit(g, "null");
    } else {
        emit(g, "0");
    }
}

fn emit_int_value(g: @Codegen, value: int) {
    emit_int(g, value);
}

fn bool_str(value: bool): []char {
    if value { return "true"; }
    return "false";
}

fn set_last(g: @Codegen, ty: int) { (*g).last_type = ty; }
fn get_last(g: @Codegen): int { return (*g).last_type; }
fn emit_zext_i1_to_i64(g: @Codegen, src_reg: int): int { var r = next_temp(g); emit(g, "    "); push_temp(g, r); emit(g, "= zext i1 "); push_reg(g, src_reg); emit(g, " to i64"); newline(g); return r; }

fn lookup_local(g: @Codegen, p: @resolver::Project, name: span::Span): int {
    var fn_id = (*g).current_fn_id;
    if fn_id >= 0 { var fi = (*(*p).arena).functions[fn_id]; var pi = 0; while pi < fi.param_len { var pr = (*(*p).arena).params[fi.param_start + pi]; if semantic::name_equals((*(*p).source).data, pr.name_span, name) { return 100 + pi; } pi = pi + 1; } }
    var limit = (*g).local_name_base + (*g).local_count - 1;
    var ni = limit;
    while ni >= (*g).local_name_base { var n = (*(*p).arena).name_refs[ni]; if semantic::name_equals((*(*p).source).data, n, name) { var offset = ni - (*g).local_name_base; return (*(*p).arena).expr_refs[(*g).local_reg_base + offset]; } ni = ni - 1; }
    return -1;
}

fn lookup_local_type(g: @Codegen, p: @resolver::Project, name: span::Span): int { var fn_id = (*g).current_fn_id; if fn_id >= 0 { var fi = (*(*p).arena).functions[fn_id]; var pi = 0; while pi < fi.param_len { var pr = (*(*p).arena).params[fi.param_start + pi]; if semantic::name_equals((*(*p).source).data, pr.name_span, name) { var pty = semantic::type_int(); if pr.has_type_hint { var errors: array::Array<semantic::SemanticError> = array::Array(); var summary = semantic::make_empty_summary(); pty = semantic::resolve_type_ref(p, pr.type_ref, @errors, @summary); } return pty; } pi = pi + 1; } } var limit = (*g).local_name_base + (*g).local_count - 1; var ni = limit; while ni >= (*g).local_name_base { var n = (*(*p).arena).name_refs[ni]; if semantic::name_equals((*(*p).source).data, n, name) { var offset = ni - (*g).local_name_base; return (*(*p).arena).stmt_refs[(*g).local_type_base + offset]; } ni = ni - 1; } return semantic::type_int(); }

fn register_local(g: @Codegen, p: @resolver::Project, name: span::Span, ty: int, reg: int) { var arena = (*p).arena; if (*g).local_count == 0 { (*g).local_name_base = (*arena).name_refs.len; (*g).local_reg_base = (*arena).expr_refs.len; (*g).local_type_base = (*arena).stmt_refs.len; } (*arena).name_refs.push(name); (*arena).expr_refs.push(reg); (*arena).stmt_refs.push(ty); (*g).local_count = (*g).local_count + 1; }

fn push_loop(g: @Codegen, break_label: int, continue_label: int) { (*g).loop_break = break_label; (*g).loop_continue = continue_label; }

fn pop_loop(g: @Codegen, old_break: int, old_continue: int) { (*g).loop_break = old_break; (*g).loop_continue = old_continue; }

fn push_scope(g: @Codegen) { (*g).scope_saved_counts.push((*g).local_count); (*g).scope_depth = (*g).scope_depth + 1; }

fn pop_scope(g: @Codegen) { if (*g).scope_depth > 0 { (*g).scope_depth = (*g).scope_depth - 1; (*g).local_count = (*g).scope_saved_counts[(*g).scope_depth]; } }

fn register_cleanup(g: @Codegen, reg: int, class_ty: int) {
    (*g).cleanup_regs.push(reg);
    (*g).cleanup_classes.push(class_ty);
    (*g).cleanup_depths.push((*g).scope_depth);
}

fn emit_cleanups_to_depth(g: @Codegen, p: @resolver::Project, min_depth: int) {
    while (*g).cleanup_regs.len > 0 {
        var last_idx = (*g).cleanup_regs.len - 1;
        var cleanup_depth = (*g).cleanup_depths[last_idx];
        if cleanup_depth < min_depth { break; }
        var reg = (*g).cleanup_regs[last_idx];
        var class_ty = (*g).cleanup_classes[last_idx];
        var ci = class_ty - 4000;
        if ci >= 0 and ci < (*(*p).arena).classes.len {
            var class_info = (*(*p).arena).classes[ci];
            emit(g, "    call void @\"");
            emit_name(@(*g).output, p, class_info.name_span);
            emit(g, ".destroy\"(");
            emit_type(g, class_ty, p);
            emit(g, "* ");
            push_reg(g, reg);
            emit(g, ")");
            newline(g);
        }
        (*g).cleanup_regs.len = (*g).cleanup_regs.len - 1;
        (*g).cleanup_classes.len = (*g).cleanup_classes.len - 1;
        (*g).cleanup_depths.len = (*g).cleanup_depths.len - 1;
    }
}

fn emit_all_cleanups(g: @Codegen, p: @resolver::Project) {
    emit_cleanups_to_depth(g, p, 0);
}

fn emit_alloca(g: @Codegen, dest_reg: int, atype: int) { push_temp(g, dest_reg); emit(g, "= alloca "); emit(g, llvm_type(atype)); newline(g); }

fn emit_store(g: @Codegen, src_reg: int, dst_reg: int, atype: int) { emit(g, "    store "); emit(g, llvm_type(atype)); emit(g, " "); push_reg(g, src_reg); emit(g, ", "); emit(g, llvm_type(atype)); emit(g, "* "); push_reg(g, dst_reg); newline(g); }

fn emit_load(g: @Codegen, dest_reg: int, src_reg: int, atype: int) { push_temp(g, dest_reg); emit(g, "= load "); emit(g, llvm_type(atype)); emit(g, ", "); emit(g, llvm_type(atype)); emit(g, "* "); push_reg(g, src_reg); newline(g); }

fn emit_binop(g: @Codegen, dest_reg: int, op: []char, atype: int, lhs_reg: int, rhs_reg: int, p: @resolver::Project) {
    push_temp(g, dest_reg);
    emit(g, "= ");
    emit(g, op);
    emit(g, " ");
    emit_type(g, atype, p);
    emit(g, " ");
    push_reg(g, lhs_reg);
    emit(g, ", ");
    push_reg(g, rhs_reg);
    newline(g);
}

fn emit_icmp(g: @Codegen, dest_reg: int, cmp: []char, atype: int, lhs_reg: int, rhs_reg: int, p: @resolver::Project) {
    push_temp(g, dest_reg);
    emit(g, "= icmp ");
    emit(g, cmp);
    emit(g, " ");
    emit_type(g, atype, p);
    emit(g, " ");
    push_reg(g, lhs_reg);
    emit(g, ", ");
    push_reg(g, rhs_reg);
    newline(g);
}

fn emit_fcmp(g: @Codegen, dest_reg: int, cmp: []char, atype: int, lhs_reg: int, rhs_reg: int, p: @resolver::Project) {
    push_temp(g, dest_reg);
    emit(g, "= fcmp ");
    emit(g, cmp);
    emit(g, " ");
    emit_type(g, atype, p);
    emit(g, " ");
    push_reg(g, lhs_reg);
    emit(g, ", ");
    push_reg(g, rhs_reg);
    newline(g);
}

fn emit_br(g: @Codegen, label: int) {
    emit(g, "    br label %");
    emit(g, "block");
    emit_int(g, label);
    newline(g);
}

fn emit_cond_br(g: @Codegen, cond_reg: int, then_label: int, else_label: int) {
    emit(g, "    br i1 ");
    push_reg(g, cond_reg);
    emit(g, ", label %");
    emit(g, "block");
    emit_int(g, then_label);
    emit(g, ", label %");
    emit(g, "block");
    emit_int(g, else_label);
    newline(g);
}

fn emit_label(g: @Codegen, label: int) {
    emit(g, "block");
    emit_int(g, label);
    emit(g, ":");
    newline(g);
}

fn emit_call(g: @Codegen, dest_reg: int, fn_name: @char?, fn_len: int, ret_ty: int, param_regs: @array::Array<int>, param_types: @array::Array<int>, p: @resolver::Project) {
    emit(g, "    ");
    if ret_ty != type_void_val() {
        push_temp(g, dest_reg);
        emit(g, "= ");
    }
    emit(g, "call ");
    emit_type(g, ret_ty, p);
    emit(g, " @\"");
    var ni = 0;
    while ni < fn_len {
        (*g).output.push(fn_name[ni]);
        ni = ni + 1;
    }
    emit(g, "\"(");
    var i = 0;
    while i < param_regs.len {
        if i > 0 { emit(g, ", "); }
        emit_type(g, param_types[i], p);
        emit(g, " ");
        push_reg(g, param_regs[i]);
        i = i + 1;
    }
    emit(g, ")");
    newline(g);
}

fn emit_ret(g: @Codegen, reg: int, ty: int) {
    emit(g, "    ret ");
    emit(g, llvm_type(ty));
    emit(g, " ");
    if reg >= 0 {
        push_reg(g, reg);
    } else {
        emit_zero(g, ty);
    }
    newline(g);
    (*g).block_terminated = true;
}

fn emit_ret_void(g: @Codegen) {
    emit(g, "    ret void");
    newline(g);
    (*g).block_terminated = true;
}

fn emit_module_header(g: @Codegen, source_name: []char) {
    emit(g, "source_filename = \"");
    emit(g, source_name);
    emit(g, "\"");
    newline(g);
    emit(g, "target datalayout = \"e-m:e-p270:32:32-p271:32:32-p272:64:64-i64:64-i128:128-f80:128-n8:16:32:64-S128\"");
    newline(g);
    emit(g, "target triple = \"x86_64-unknown-linux-gnu\"");
    newline(g);
    newline(g);
}

fn codegen_expr(g: @Codegen, p: @resolver::Project, expr_id: int, source: @array::Array<char>): int {
    if expr_id < 0 { return -1; }
    var expr = (*(*p).arena).exprs[expr_id];

    if expr.kind == 2 {
        var r = next_temp(g);
        emit(g, "    ");
        push_temp(g, r);
        emit(g, "= add i64 0, ");
        emit_int_value(g, expr.int_value);
        newline(g);
        set_last(g, semantic::type_int());
        return r;
    }

    if expr.kind == 3 {
        var r = next_temp(g);
        emit(g, "    ");
        push_temp(g, r);
        emit(g, "= add i1 0, ");
        emit(g, bool_str(expr.bool_value));
        newline(g);
        set_last(g, semantic::type_bool());
        return r;
    }

    if expr.kind == 12 {
        var r = next_temp(g);
        emit(g, "    ");
        push_temp(g, r);
        emit(g, "= fadd double 0.0, "); var fi = expr.span.start; while fi < expr.span.end { (*g).output.push((*(*p).source).data[fi]); fi = fi + 1; } newline(g); set_last(g, semantic::type_float()); return r;
    }

    if expr.kind == 13 {
        if expr.child_len == 0 {
            var r = next_temp(g);
            emit(g, "    ");
            push_temp(g, r);
            emit(g, "= add i64 0, 0");
            newline(g);
            set_last(g, semantic::type_int());
            return r;
        }
        var elem_type = semantic::type_int();
        {
            var errors: array::Array<semantic::SemanticError> = array::Array();
            var summary = semantic::make_empty_summary();
            var first_child = (*(*p).arena).exprs[(*(*p).arena).expr_refs[expr.child_start]];
            if first_child.kind == 2 { elem_type = semantic::type_int(); }
            else if first_child.kind == 3 { elem_type = semantic::type_bool(); }
            else if first_child.kind == 7 { elem_type = semantic::type_char(); }
            else if first_child.kind == 12 { elem_type = semantic::type_float(); }
        }
        var arr_ptr = next_temp(g);
        emit_alloca(g, arr_ptr, elem_type);
        var i = 0;
        while i < expr.child_len {
            var elem_reg = codegen_expr(g, p, (*(*p).arena).expr_refs[expr.child_start + i], source);
            var elem_ptr = next_temp(g);
            emit_gep(g, elem_ptr, elem_type, p, arr_ptr, 0, i);
            if elem_type >= 1000 {
                emit_store_typed(g, elem_reg, elem_ptr, elem_type, p);
            } else {
                emit_store(g, elem_reg, elem_ptr, elem_type);
            }
            i = i + 1;
        }
        set_last(g, elem_type);
        return arr_ptr;
    }

    if expr.kind == 14 {
        var receiver_reg = -1;
        if expr.child_len > 0 {
            receiver_reg = codegen_expr(g, p, (*(*p).arena).expr_refs[expr.child_start], source);
        } else {
            receiver_reg = lookup_local(g, p, expr.callee_span);
            if receiver_reg < 0 {
                var r2 = next_temp(g);
                emit(g, "    ");
                push_temp(g, r2);
                emit(g, "= add i64 0, 0");
                newline(g);
                set_last(g, semantic::type_int());
                return r2;
            }
            var ty2 = lookup_local_type(g, p, expr.callee_span);
            var r3 = next_temp(g);
            if ty2 >= 1000 or ty2 >= 2000 or ty2 >= 3000 or ty2 >= 4000 {
                emit_load_typed(g, r3, receiver_reg, ty2, p);
            } else {
                emit_load(g, r3, receiver_reg, ty2);
            }
            set_last(g, ty2);
            receiver_reg = r3;
        }
        var r = next_temp(g);
        var method_fn_id = -1;
        var found_class_id = -1;
        var ci = 0;
        while ci < (*(*p).arena).classes.len and method_fn_id < 0 {
            var cl = (*(*p).arena).classes[ci];
            var mi = 0;
            while mi < cl.method_len {
                var cm = (*(*p).arena).class_methods[cl.method_start + mi];
                var mfunc = (*p).arena.functions[cm.function_id];
                if semantic::name_equals((*(*p).source).data, mfunc.name_span, expr.name_span) {
                    method_fn_id = cm.function_id;
                    found_class_id = ci;
                    break;
                }
                mi = mi + 1;
            }
            ci = ci + 1;
        }

        if method_fn_id < 0 {
            var r = next_temp(g);
            emit(g, "    ");
            push_temp(g, r);
            emit(g, "= add i64 0, 0");
            newline(g);
            set_last(g, semantic::type_int());
            return r;
        }

        var method_info = (*p).arena.functions[method_fn_id];

        var param_regs: array::Array<int> = array::Array();
        var param_tys: array::Array<int> = array::Array();
        param_regs.push(receiver_reg);
        param_tys.push(semantic::type_int());

        var ai = 0;
        while ai < expr.child_len {
            var arg_reg = codegen_expr(g, p, (*(*p).arena).expr_refs[expr.child_start + ai], source);
            param_regs.push(arg_reg);
            param_tys.push(get_last(g));
            ai = ai + 1;
        }

        var ret_ty = semantic::type_int();
        if method_info.has_return_type {
            var errors: array::Array<semantic::SemanticError> = array::Array();
            var summary = semantic::make_empty_summary();
            ret_ty = semantic::resolve_type_ref(p, method_info.return_type_ref, @errors, @summary);
        }

        var ret_reg = next_temp(g);
        var fn_chars: array::Array<char> = array::Array();
        var csi = method_info.name_span.start;
        while csi < method_info.name_span.end {
            fn_chars.push((*(*p).source).data[csi]);
            csi = csi + 1;
        }
        emit_call(g, ret_reg, fn_chars.data, fn_chars.len, ret_ty, @param_regs, @param_tys, p);
        set_last(g, ret_ty);
        return ret_reg;
    }

    if expr.kind == 15 {
        if expr.child_len == 0 { return -1; }
        var src_reg = codegen_expr(g, p, (*(*p).arena).expr_refs[expr.child_start], source);
        var from_ty = get_last(g);
        var to_ty = resolve_type_simple(p, ast::make_type_ref(6, expr.name_span.start, expr.name_span.end));
        if to_ty == semantic::type_unknown() {
            to_ty = semantic::type_int();
        }
        var r = next_temp(g);
        var cast_op = "trunc";
        var from_is_float = (from_ty == semantic::type_float() or from_ty == semantic::type_float64() or from_ty == semantic::type_float32());
        var to_is_float = (to_ty == semantic::type_float() or to_ty == semantic::type_float64() or to_ty == semantic::type_float32());
        var from_is_ptr = semantic::is_pointer_type(from_ty);
        var to_is_ptr = semantic::is_pointer_type(to_ty);

        if from_is_float and !to_is_float {
            cast_op = "fptosi";
        } else if !from_is_float and to_is_float {
            cast_op = "sitofp";
        } else if from_is_float and to_is_float {
            if from_ty == semantic::type_float32() and (to_ty == semantic::type_float64() or to_ty == semantic::type_float()) {
                cast_op = "fpext";
            } else {
                cast_op = "fptrunc";
            }
        } else if from_is_ptr and !to_is_ptr {
            cast_op = "ptrtoint";
        } else if !from_is_ptr and to_is_ptr {
            cast_op = "inttoptr";
        } else {
            cast_op = "trunc";
        }

        emit(g, "    ");
        push_temp(g, r);
        emit(g, "= ");
        emit(g, cast_op);
        emit(g, " ");
        emit_type(g, from_ty, p);
        emit(g, " ");
        push_reg(g, src_reg);
        emit(g, " to ");
        emit_type(g, to_ty, p);
        newline(g);
        set_last(g, to_ty);
        return r;
    }

    if expr.kind == 16 {
        var ty = resolve_type_simple(p, ast::make_type_ref(6, expr.name_span.start, expr.name_span.end));
        var size = semantic::type_int(ty);
        var r = next_temp(g);
        emit(g, "    ");
        push_temp(g, r);
        emit(g, "= add i64 0, ");
        emit_int(g, size);
        newline(g);
        set_last(g, semantic::type_int());
        return r;
    }

    if expr.kind == 17 {
        if expr.child_len == 0 { return -1; }
        var target_reg = codegen_expr(g, p, (*(*p).arena).expr_refs[expr.child_start], source);
        var ty = resolve_type_simple(p, ast::make_type_ref(6, expr.name_span.start, expr.name_span.end));
        emit(g, "    call void @\"");
        {
            var errors: array::Array<semantic::SemanticError> = array::Array();
            var summary = semantic::make_empty_summary();
        }
        var ni = expr.name_span.start;
        while ni < expr.name_span.end {
            (*g).output.push(source.data[ni]);
            ni = ni + 1;
        }
        emit(g, ".destroy\"(");
        emit_type(g, ty, p);
        emit(g, "* ");
        push_reg(g, target_reg);
        emit(g, ")");
        newline(g);
        set_last(g, semantic::type_int());
        return target_reg;
    }

    if expr.kind == 18 {
        var type_name = expr.callee_span;
        var method_name = expr.name_span;
        var ci = 0;
        var found_fn_id = -1;
        while ci < (*(*p).arena).classes.len and found_fn_id < 0 {
            var class_info = (*(*p).arena).classes[ci];
            if semantic::name_equals((*(*p).source).data, class_info.name_span, type_name) {
                var mi = 0;
                while mi < class_info.method_len {
        var cm = (*(*p).arena).class_methods[class_info.method_start + mi];
                    var mfunc = (*p).arena.functions[cm.function_id];
                    if semantic::name_equals((*(*p).source).data, mfunc.name_span, method_name) {
                        found_fn_id = cm.function_id;
                        break;
                    }
                    mi = mi + 1;
                }
            }
            ci = ci + 1;
        }
        if found_fn_id >= 0 {
            var method_info = (*p).arena.functions[found_fn_id];
            var param_regs: array::Array<int> = array::Array();
            var param_tys: array::Array<int> = array::Array();
            var ai = 0;
            while ai < expr.child_len {
                var arg_reg = codegen_expr(g, p, (*(*p).arena).expr_refs[expr.child_start + ai], source);
                param_regs.push(arg_reg);
                param_tys.push(get_last(g));
                ai = ai + 1;
            }
            var ret_ty = semantic::type_int();
            if method_info.has_return_type {
                var errors: array::Array<semantic::SemanticError> = array::Array();
                var summary = semantic::make_empty_summary();
                ret_ty = semantic::resolve_type_ref(p, method_info.return_type_ref, @errors, @summary);
            }
            var ret_reg = next_temp(g);
            var fn_chars: array::Array<char> = array::Array();
            var csi = method_info.name_span.start;
            while csi < method_info.name_span.end {
                fn_chars.push(source.data[csi]);
                csi = csi + 1;
            }
            emit_call(g, ret_reg, fn_chars.data, fn_chars.len, ret_ty, @param_regs, @param_tys, p);
            set_last(g, ret_ty);
            return ret_reg;
        }
        var enum_idx = -1;
        var ei = 0;
        while ei < (*p).arena.enums.len {
            var ei2 = (*p).arena.enums[ei];
            if semantic::name_equals((*(*p).source).data, ei2.name_span, type_name) { enum_idx = ei; break; }
            ei = ei + 1;
        }
        if enum_idx >= 0 {
            var r = next_temp(g);
            emit(g, "    ");
            push_temp(g, r);
            emit(g, "= add i64 0, 0");
            newline(g);
            set_last(g, 2000 + enum_idx);
            return r;
        }
        var choice_idx = -1;
        var chi = 0;
        while chi < (*p).arena.choices.len {
            var chi2 = (*p).arena.choices[chi];
            if semantic::name_equals((*(*p).source).data, chi2.name_span, type_name) { choice_idx = chi; break; }
            chi = chi + 1;
        }
        if choice_idx >= 0 {
            var variant_idx = -1;
            var choice_info = (*p).arena.choices[choice_idx];
            var vi = 0;
            while vi < choice_info.variant_len {
                var v = (*p).arena.choice_variants[choice_info.variant_start + vi];
                if semantic::name_equals((*(*p).source).data, v.name_span, method_name) { variant_idx = vi; break; }
                vi = vi + 1;
            }
            var r = next_temp(g);
            if variant_idx >= 0 {
                var payload_reg = -1;
                if expr.child_len > 0 {
                    payload_reg = codegen_expr(g, p, (*(*p).arena).expr_refs[expr.child_start], source);
                }
                emit(g, "    ");
                push_temp(g, r);
                emit(g, "= insertvalue ");
                emit_type(g, 3000 + choice_idx, p);
                emit(g, " undef, i64 ");
                emit_int(g, variant_idx);
                emit(g, ", 0");
                newline(g);
                if payload_reg >= 0 {
                    var r2 = next_temp(g);
                    emit(g, "    ");
                    push_temp(g, r2);
                    emit(g, "= insertvalue ");
                    emit_type(g, 3000 + choice_idx, p);
                    emit(g, " ");
                    push_reg(g, r);
                    emit(g, ", i64 ");
                    push_reg(g, payload_reg);
                    emit(g, ", 1");
                    newline(g);
                    set_last(g, 3000 + choice_idx);
                    return r2;
                }
            } else {
                emit(g, "    ");
                push_temp(g, r);
                emit(g, "= add i64 0, 0");
                newline(g);
            }
            set_last(g, 3000 + choice_idx);
            return r;
        }
        var struct_idx = -1;
        var si = 0;
        while si < (*p).arena.structs.len {
            var si2 = (*p).arena.structs[si];
            if semantic::name_equals((*(*p).source).data, si2.name_span, type_name) { struct_idx = si; break; }
            si = si + 1;
        }
        if struct_idx >= 0 {
            var si2 = (*p).arena.structs[struct_idx];
            var r = next_temp(g);
            var prev_r = -1;
            emit(g, "    ");
            push_temp(g, r);
            emit(g, "= insertvalue ");
            emit_type(g, 1000 + struct_idx, p);
            emit(g, " undef, ");
            var fi = 0;
            while fi < expr.child_len and fi < si2.field_len {
                var field_reg = codegen_expr(g, p, (*(*p).arena).expr_refs[expr.child_start + fi], source);
                if fi > 0 {
                    var new_r = next_temp(g);
                    emit(g, "    ");
                    push_temp(g, new_r);
                    emit(g, "= insertvalue ");
                    emit_type(g, 1000 + struct_idx, p);
                    emit(g, " ");
                    push_reg(g, prev_r);
                    emit(g, ", ");
                    prev_r = new_r;
                } else {
                    prev_r = r;
                }
                emit_type(g, 1000 + struct_idx, p);
                emit(g, " ");
                push_reg(g, field_reg);
                emit(g, ", ");
                emit_int(g, fi);
                newline(g);
                fi = fi + 1;
            }
            if prev_r < 0 { prev_r = r; }
            set_last(g, 1000 + struct_idx);
            return prev_r;
        }
        var r = next_temp(g);
        emit(g, "    ");
        push_temp(g, r);
        emit(g, "= add i64 0, 0");
        newline(g);
        set_last(g, semantic::type_int());
        return r;
    }

    if expr.kind == 19 {
        var type_name = expr.callee_span;
        var member_name = expr.name_span;
        var r = next_temp(g);
        emit(g, "    ");
        push_temp(g, r);
        emit(g, "= add i64 0, 0");
        newline(g);
        var enum_idx = -1;
        var ei = 0;
        while ei < (*p).arena.enums.len {
            var ei2 = (*p).arena.enums[ei];
            if semantic::name_equals((*(*p).source).data, ei2.name_span, type_name) { enum_idx = ei; break; }
            ei = ei + 1;
        }
        if enum_idx >= 0 {
            var vi = 0;
            var enum_info = (*p).arena.enums[enum_idx];
            while vi < enum_info.variant_len {
                var v = (*p).arena.enum_variants[enum_info.variant_start + vi];
                if semantic::name_equals((*(*p).source).data, v.name_span, member_name) {
                    emit(g, "    ");
                    push_temp(g, r);
                    emit(g, "= add i64 0, ");
                    emit_int(g, vi);
                    newline(g);
                    break;
                }
                vi = vi + 1;
            }
            set_last(g, 2000 + enum_idx);
            return r;
        }
        set_last(g, semantic::type_int());
        return r;
    }

    if expr.kind == 20 {
        var param_regs: array::Array<int> = array::Array();
        var param_tys: array::Array<int> = array::Array();
        var ai = 0;
        while ai < expr.child_len {
            var arg_reg = codegen_expr(g, p, (*(*p).arena).expr_refs[expr.child_start + ai], source);
            param_regs.push(arg_reg);
            param_tys.push(get_last(g));
            ai = ai + 1;
        }

        var fn_name_span = expr.callee_span;
        var fn_index = -1;
        var ni = 0;
        while ni < (*(*p).arena).functions.len {
            var fn2 = (*(*p).arena).functions[ni];
            if fn2.name_span.start == fn_name_span.start and fn2.name_span.end == fn_name_span.end {
                fn_index = ni;
                break;
            }
            ni = ni + 1;
        }

        if fn_index >= 0 and expr.int_value > 0 {
            var type_arg_span = (*(*p).arena).name_refs[expr.name_ref_start];
            var concrete_fn_id = monomorphizer::instantiate_generic(p, fn_index, type_arg_span);
            if concrete_fn_id >= 0 {
                var concrete_func = (*(*p).arena).functions[concrete_fn_id];
                fn_name_span = concrete_func.name_span;
            }
        }

        var fn_chars: array::Array<char> = array::Array();
        var csi = fn_name_span.start;
        while csi < fn_name_span.end {
            fn_chars.push(source.data[csi]);
            csi = csi + 1;
        }
        var ret_reg = next_temp(g);
        emit_call(g, ret_reg, fn_chars.data, fn_chars.len, semantic::type_int(), @param_regs, @param_tys, p);
        set_last(g, semantic::type_int());
        return ret_reg;
    }

    if expr.kind == 7 {
        var r = next_temp(g);
        emit(g, "    ");
        push_temp(g, r);
        emit(g, "= add i8 0, ");
        emit_int(g, cast<int>(expr.char_value));
        newline(g);
        set_last(g, semantic::type_char());
        return r;
    }

    if expr.kind == 8 {
        var sc = (*g).str_counter;
        (*g).str_counter = sc + 1;
        emit_str_buf(@(*g).string_globals, "@.str.");
        emit_int_buf(@(*g).string_globals, sc);
        emit_str_buf(@(*g).string_globals, " = private unnamed_addr constant [");
        var slen = expr.span.end - expr.span.start - 2;
        emit_int_buf(@(*g).string_globals, slen + 1);
        emit_str_buf(@(*g).string_globals, " x i8] c\"");
        var si = expr.span.start + 1;
        var sei = expr.span.end - 1;
        while si < sei {
            var ch = (*(*p).source).data[si];
            var q = cast<char>(34);
            if ch == '\n' { emit_str_buf(@(*g).string_globals, "\\0A"); }
            else if ch == q { emit_str_buf(@(*g).string_globals, "\\22"); }
            else if ch == '\\' { emit_str_buf(@(*g).string_globals, "\\\\"); }
            else { (*g).string_globals.push(ch); }
            si = si + 1;
        }
        emit_str_buf(@(*g).string_globals, "\\00\"");
        (*g).string_globals.push('\n');

        var ptr_reg = next_temp(g);
        emit(g, "    ");
        push_temp(g, ptr_reg);
        emit(g, "= getelementptr inbounds [");
        emit_int(g, slen + 1);
        emit(g, " x i8], [");
        emit_int(g, slen + 1);
        emit(g, " x i8]* @.str.");
        emit_int(g, sc);
        emit(g, ", i64 0, i64 0");
        newline(g);

        var len_reg = next_temp(g);
        emit(g, "    ");
        push_temp(g, len_reg);
        emit(g, "= add i64 0, ");
        emit_int(g, slen);
        newline(g);

        var r = next_temp(g);
        emit(g, "    ");
        push_temp(g, r);
        emit(g, "= insertvalue { i8*, i64 } undef, i8* ");
        push_reg(g, ptr_reg);
        emit(g, ", 0");
        newline(g);
        var r2 = next_temp(g);
        emit(g, "    ");
        push_temp(g, r2);
        emit(g, "= insertvalue { i8*, i64 } ");
        push_reg(g, r);
        emit(g, ", i64 ");
        push_reg(g, len_reg);
        emit(g, ", 1");
        newline(g);
        set_last(g, semantic::type_string_literal());
        return r2;
    }

    if expr.kind == 1 {
        var reg = lookup_local(g, p, expr.name_span);
        if reg < 0 {
            var null_span = expr.name_span;
            var nn = (*(*p).source).data;
            if null_span.end - null_span.start == 4 and nn[null_span.start] == 'n' and nn[null_span.start + 1] == 'u' and nn[null_span.start + 2] == 'l' and nn[null_span.start + 3] == 'l' {
                var r = next_temp(g);
                emit(g, "    ");
                push_temp(g, r);
                emit(g, "= add i64 0, 0");
                newline(g);
                set_last(g, semantic::type_int());
                return r;
            }
            return -1;
        }
        var ty = lookup_local_type(g, p, expr.name_span);
        var r = next_temp(g);
        if ty >= 1000 or ty >= 2000 or ty >= 3000 or ty >= 4000 {
            emit_load_typed(g, r, reg, ty, p);
        } else {
            emit_load(g, r, reg, ty);
        }
        set_last(g, ty);
        return r;
    }

    if expr.kind == 4 {
        return codegen_expr(g, p, (*(*p).arena).expr_refs[expr.child_start]);
    }

    if expr.kind == 5 {
        var is_unary = expr.child_len == 1;
        if expr.child_len == 0 { return -1; }
        var lhs_reg = codegen_expr(g, p, (*(*p).arena).expr_refs[expr.child_start]);
        var lhs_ty = get_last(g);
        var rhs_reg = -1;
        var rhs_ty = semantic::type_int();
        if expr.child_len > 1 {
            rhs_reg = codegen_expr(g, p, (*(*p).arena).expr_refs[expr.child_start + 1]);
            rhs_ty = get_last(g);
        }

        if lhs_ty >= 10000 and rhs_ty == semantic::type_int() {
            var new_rhs = next_temp(g);
            emit(g, "    "); push_temp(g, new_rhs); emit(g, "= inttoptr i64 "); push_reg(g, rhs_reg); emit(g, " to "); emit_type(g, lhs_ty, p); newline(g);
            rhs_reg = new_rhs;
            rhs_ty = lhs_ty;
        } else if rhs_ty >= 10000 and lhs_ty == semantic::type_int() {
            var new_lhs = next_temp(g);
            emit(g, "    "); push_temp(g, new_lhs); emit(g, "= inttoptr i64 "); push_reg(g, lhs_reg); emit(g, " to "); emit_type(g, rhs_ty, p); newline(g);
            lhs_reg = new_lhs;
            lhs_ty = rhs_ty;
        }

        var op = expr.op_kind;
        var r = next_temp(g);
        var aty = lhs_ty;

        if op == 46 or op == 49 or op == 50 {
            if !is_unary and try_emit_overloaded_binary_op(g, p, op, lhs_reg, rhs_reg, source) {
                set_last(g, semantic::type_int());
                return r;
            }
            var opstr = "add";
            if op == 49 { opstr = "sdiv"; }
            if op == 50 { opstr = "srem"; }
            var arith_ty = get_last(g);
            if arith_ty == semantic::type_float() or arith_ty == semantic::type_float64() {
                if op == 46 { opstr = "fadd"; }
                if op == 49 { opstr = "fdiv"; }
                if op == 50 { opstr = "frem"; }
            }
            emit_binop(g, r, opstr, arith_ty, lhs_reg, rhs_reg, p);
            set_last(g, arith_ty);
            return r;
        }
        if op == 47 {
            var arith_ty = get_last(g);
            if is_unary {
                emit_binop_with_zero(g, r, "sub", lhs_reg, p);
            } else {
                var opstr = "sub";
                if arith_ty == semantic::type_float() or arith_ty == semantic::type_float64() { opstr = "fsub"; }
                emit_binop(g, r, opstr, arith_ty, lhs_reg, rhs_reg, p);
            }
            set_last(g, arith_ty);
            return r;
        }
        if op == 48 {
            if is_unary {
                var ptr_ty = get_last(g);
                if semantic::is_pointer_type(ptr_ty) {
                    var target_ty = semantic::type_dereference(ptr_ty);
                    var r = next_temp(g);
                    var cast_ptr = next_temp(g);
                    emit(g, "    ");
                    push_temp(g, cast_ptr);
                    emit(g, "= inttoptr i64 ");
                    push_reg(g, lhs_reg);
                    emit(g, " to ptr");
                    newline(g);
                    push_temp(g, r);
                    emit(g, "= load ");
                    if target_ty >= 4000 {
                        var ci2 = target_ty - 4000;
                        if ci2 < (*(*p).arena).classes.len {
                            emit(g, "%class.");
                            var cls = (*(*p).arena).classes[ci2];
                            var ni8 = cls.name_span.start;
                            while ni8 < cls.name_span.end {
                                (*g).output.push((*(*p).source).data[ni8]);
                                ni8 = ni8 + 1;
                            }
                        } else { emit(g, "i64"); }
                    } else if target_ty >= 3000 {
                        var ci3 = target_ty - 3000;
                        if ci3 < (*(*p).arena).choices.len {
                            emit(g, "%choice.");
                            var ch2 = (*(*p).arena).choices[ci3];
                            var ni9 = ch2.name_span.start;
                            while ni9 < ch2.name_span.end {
                                (*g).output.push((*(*p).source).data[ni9]);
                                ni9 = ni9 + 1;
                            }
                        } else { emit(g, "i64"); }
                    } else if target_ty >= 1000 {
                        var si = target_ty - 1000;
                        if si < (*(*p).arena).structs.len {
                            emit(g, "%struct.");
                            var st = (*(*p).arena).structs[si];
                            var ni10 = st.name_span.start;
                            while ni10 < st.name_span.end {
                                (*g).output.push((*(*p).source).data[ni10]);
                                ni10 = ni10 + 1;
                            }
                        } else { emit(g, "i64"); }
                    } else { emit_type(g, target_ty, p); }
                    emit(g, ", ptr ");
                    push_reg(g, cast_ptr);
                    newline(g);
                    set_last(g, target_ty);
                    return r;
                }
                return lhs_reg;
            }
            var arith_ty = get_last(g);
            var opstr = "mul";
            if arith_ty == semantic::type_float() or arith_ty == semantic::type_float64() { opstr = "fmul"; }
            emit_binop(g, r, opstr, arith_ty, lhs_reg, rhs_reg, p);
            set_last(g, arith_ty);
            return r;
        }
        if op == 61 {
            if is_unary {
                var child_expr = (*(*p).arena).exprs[(*(*p).arena).expr_refs[expr.child_start]];
                if child_expr.kind == 1 {
                    var ptr_reg = lookup_local(g, p, child_expr.name_span);
                    if ptr_reg >= 0 {
                        var r = next_temp(g);
                        emit(g, "    ");
                        push_temp(g, r);
                        emit(g, "= ptrtoint ptr ");
                        push_reg(g, ptr_reg);
                        emit(g, " to i64");
                        newline(g);
                        set_last(g, semantic::type_int());
                        return r;
                    }
                }
                if child_expr.kind == 9 and child_expr.child_len > 0 {
                    var base_expr = (*(*p).arena).exprs[(*(*p).arena).expr_refs[child_expr.child_start]];
                    if base_expr.kind == 1 {
                        var base_reg = lookup_local(g, p, base_expr.name_span);
                        if base_reg >= 0 {
                            var field_idx = -1;
                            var base_ty = semantic::type_int();
                            var si = 0;
                            while si < (*p).arena.structs.len and field_idx < 0 {
                                var st = (*p).arena.structs[si];
                                var fi = 0;
                                while fi < st.field_len {
                                    var f = (*p).arena.struct_fields[st.field_start + fi];
                                    if semantic::name_equals((*(*p).source).data, f.name_span, child_expr.name_span) {
                                        field_idx = fi;
                                        base_ty = 1000 + si;
                                        break;
                                    }
                                    fi = fi + 1;
                                }
                                si = si + 1;
                            }
                            if field_idx >= 0 {
                                var gep_reg = next_temp(g);
                                emit_gep(g, gep_reg, base_ty, p, base_reg, 0, field_idx);
                                var r = next_temp(g);
                                emit(g, "    ");
                                push_temp(g, r);
                                emit(g, "= ptrtoint ptr ");
                                push_reg(g, gep_reg);
                                emit(g, " to i64");
                                newline(g);
                                set_last(g, semantic::type_int());
                                return r;
                            }
                        }
                    }
                }
            }
            return lhs_reg;
        }
        if op == 62 {
            var tag_gep = next_temp(g);
            emit_gep(g, tag_gep, 3000, p, lhs_reg, 0, 0);
            var tag_reg = next_temp(g);
            emit_load_typed(g, tag_reg, tag_gep, semantic::type_int(), p);
            var ok_label = next_label(g);
            var err_label = next_label(g);
            var end_label = next_label(g);
            emit_cond_br(g, tag_reg, ok_label, err_label);

            (*g).block_terminated = false;
            emit_label(g, ok_label);
            var payload_gep = next_temp(g);
            emit_gep(g, payload_gep, 3000, p, lhs_reg, 0, 1);
            var payload_reg = next_temp(g);
            emit_load_typed(g, payload_reg, payload_gep, semantic::type_int(), p);
            emit_br(g, end_label);

            (*g).block_terminated = false;
            emit_label(g, err_label);
            var save_ret = (*g).fn_return_type;
            (*g).fn_return_type = 3000;
            emit_ret(g, lhs_reg, 3000);
            (*g).fn_return_type = save_ret;

            (*g).block_terminated = false;
            emit_label(g, end_label);
            return payload_reg;
        }
        if op == 74 {
            var base_ty = get_last(g);
            if base_ty >= 4000 and !is_unary {

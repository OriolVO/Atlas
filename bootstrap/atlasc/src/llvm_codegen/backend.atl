            cg_types::push_temp(g, tru_reg);
            cg_types::emit(g, "= add i1 0, true");
            cg_types::newline(g);
            cg_types::emit(g, "    ");
            cg_types::push_temp(g, xor_r);
            cg_types::emit(g, "= xor i1 ");
            cg_types::push_reg(g, lhs_reg);
            cg_types::emit(g, ", true");
            cg_types::newline(g);
            return xor_r;
        }

        return r;

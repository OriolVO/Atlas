            }
            cg_types::set_last(g, semantic::type_bool());
            return r;
        }
        if op == 25 or op == 59 {
            if is_unary { return lhs_reg; }
            var and_r = cg_types::next_temp(g);
            cg_types::emit_binop(g, and_r, "and", semantic::type_bool(), lhs_reg, rhs_reg, p);
            cg_types::set_last(g, semantic::type_bool());
            return and_r;
        }
        if op == 26 or op == 60 {
            if is_unary { return lhs_reg; }
            var or_r = cg_types::next_temp(g);
            cg_types::emit_binop(g, or_r, "or", semantic::type_bool(), lhs_reg, rhs_reg, p);
            cg_types::set_last(g, semantic::type_bool());
            return or_r;
        }
        if op == 27 or op == 58 {
            cg_types::set_last(g, semantic::type_bool());
            var xor_r = cg_types::next_temp(g);

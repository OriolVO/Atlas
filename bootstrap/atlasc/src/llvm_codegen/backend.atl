            var positional_value = -1;
            var positional_i = 0;
            while positional_i < param_regs.len {
                var inserted = cg_types::next_temp(g);
                cg_types::emit(g, "    ");
                cg_types::push_temp(g, inserted);
                cg_types::emit(g, "= insertvalue ");
                cg_types::emit_type(g, positional_ty, p);
                cg_types::emit(g, " ");
                if positional_value < 0 {
                    cg_types::emit(g, "undef");
                } else {
                    cg_types::push_reg(g, positional_value);
                }
                cg_types::emit(g, ", ");
                cg_types::emit_type(g, param_tys[positional_i], p);
                cg_types::emit(g, " ");
                cg_types::push_reg(g, param_regs[positional_i]);
                cg_types::emit(g, ", ");
                cg_types::emit_int(g, positional_i);
                cg_types::newline(g);
                positional_value = inserted;
                positional_i = positional_i + 1;
            }
            if positional_value < 0 {
                positional_value = cg_types::next_temp(g);
                cg_types::emit(g, "    ");
                cg_types::push_temp(g, positional_value);
                cg_types::emit(g, "= insertvalue ");
                cg_types::emit_type(g, positional_ty, p);
                cg_types::emit(g, " undef, i64 0, 0");
                cg_types::newline(g);
            }
            cg_types::set_last(g, positional_ty);
            return positional_value;
        }

        var ci = 0;
        var constructor_candidate = cg_types::last_segment(expr.callee_span, source);
        while ci < (*(*p).arena).classes.len {
            var cl = (*(*p).arena).classes[ci];
            if semantic::name_equals(p.source.data, cl.name_span, constructor_candidate) {

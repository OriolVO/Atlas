            rhs_reg = codegen_expr(g, p, (*(*p).arena).expr_refs[expr.child_start + 1], source);
            rhs_ty = cg_types::get_last(g);
        }

        if !is_unary and lhs_ty >= 10000 and rhs_ty == semantic::type_int() {
            var new_rhs = cg_types::next_temp(g);
            cg_types::emit(g, "    "); cg_types::push_temp(g, new_rhs); cg_types::emit(g, "= inttoptr i64 "); cg_types::push_reg(g, rhs_reg); cg_types::emit(g, " to "); cg_types::emit_type(g, lhs_ty, p); cg_types::newline(g);
            rhs_reg = new_rhs;
            rhs_ty = lhs_ty;
        } else if !is_unary and rhs_ty >= 10000 and lhs_ty == semantic::type_int() {
            var new_lhs = cg_types::next_temp(g);
            cg_types::emit(g, "    "); cg_types::push_temp(g, new_lhs); cg_types::emit(g, "= inttoptr i64 "); cg_types::push_reg(g, lhs_reg); cg_types::emit(g, " to "); cg_types::emit_type(g, rhs_ty, p); cg_types::newline(g);
            lhs_reg = new_lhs;
            lhs_ty = rhs_ty;
        }

        if !is_unary and lhs_ty != rhs_ty and cg_types::is_llvm_integer_type(lhs_ty) and cg_types::is_llvm_integer_type(rhs_ty) {
            var lw = cg_types::integer_width(lhs_ty);
            var rw = cg_types::integer_width(rhs_ty);
            if lw > rw {
                var new_rhs = cg_types::next_temp(g);
                cg_types::emit(g, "    "); cg_types::push_temp(g, new_rhs); cg_types::emit(g, "= zext "); cg_types::emit_type(g, rhs_ty, p); cg_types::emit(g, " "); cg_types::push_reg(g, rhs_reg); cg_types::emit(g, " to i64"); cg_types::newline(g);
                rhs_reg = new_rhs;
                rhs_ty = lhs_ty;
            } else if rw > lw {
                var new_lhs = cg_types::next_temp(g);
                cg_types::emit(g, "    "); cg_types::push_temp(g, new_lhs); cg_types::emit(g, "= zext "); cg_types::emit_type(g, lhs_ty, p); cg_types::emit(g, " "); cg_types::push_reg(g, lhs_reg); cg_types::emit(g, " to i64"); cg_types::newline(g);
                lhs_reg = new_lhs;
                lhs_ty = rhs_ty;
            }
        }

        var op = expr.op_kind;
        var r = cg_types::next_temp(g);
        var aty = lhs_ty;

        if op == 46 or op == 49 or op == 50 {
            if !is_unary and try_emit_overloaded_binary_op(g, p, op, r, lhs_reg, rhs_reg, source) {
                return r;
            }
            var opstr = "add";
            if op == 49 { opstr = "sdiv"; }
            if op == 50 { opstr = "srem"; }
            var arith_ty = cg_types::get_last(g);
            if arith_ty == semantic::type_float() or arith_ty == semantic::type_float64() {
                if op == 46 { opstr = "fadd"; }
                if op == 49 { opstr = "fdiv"; }
                if op == 50 { opstr = "frem"; }
            }
            cg_types::emit_binop(g, r, opstr, arith_ty, lhs_reg, rhs_reg, p);
            cg_types::set_last(g, arith_ty);
            return r;
        }
        if op == 47 {
            var arith_ty = cg_types::get_last(g);
            if is_unary {
                emit_binop_with_zero(g, r, "sub", lhs_reg, p);
            } else {
                var opstr = "sub";
                if arith_ty == semantic::type_float() or arith_ty == semantic::type_float64() { opstr = "fsub"; }
                cg_types::emit_binop(g, r, opstr, arith_ty, lhs_reg, rhs_reg, p);
            }
            cg_types::set_last(g, arith_ty);
            return r;
        }
        if op == 48 {
            if is_unary {
                var ptr_ty = cg_types::get_last(g);
                if semantic::is_pointer_type(ptr_ty) {
                    var target_ty = semantic::type_dereference(ptr_ty);
                    var deref_reg = cg_types::next_temp(g);
                    cg_types::push_temp(g, deref_reg);
                    cg_types::emit(g, "= load ");
                    cg_types::emit_type(g, target_ty, p);
                    cg_types::emit(g, ", ptr ");
                    cg_types::push_reg(g, lhs_reg);
                    cg_types::newline(g);
                    cg_types::set_last(g, target_ty);
                    return deref_reg;
                }
                return lhs_reg;
            }
            var arith_ty = cg_types::get_last(g);
            var opstr = "mul";
            if arith_ty == semantic::type_float() or arith_ty == semantic::type_float64() { opstr = "fmul"; }
            cg_types::emit_binop(g, r, opstr, arith_ty, lhs_reg, rhs_reg, p);
            cg_types::set_last(g, arith_ty);
            return r;
        }
        if op == 61 { return lhs_reg; }
        if op == 62 {
            var tag_reg = cg_types::next_temp(g);
            cg_types::emit(g, "    ");
            cg_types::push_temp(g, tag_reg);
            cg_types::emit(g, "= extractvalue ");
            cg_types::emit_type(g, lhs_ty, p);
            cg_types::emit(g, " ");
            cg_types::push_reg(g, lhs_reg);
            cg_types::emit(g, ", 0");
            cg_types::newline(g);
            var zero_reg = cg_types::next_temp(g);
            cg_types::emit(g, "    ");
            cg_types::push_temp(g, zero_reg);
            cg_types::emit(g, "= add i64 0, 0");
            cg_types::newline(g);
            var is_ok_reg = cg_types::next_temp(g);
            cg_types::emit_icmp(g, is_ok_reg, "eq", semantic::type_int(), tag_reg, zero_reg, p);
            var ok_label = cg_types::next_label(g);
            var err_label = cg_types::next_label(g);
            var end_label = cg_types::next_label(g);
            cg_types::emit_cond_br(g, is_ok_reg, ok_label, err_label);

            (*g).block_terminated = false;
            cg_types::emit_label(g, ok_label);
            var payload_reg = cg_types::next_temp(g);
            cg_types::emit(g, "    ");
            cg_types::push_temp(g, payload_reg);
            cg_types::emit(g, "= extractvalue ");
            cg_types::emit_type(g, lhs_ty, p);
            cg_types::emit(g, " ");
            cg_types::push_reg(g, lhs_reg);
            cg_types::emit(g, ", 1");
            cg_types::newline(g);
            cg_types::emit_br(g, end_label);

            (*g).block_terminated = false;
            cg_types::emit_label(g, err_label);
            var save_ret = (*g).fn_return_type;
            (*g).fn_return_type = lhs_ty;
            cg_types::emit_ret(g, lhs_reg, lhs_ty, p);
            (*g).fn_return_type = save_ret;

            (*g).block_terminated = false;
            cg_types::emit_label(g, end_label);
            var propagated_ty = semantic::type_int();
            if semantic::is_choice_type(lhs_ty) {
                var propagated_choice = (*(*p).arena).choices[lhs_ty - 3000];
                if propagated_choice.variant_len > 0 {
                    var propagated_variant = (*(*p).arena).choice_variants[propagated_choice.variant_start];
                    if propagated_variant.has_payload {
                        var propagated_errors: array::Array<semantic::SemanticError> = array::Array();
                        var propagated_summary = semantic::make_empty_summary();
                        propagated_ty = semantic::resolve_type_ref(p, propagated_variant.payload_type_ref, @propagated_errors, @propagated_summary);

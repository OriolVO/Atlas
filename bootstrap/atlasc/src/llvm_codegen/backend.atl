                cg_types::emit(g, "    "); cg_types::push_temp(g, zl); cg_types::emit(g, "= zext ");
                cg_types::emit_type(g, lhs_ty, p); cg_types::emit(g, " "); cg_types::push_reg(g, lhs_reg);
                cg_types::emit(g, " to "); cg_types::emit_type(g, rhs_ty, p); cg_types::newline(g);

        if op == 51 {
            var cmp_ty = cg_types::get_last(g);
            if cg_types::integer_width(lhs_ty) > cg_types::integer_width(rhs_ty) {
                var zr = cg_types::next_temp(g);
                cg_types::emit(g, "    "); cg_types::push_temp(g, zr); cg_types::emit(g, "= zext ");
                cg_types::emit_type(g, rhs_ty, p); cg_types::emit(g, " "); cg_types::push_reg(g, rhs_reg);
                cg_types::emit(g, " to "); cg_types::emit_type(g, lhs_ty, p); cg_types::newline(g);

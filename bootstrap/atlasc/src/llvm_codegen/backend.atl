                cg_types::emit(g, "    "); cg_types::push_temp(g, malloc_size); cg_types::emit(g, "= add i64 0, 8192"); cg_types::newline(g);
                var malloc_name: array::Array<char> = array::Array();
                malloc_name.push('m'); malloc_name.push('a'); malloc_name.push('l'); malloc_name.push('l'); malloc_name.push('o'); malloc_name.push('c');
                var malloc_regs: array::Array<int> = array::Array();
                var malloc_tys: array::Array<int> = array::Array();
                malloc_regs.push(malloc_size);
                malloc_tys.push(semantic::type_int());
                var map_data = cg_types::next_temp(g);
                cg_types::emit_call(g, map_data, malloc_name.data, malloc_name.len, semantic::type_pointer(semantic::type_char(), false), @malloc_regs, @malloc_tys, p);
                var map_entries = cg_types::next_temp(g);
                cg_types::emit_gep(g, map_entries, map_ty, p, map_alloca, 0, 0);
                var map_data_field = cg_types::next_temp(g);
                cg_types::emit_gep(g, map_data_field, cg_types::find_named_class_type(p, "Array"), p, map_entries, 0, 0);
                cg_types::emit_store_typed(g, map_data, map_data_field, semantic::type_pointer(semantic::type_int(), false), p);
                var map_result = cg_types::next_temp(g);
                cg_types::emit_load_typed(g, map_result, map_alloca, map_ty, p);
                cg_types::set_last(g, map_ty);
                return map_result;
            }
            var ctor_chars: array::Array<char> = array::Array();
            var ctor_name = (*(*p).arena).classes[ctor_class_id].name_span;
            var ctor_name_i = ctor_name.start;
            while ctor_name_i < ctor_name.end {
                ctor_chars.push(source.data[ctor_name_i]);
                ctor_name_i = ctor_name_i + 1;
            }
            ctor_chars.push('.');
            ctor_chars.push('i'); ctor_chars.push('n'); ctor_chars.push('i'); ctor_chars.push('t');
            var alloca_reg = cg_types::next_temp(g);
            cg_types::emit_alloca_typed(g, alloca_reg, 4000 + ctor_class_id, p);
            cg_types::emit_default_store(g, alloca_reg, 4000 + ctor_class_id, p);
            var new_regs: array::Array<int> = array::Array();
            var new_tys: array::Array<int> = array::Array();
            new_regs.push(alloca_reg);
            new_tys.push(semantic::type_pointer(4000 + ctor_class_id, false));
            var j2 = 0;
            while j2 < param_regs.len {
                new_regs.push(param_regs[j2]);
                new_tys.push(param_tys[j2]);
                j2 = j2 + 1;
            }
            var ignore_reg = cg_types::next_temp(g);
            cg_types::emit_call(g, ignore_reg, ctor_chars.data, ctor_chars.len, semantic::type_void(), @new_regs, @new_tys, p);
            var result_reg = cg_types::next_temp(g);
            cg_types::emit_load_typed(g, result_reg, alloca_reg, 4000 + ctor_class_id, p);
            cg_types::set_last(g, 4000 + ctor_class_id);
            return result_reg;
        } else {
            var call_ret_ty = semantic::type_int();
            var direct_fn_id = cg_types::find_function_for_expr(p, expr);
            if direct_fn_id >= 0 {
                var direct_info = (*(*p).arena).functions[direct_fn_id];
                fn_chars.len = 0;
                cg_types::append_function_symbol(@fn_chars, p, direct_fn_id);
                if direct_info.has_return_type {
                    var direct_errors: array::Array<semantic::SemanticError> = array::Array();
                    var direct_summary = semantic::make_empty_summary();
                    call_ret_ty = cg_types::resolve_type_simple(p, direct_info.return_type_ref);
                } else {
                    call_ret_ty = semantic::type_void();
                }
            }
            if direct_fn_id >= 0 {
                var generic_direct_info = (*(*p).arena).functions[direct_fn_id];
                if generic_direct_info.generic_param_len > 0 and
                   (cg_types::span_ends_with(p, expr.callee_span, "print") or cg_types::span_ends_with(p, expr.callee_span, "println")) {
                    cg_types::set_last(g, semantic::type_void());
                    return -1;
                }
            }
            if direct_fn_id < 0 and expr.resolved_def_id >= 0 and expr.resolved_def_id < (*(*p).arena).items.len {
                var call_item = (*(*p).arena).items[expr.resolved_def_id];
                if call_item.kind == 1 {
                    var call_info = (*(*p).arena).functions[call_item.function_id];
                    if call_info.has_return_type {
                        var call_errors: array::Array<semantic::SemanticError> = array::Array();
                        var call_summary = semantic::make_empty_summary();
                        call_ret_ty = cg_types::resolve_type_simple(p, call_info.return_type_ref);
                    } else {
                        call_ret_ty = semantic::type_void();
                    }
                }
            }
            cg_types::prepare_call_arguments(g, p, expr, @param_regs, @param_tys);
            cg_types::emit_call(g, ret_reg, fn_chars.data, fn_chars.len, call_ret_ty, @param_regs, @param_tys, p);
            cg_types::set_last(g, call_ret_ty);
            return ret_reg;
        }
    }

    if expr.kind == 9 {
        if expr.child_len == 0 { return -1; }
        var base_val = codegen_expr(g, p, (*(*p).arena).expr_refs[expr.child_start], source);
        if base_val < 0 { return -1; }
        var base_ty = cg_types::get_last(g);
        
        var is_len = false;
        if expr.name_span.end - expr.name_span.start == 3 {
            var sdata = p.source.data;
            if sdata[expr.name_span.start] == 'l' and sdata[expr.name_span.start+1] == 'e' and sdata[expr.name_span.start+2] == 'n' {
                is_len = true;
            }
        }
        if is_len {
            var work_val = base_val;
            var work_ty = base_ty;
            if semantic::is_pointer_type(base_ty) {
                work_val = cg_types::next_temp(g);
                work_ty = semantic::type_dereference(base_ty);
                cg_types::emit_load_typed(g, work_val, base_val, work_ty, p);
            }
            if not semantic::is_pointer_type(work_ty) {
                var r = cg_types::next_temp(g);
                cg_types::emit(g, "    "); cg_types::push_temp(g, r); cg_types::emit(g, "= extractvalue ");
                cg_types::emit_type(g, work_ty, p);
                cg_types::emit(g, " "); cg_types::push_reg(g, work_val); cg_types::emit(g, ", 1"); cg_types::newline(g);
                cg_types::set_last(g, semantic::type_int());
                return r;
            }
        }

        var field_idx = -1;
        var field_ty = semantic::type_int();
        var member_target_ty = base_ty;
        if semantic::is_pointer_type(member_target_ty) {
            member_target_ty = semantic::type_dereference(member_target_ty);
        }
        if semantic::is_struct_type(member_target_ty) {
            var si = member_target_ty - 1000;
            var st = (*(*p).arena).structs[si];
            var fi = 0;
            while fi < st.field_len {
                var f = (*(*p).arena).struct_fields[st.field_start + fi];
                if semantic::name_equals(p.source.data, f.name_span, expr.name_span) {
                    field_idx = fi;
                    field_ty = resolve_field_type_for_codegen(p, f.type_ref, f.span);
                    if cg_types::span_ends_with(p, f.name_span, "is_used") {
                        field_ty = semantic::type_bool();
                    }
                    break;
                }
                fi = fi + 1;
            }
        }
        if semantic::is_class_type(member_target_ty) {
            var ci = member_target_ty - 4000;
            var cl = (*(*p).arena).classes[ci];
            var fi = 0;
            while fi < cl.field_len {
                var f = (*(*p).arena).class_fields[cl.field_start + fi];
                if semantic::name_equals(p.source.data, f.name_span, expr.name_span) {
                    field_idx = fi;
                    field_ty = resolve_field_type_for_codegen(p, f.type_ref, f.span);
                    if cg_types::span_ends_with(p, f.name_span, "is_used") {
                        field_ty = semantic::type_bool();
                    }
                    break;
                }
                fi = fi + 1;
            }
        }
        if field_idx < 0 { return -1; }
        var r = cg_types::next_temp(g);
        if semantic::is_pointer_type(base_ty) {
            var field_ptr = cg_types::next_temp(g);
            cg_types::emit_gep(g, field_ptr, member_target_ty, p, base_val, 0, field_idx);
            cg_types::emit_load_typed(g, r, field_ptr, field_ty, p);
        } else {
            cg_types::emit(g, "    ");
            cg_types::push_temp(g, r);
            cg_types::emit(g, "= extractvalue ");
            cg_types::emit_type(g, member_target_ty, p);
            cg_types::emit(g, " ");
            cg_types::push_reg(g, base_val);
            cg_types::emit(g, ", ");
            cg_types::emit_int(g, field_idx);
            cg_types::newline(g);
        }
        cg_types::set_last(g, field_ty);
        return r;
    }

    if expr.kind == 10 {
        var struct_ty = semantic::type_int();
        var si = 0;
        var search_name_2 = semantic::last_path_segment_name(p.source, expr.callee_span);
        while si < (*(*p).arena).structs.len {
            var st = (*(*p).arena).structs[si];
            if semantic::name_equals(p.source.data, st.name_span, search_name_2) {
                struct_ty = 1000 + si;
                break;
            }
            si = si + 1;
        }
        var accum_value = -1;
        var struct_id_for_fields = struct_ty - 1000;
        var fi = 0;
        while fi < expr.child_len {
            var val_reg = codegen_expr(g, p, (*(*p).arena).expr_refs[expr.child_start + fi], source);
            if val_reg >= 0 {
                var field_ty = cg_types::get_last(g);
                var field_name_span = (*(*p).arena).name_refs[expr.name_ref_start + fi];
                var actual_fi = fi;
                if struct_id_for_fields >= 0 and struct_id_for_fields < (*(*p).arena).structs.len {
                    var st_info = (*(*p).arena).structs[struct_id_for_fields];
                    var sfi = 0;
                    while sfi < st_info.field_len {
                        var sf = (*(*p).arena).struct_fields[st_info.field_start + sfi];
                        if semantic::name_equals(p.source.data, sf.name_span, field_name_span) {
                            actual_fi = sfi;
                            break;
                        }
                        sfi = sfi + 1;
                    }
                }
                var new_accum = cg_types::next_temp(g);
                cg_types::emit(g, "    ");
                cg_types::push_temp(g, new_accum);
                cg_types::emit(g, "= insertvalue ");
                cg_types::emit_type(g, struct_ty, p);
                cg_types::emit(g, " ");
                if accum_value < 0 {
                    cg_types::emit(g, "undef");
                } else {
                    cg_types::push_reg(g, accum_value);
                }
                cg_types::emit(g, ", ");
                cg_types::emit_type(g, field_ty, p);
                cg_types::emit(g, " ");
                cg_types::push_reg(g, val_reg);
                cg_types::emit(g, ", ");
                cg_types::emit_int(g, actual_fi);
                cg_types::newline(g);
                accum_value = new_accum;
            }
            fi = fi + 1;
        }
        cg_types::set_last(g, struct_ty);
        return accum_value;
    }

    if expr.kind == 11 {
        var ei = 0;
        while ei < (*(*p).arena).enums.len {
            var enum_info = (*(*p).arena).enums[ei];
            if semantic::name_equals(p.source.data, enum_info.name_span, expr.callee_span) {
                var vi = 0;
                while vi < enum_info.variant_len {
                    var variant = (*(*p).arena).enum_variants[enum_info.variant_start + vi];
                    if semantic::name_equals(p.source.data, variant.name_span, expr.name_span) {
                        var r = cg_types::next_temp(g);
                        cg_types::emit(g, "    ");
                        cg_types::push_temp(g, r);
                        cg_types::emit(g, "= add i64 0, ");
                        cg_types::emit_int(g, vi);
                        cg_types::newline(g);
                        cg_types::set_last(g, semantic::type_int());
                        return r;
                    }
                    vi = vi + 1;
                }
            }
            ei = ei + 1;
        }
        var ci = 0;
        while ci < (*(*p).arena).choices.len {
            var choice_info = (*(*p).arena).choices[ci];
            if semantic::name_equals(p.source.data, choice_info.name_span, expr.callee_span) {
                var vi = 0;
                while vi < choice_info.variant_len {
                    var variant = (*(*p).arena).choice_variants[choice_info.variant_start + vi];
                    if semantic::name_equals(p.source.data, variant.name_span, expr.name_span) {
                        var choice_ty = 3000 + ci;
                        var tag_reg = cg_types::next_temp(g);
                        cg_types::emit(g, "    ");
                        cg_types::push_temp(g, tag_reg);
                        cg_types::emit(g, "= insertvalue ");
                        cg_types::emit_type(g, choice_ty, p);
                        cg_types::emit(g, " undef, i64 ");
                        cg_types::emit_int(g, vi);
                        cg_types::emit(g, ", 0");
                        cg_types::newline(g);
                        var accum = tag_reg;
                        if variant.has_payload and expr.child_len > 0 {
                            var payload_reg = codegen_expr(g, p, (*(*p).arena).expr_refs[expr.child_start], source);
                            if payload_reg >= 0 {
                                var result_reg = cg_types::next_temp(g);
                                cg_types::emit(g, "    ");
                                cg_types::push_temp(g, result_reg);
                                cg_types::emit(g, "= insertvalue ");
                                cg_types::emit_type(g, choice_ty, p);
                                cg_types::emit(g, " ");
                                cg_types::push_reg(g, accum);
                                cg_types::emit(g, ", ");
                                cg_types::emit_type(g, cg_types::get_last(g), p);
                                cg_types::emit(g, " ");
                                cg_types::push_reg(g, payload_reg);
                                cg_types::emit(g, ", 1");
                                cg_types::newline(g);
                                accum = result_reg;
                            }
                        }
                        cg_types::set_last(g, choice_ty);
                        return accum;
                    }
                    vi = vi + 1;
                }
            }
            ci = ci + 1;
        }
        return -1;
    }

    return -1;
}

export fn codegen_lvalue(g: @cg_types::Codegen, p: @resolver::Project, expr_id: int, source: @array::Array<char>): int {
    if expr_id < 0 {
        return -1;
    }
    var expr = (*(*p).arena).exprs[expr_id];
    if expr.kind == 4 and expr.child_len > 0 {
        return codegen_lvalue(g, p, (*(*p).arena).expr_refs[expr.child_start], source);
    }
    if expr.kind == 1 {
        var slot = cg_types::lookup_local(g, p, expr.name_span);
        cg_types::set_last(g, cg_types::lookup_local_type(g, p, expr.name_span));
        return slot;
    }
    if expr.kind == 5 and expr.op_kind == 48 and expr.child_len == 1 {
        var pointer_value = codegen_expr(g, p, (*(*p).arena).expr_refs[expr.child_start], source);
        var pointer_ty = cg_types::get_last(g);
        cg_types::set_last(g, semantic::type_dereference(pointer_ty));
        return pointer_value;
    }
    if expr.kind == 5 and expr.op_kind == 74 and expr.child_len == 2 {
        var base_expr_id = (*(*p).arena).expr_refs[expr.child_start];
        var index_expr_id = (*(*p).arena).expr_refs[expr.child_start + 1];
        var base_expr = (*(*p).arena).exprs[base_expr_id];
        var base_ptr = -1;
        var base_ty = semantic::type_unknown();
        if base_expr.kind == 1 {
            base_ptr = cg_types::lookup_local(g, p, base_expr.name_span);
            base_ty = cg_types::lookup_local_type(g, p, base_expr.name_span);
        } else {
            base_ptr = codegen_expr(g, p, base_expr_id, source);
            base_ty = cg_types::get_last(g);
        }
        var index_reg = codegen_expr(g, p, index_expr_id, source);
        var index_ty = cg_types::get_last(g);
        index_reg = coerce_type(g, p, index_reg, index_ty, semantic::type_int());
        var element_ty = semantic::type_int();
        var element_ptr = -1;
        if semantic::is_array_type(base_ty) {
            element_ty = semantic::array_element_type(base_ty);
            element_ptr = cg_types::next_temp(g);
            cg_types::emit(g, "    ");
            cg_types::push_temp(g, element_ptr);
            cg_types::emit(g, "= getelementptr inbounds ");
            cg_types::emit_type(g, base_ty, p);
            cg_types::emit(g, ", ptr ");
            cg_types::push_reg(g, base_ptr);
            cg_types::emit(g, ", i64 0, i64 ");
            cg_types::push_reg(g, index_reg);
        } else if semantic::is_slice_type(base_ty) {
            element_ty = semantic::slice_element_type(base_ty);
            var slice_value = base_ptr;
            if base_expr.kind == 1 {
                slice_value = cg_types::next_temp(g);
                cg_types::emit_load_typed(g, slice_value, base_ptr, base_ty, p);
            }
            var data_reg = cg_types::next_temp(g);
            cg_types::emit(g, "    ");
            cg_types::push_temp(g, data_reg);
            cg_types::emit(g, "= extractvalue ");
            cg_types::emit_type(g, base_ty, p);
            cg_types::emit(g, " ");
            cg_types::push_reg(g, slice_value);
            cg_types::emit(g, ", 0");
            cg_types::newline(g);
            element_ptr = cg_types::next_temp(g);
            cg_types::emit(g, "    ");
            cg_types::push_temp(g, element_ptr);
            cg_types::emit(g, "= getelementptr inbounds ");
            cg_types::emit_type(g, element_ty, p);
            cg_types::emit(g, ", ptr ");
            cg_types::push_reg(g, data_reg);
            cg_types::emit(g, ", i64 ");
            cg_types::push_reg(g, index_reg);
        } else if semantic::is_pointer_type(base_ty) {
            var pointee_ty = semantic::type_dereference(base_ty);
            if semantic::is_class_type(pointee_ty) {
                var class_id = pointee_ty - 4000;
                var class_info = (*(*p).arena).classes[class_id];
                element_ty = semantic::type_unknown();
                if class_info.concrete_arg_len > 0 {
                    element_ty = (*(*p).arena).concrete_type_args[class_info.concrete_arg_start];
                }
                if element_ty == semantic::type_unknown() and class_info.field_len > 0 {
                    var data_field = (*(*p).arena).class_fields[class_info.field_start];
                    var data_field_ty = cg_types::resolve_type_simple(p, data_field.type_ref);
                    if semantic::is_pointer_type(data_field_ty) {
                        element_ty = semantic::type_dereference(data_field_ty);
                    }
                }
                if element_ty == semantic::type_unknown() {
                    element_ty = semantic::type_int();
                }
                if base_expr.kind == 1 {
                    var loaded_class_ptr = cg_types::next_temp(g);
                    cg_types::emit_load_typed(g, loaded_class_ptr, base_ptr, base_ty, p);
                    base_ptr = loaded_class_ptr;
                }
                var data_field_ptr = cg_types::next_temp(g);
                cg_types::emit(g, "    ");
                cg_types::push_temp(g, data_field_ptr);
                cg_types::emit(g, "= getelementptr inbounds ");
                cg_types::emit_type(g, pointee_ty, p);
                cg_types::emit(g, ", ptr ");
                cg_types::push_reg(g, base_ptr);
                cg_types::emit(g, ", i64 0, i32 0");
                cg_types::newline(g);
                var data_reg = cg_types::next_temp(g);
                cg_types::emit_load_typed(g, data_reg, data_field_ptr, semantic::type_pointer(element_ty, true), p);
                element_ptr = cg_types::next_temp(g);
                cg_types::emit(g, "    ");
                cg_types::push_temp(g, element_ptr);
                cg_types::emit(g, "= getelementptr inbounds ");
                cg_types::emit_type(g, element_ty, p);
                cg_types::emit(g, ", ptr ");
                cg_types::push_reg(g, data_reg);
                cg_types::emit(g, ", i64 ");
                cg_types::push_reg(g, index_reg);
            } else {
                element_ty = pointee_ty;
                if base_expr.kind == 1 {
                    var loaded_base_ptr = cg_types::next_temp(g);
                    cg_types::emit_load_typed(g, loaded_base_ptr, base_ptr, base_ty, p);
                    base_ptr = loaded_base_ptr;
                }
                element_ptr = cg_types::next_temp(g);
                cg_types::emit(g, "    ");
                cg_types::push_temp(g, element_ptr);
                cg_types::emit(g, "= getelementptr inbounds ");
                cg_types::emit_type(g, element_ty, p);
                cg_types::emit(g, ", ptr ");
                cg_types::push_reg(g, base_ptr);
                cg_types::emit(g, ", i64 ");
                cg_types::push_reg(g, index_reg);
            }
        } else if semantic::is_class_type(base_ty) {
            element_ty = semantic::type_int();
            var indexed_class_id = base_ty - 4000;
            if indexed_class_id >= 0 and indexed_class_id < (*(*p).arena).classes.len {
                var indexed_class = (*(*p).arena).classes[indexed_class_id];
                if indexed_class.field_len > 0 {
                    var data_field = (*(*p).arena).class_fields[indexed_class.field_start];
                    var data_field_ty = cg_types::resolve_type_simple(p, data_field.type_ref);
                    if semantic::is_pointer_type(data_field_ty) {
                        element_ty = semantic::type_dereference(data_field_ty);
                    }
                }
                if element_ty == semantic::type_unknown() or element_ty == semantic::type_int() {
                    var concrete_name = indexed_class.name_span;
                    var suffix_start = concrete_name.start;
                    var name_i = concrete_name.start;
                    while name_i < concrete_name.end {
                        if p.source.data[name_i] == '_' {
                            suffix_start = name_i + 1;
                            break;
                        }
                        name_i = name_i + 1;
                    }
                    if suffix_start > concrete_name.start {
                        var suffix = span::make(suffix_start, concrete_name.end);
                        var suffix_primitive = semantic::resolve_numeric_alias(p, suffix);
                        if suffix_primitive != semantic::type_unknown() {
                            element_ty = suffix_primitive;
                        } else {
                            var suffix_len = suffix.end - suffix.start;
                            if suffix_len == 4 and
                               p.source.data[suffix.start] == 'b' and
                               p.source.data[suffix.start + 1] == 'o' and
                               p.source.data[suffix.start + 2] == 'o' and
                               p.source.data[suffix.start + 3] == 'l' {
                                element_ty = semantic::type_bool();
                            } else if suffix_len == 4 and
                                      p.source.data[suffix.start] == 'c' and
                                      p.source.data[suffix.start + 1] == 'h' and
                                      p.source.data[suffix.start + 2] == 'a' and
                                      p.source.data[suffix.start + 3] == 'r' {
                                element_ty = semantic::type_char();
                            } else {
                                var suffix_struct = 0;
                                while suffix_struct < (*(*p).arena).structs.len {
                                    if semantic::name_equals(p.source.data, (*(*p).arena).structs[suffix_struct].name_span, suffix) {
                                        element_ty = 1000 + suffix_struct;
                                        break;
                                    }
                                    suffix_struct = suffix_struct + 1;
                                }
                            }
                        }
                    }
                }
            }
            var class_val = base_ptr;
            if base_expr.kind == 1 {
                class_val = cg_types::next_temp(g);
                cg_types::emit_load_typed(g, class_val, base_ptr, base_ty, p);
            }
            var data_reg = cg_types::next_temp(g);
            cg_types::emit(g, "    ");
            cg_types::push_temp(g, data_reg);
            cg_types::emit(g, "= extractvalue ");
            cg_types::emit_type(g, base_ty, p);
            cg_types::emit(g, " ");
            cg_types::push_reg(g, class_val);
            cg_types::emit(g, ", 0");
            cg_types::newline(g);
            element_ptr = cg_types::next_temp(g);
            cg_types::emit(g, "    ");
            cg_types::push_temp(g, element_ptr);
            cg_types::emit(g, "= getelementptr inbounds ");
            cg_types::emit_type(g, element_ty, p);
            cg_types::emit(g, ", ptr ");
            cg_types::push_reg(g, data_reg);
            cg_types::emit(g, ", i64 ");
            cg_types::push_reg(g, index_reg);
        } else {
            element_ptr = cg_types::next_temp(g);
            cg_types::emit(g, "    ");
            cg_types::push_temp(g, element_ptr);
            cg_types::emit(g, "= getelementptr inbounds i64, ptr ");
            cg_types::push_reg(g, base_ptr);
            cg_types::emit(g, ", i64 ");
            cg_types::push_reg(g, index_reg);
        }
        cg_types::newline(g);
        cg_types::set_last(g, element_ty);
        return element_ptr;
    }
    if expr.kind == 9 and expr.child_len > 0 {
        var aggregate_expr_id = (*(*p).arena).expr_refs[expr.child_start];
        var aggregate_expr = (*(*p).arena).exprs[aggregate_expr_id];
        var aggregate_ptr = codegen_lvalue(g, p, aggregate_expr_id, source);
        var aggregate_ty = cg_types::get_last(g);
        var target_ty = aggregate_ty;
        if semantic::is_pointer_type(target_ty) {
            target_ty = semantic::type_dereference(target_ty);
            var is_explicit_deref = aggregate_expr.kind == 5 and aggregate_expr.op_kind == 48;
            if not is_explicit_deref {
                var loaded_aggregate_ptr = cg_types::next_temp(g);
                cg_types::emit_load_typed(g, loaded_aggregate_ptr, aggregate_ptr, aggregate_ty, p);
                aggregate_ptr = loaded_aggregate_ptr;
            }
        }
        var field_idx = -1;
        var field_ty = semantic::type_unknown();
        if semantic::is_struct_type(target_ty) {
            var struct_info = (*(*p).arena).structs[target_ty - 1000];
            var fi = 0;
            while fi < struct_info.field_len {
                var field = (*(*p).arena).struct_fields[struct_info.field_start + fi];
                if semantic::name_equals(source.data, field.name_span, expr.name_span) {
                    field_idx = fi;
                    field_ty = resolve_field_type_for_codegen(p, field.type_ref, field.span);
                    if cg_types::span_ends_with(p, field.name_span, "is_used") {
                        field_ty = semantic::type_bool();
                    }
                    break;
                }
                fi = fi + 1;
            }
        } else if semantic::is_class_type(target_ty) {
            var class_info = (*(*p).arena).classes[target_ty - 4000];
            var fi2 = 0;
            while fi2 < class_info.field_len {
                var field2 = (*(*p).arena).class_fields[class_info.field_start + fi2];
                if semantic::name_equals(source.data, field2.name_span, expr.name_span) {
                    field_idx = fi2;
                    field_ty = resolve_field_type_for_codegen(p, field2.type_ref, field2.span);
                    if cg_types::span_ends_with(p, field2.name_span, "is_used") {
                        field_ty = semantic::type_bool();
                    }
                    break;
                }
                fi2 = fi2 + 1;
            }
        }
        if field_idx >= 0 {
            var field_ptr = cg_types::next_temp(g);
            cg_types::emit_gep(g, field_ptr, target_ty, p, aggregate_ptr, 0, field_idx);
            cg_types::set_last(g, field_ty);
            return field_ptr;
        }
    }
    return -1;
}

export fn operator_method_name(op_kind: int): []char {
    if op_kind == 46 { return "operator+"; }
    if op_kind == 47 { return "operator-"; }
    if op_kind == 48 { return "operator*"; }
    if op_kind == 49 { return "operator/"; }
    if op_kind == 50 { return "operator%"; }
    if op_kind == 51 { return "operator=="; }
    if op_kind == 52 { return "operator!="; }
    if op_kind == 55 { return "operator<"; }
    if op_kind == 56 { return "operator>"; }
    if op_kind == 53 { return "operator<="; }
    if op_kind == 54 { return "operator>="; }
    if op_kind == 74 { return "operator[]"; }
    return "";
}

export fn try_emit_overloaded_binary_op(g: @cg_types::Codegen, p: @resolver::Project, op_kind: int, dest_reg: int, lhs_reg: int, rhs_reg: int, source: @array::Array<char>): bool {
    var lhs_ty = cg_types::get_last(g);
    if lhs_ty < 4000 { return false; }
    var ci = lhs_ty - 4000;
    if ci < 0 or ci >= (*(*p).arena).classes.len { return false; }
    var class_info = (*(*p).arena).classes[ci];
    var op_name = operator_method_name(op_kind);
    if op_name.len == 0 { return false; }
    var mi = 0;
    while mi < class_info.method_len {
        var cm = (*p).arena.class_methods[class_info.method_start + mi];
        var mfunc = (*p).arena.functions[cm.function_id];
        var matched = true;
        var oni = 0;
        while oni < op_name.len {
            if oni >= mfunc.name_span.end - mfunc.name_span.start { matched = false; break; }
            if source.data[mfunc.name_span.start + oni] != op_name[oni] { matched = false; break; }
            oni = oni + 1;
        }
        if matched and oni == mfunc.name_span.end - mfunc.name_span.start {
            var lhs_ptr = cg_types::next_temp(g);
            cg_types::emit_alloca_typed(g, lhs_ptr, lhs_ty, p);
            cg_types::emit_store_typed(g, lhs_reg, lhs_ptr, lhs_ty, p);
            var rhs_ty = cg_types::get_last(g);
            var rhs_ptr = cg_types::next_temp(g);
            cg_types::emit_alloca_typed(g, rhs_ptr, rhs_ty, p);
            cg_types::emit_store_typed(g, rhs_reg, rhs_ptr, rhs_ty, p);
            var param_regs: array::Array<int> = array::Array();
            var param_tys: array::Array<int> = array::Array();
            param_regs.push(lhs_ptr);
            param_tys.push(semantic::type_pointer(lhs_ty, false));
            param_regs.push(rhs_ptr);
            param_tys.push(semantic::type_pointer(rhs_ty, false));
            var ret_ty = semantic::type_int();
            if mfunc.has_return_type {
                var errors: array::Array<semantic::SemanticError> = array::Array();
                var summary = semantic::make_empty_summary();
                ret_ty = semantic::resolve_type_ref(p, mfunc.return_type_ref, @errors, @summary);
            }
            var fn_chars: array::Array<char> = array::Array();
            var class_name_i = class_info.name_span.start;
            while class_name_i < class_info.name_span.end {
                fn_chars.push(source.data[class_name_i]);
                class_name_i = class_name_i + 1;
            }
            fn_chars.push('.');
            var csi = mfunc.name_span.start;
            while csi < mfunc.name_span.end {
                fn_chars.push(source.data[csi]);
                csi = csi + 1;
            }
            cg_types::emit_call(g, dest_reg, fn_chars.data, fn_chars.len, ret_ty, @param_regs, @param_tys, p);
            cg_types::set_last(g, ret_ty);
            return true;
        }
        mi = mi + 1;
    }
    return false;
}

export fn find_struct_field_index_for_codegen(p: @resolver::Project, member: span::Span): int {
    var si = 0;
    while si < (*(*p).arena).structs.len {
        var st = (*(*p).arena).structs[si];
        var fi = 0;
        while fi < st.field_len {
            var f = (*(*p).arena).struct_fields[st.field_start + fi];
            if semantic::name_equals(p.source.data, f.name_span, member) {
                return fi;
            }
            fi = fi + 1;
        }
        si = si + 1;
    }
    var ci = 0;
    while ci < (*(*p).arena).classes.len {
        var cl = (*(*p).arena).classes[ci];
        var fi = 0;
        while fi < cl.field_len {
            var f = (*(*p).arena).class_fields[cl.field_start + fi];
            if semantic::name_equals(p.source.data, f.name_span, member) {
                return fi;
            }
            fi = fi + 1;
        }
        ci = ci + 1;
    }
    return -1;
}

export fn emit_binop_with_zero(g: @cg_types::Codegen, dest_reg: int, op: []char, rhs_reg: int, p: @resolver::Project) {
    var ty = cg_types::get_last(g);
    if (ty == semantic::type_float() or ty == semantic::type_float32() or ty == semantic::type_float64()) {
        cg_types::push_temp(g, dest_reg);
        cg_types::emit(g, "= fsub ");
        cg_types::emit_type(g, ty, p);
        cg_types::emit(g, " 0.0, ");
        cg_types::push_reg(g, rhs_reg);
        cg_types::newline(g);
        return;
    }
    var zero_reg = cg_types::next_temp(g);
    cg_types::emit(g, "    ");
    cg_types::push_temp(g, zero_reg);
    cg_types::emit(g, "= add ");
    cg_types::emit_type(g, ty, p);
    cg_types::emit(g, " 0, 0");
    cg_types::newline(g);
    cg_types::push_temp(g, dest_reg);
    cg_types::emit(g, "= ");
    cg_types::emit(g, op);
    cg_types::emit(g, " i64 0, ");
    cg_types::push_reg(g, rhs_reg);
    cg_types::newline(g);
}


export fn llvm_fn_ty(return_ty: int): []char {
    if return_ty == cg_types::type_void_val() { return "void"; }
    return cg_types::llvm_type(return_ty);
}

export fn coerce_type(g: @cg_types::Codegen, p: @resolver::Project, from_reg: int, from_ty: int, to_ty: int): int {
    if from_ty == to_ty { return from_reg; }
    if semantic::is_class_type(from_ty) and semantic::is_class_type(to_ty) {
        var to_class_id = to_ty - 4000;
        if to_class_id >= 0 and to_class_id < (*(*p).arena).classes.len {
            var to_class = (*(*p).arena).classes[to_class_id];
            var converted_value = -1;
            var field_index = 0;
            while field_index < to_class.field_len {
                var field = (*(*p).arena).class_fields[to_class.field_start + field_index];
                var field_ty = resolve_field_type_for_codegen(p, field.type_ref, field.span);
                var extracted = cg_types::next_temp(g);
                cg_types::emit(g, "    ");
                cg_types::push_temp(g, extracted);
                cg_types::emit(g, "= extractvalue ");
                cg_types::emit_type(g, from_ty, p);
                cg_types::emit(g, " ");
                cg_types::push_reg(g, from_reg);
                cg_types::emit(g, ", ");
                cg_types::emit_int(g, field_index);
                cg_types::newline(g);
                var inserted = cg_types::next_temp(g);
                cg_types::emit(g, "    ");
                cg_types::push_temp(g, inserted);
                cg_types::emit(g, "= insertvalue ");
                cg_types::emit_type(g, to_ty, p);
                cg_types::emit(g, " ");
                if converted_value < 0 {
                    cg_types::emit(g, "undef");
                } else {
                    cg_types::push_reg(g, converted_value);
                }
                cg_types::emit(g, ", ");
                cg_types::emit_type(g, field_ty, p);
                cg_types::emit(g, " ");
                cg_types::push_reg(g, extracted);
                cg_types::emit(g, ", ");
                cg_types::emit_int(g, field_index);
                cg_types::newline(g);
                converted_value = inserted;
                field_index = field_index + 1;
            }
            if converted_value >= 0 {
                return converted_value;
            }
        }
    }
    if from_ty == semantic::type_string_literal() and semantic::is_class_type(to_ty) {
        var class_id = to_ty - 4000;
        if class_id >= 0 and class_id < (*(*p).arena).classes.len {
            var class_info = (*(*p).arena).classes[class_id];
            var fn_name: array::Array<char> = array::Array();
            var name_i = class_info.name_span.start;
            while name_i < class_info.name_span.end {
                fn_name.push(p.source.data[name_i]);
                name_i = name_i + 1;
            }
            fn_name.push('.');
            fn_name.push('f'); fn_name.push('r'); fn_name.push('o'); fn_name.push('m');
            var regs: array::Array<int> = array::Array();
            var tys: array::Array<int> = array::Array();
            regs.push(from_reg);
            tys.push(from_ty);
            var converted = cg_types::next_temp(g);
            cg_types::emit_call(g, converted, fn_name.data, fn_name.len, to_ty, @regs, @tys, p);
            return converted;
        }
    }
    if to_ty >= 10000 and from_ty == semantic::type_int() {
        var r = cg_types::next_temp(g);
        cg_types::emit(g, "    "); cg_types::push_temp(g, r); cg_types::emit(g, "= inttoptr i64 "); cg_types::push_reg(g, from_reg); cg_types::emit(g, " to "); cg_types::emit_type(g, to_ty, p); cg_types::newline(g);
        return r;
    }
    if from_ty >= 10000 and to_ty == semantic::type_int() {
        var r = cg_types::next_temp(g);
        cg_types::emit(g, "    "); cg_types::push_temp(g, r); cg_types::emit(g, "= ptrtoint "); cg_types::emit_type(g, from_ty, p); cg_types::emit(g, " "); cg_types::push_reg(g, from_reg); cg_types::emit(g, " to i64"); cg_types::newline(g);
        return r;
    }
    if cg_types::is_llvm_integer_type(from_ty) and cg_types::is_llvm_integer_type(to_ty) {
        var fw = cg_types::integer_width(from_ty);
        var tw = cg_types::integer_width(to_ty);
        if fw != tw {
            var r = cg_types::next_temp(g);
            cg_types::emit(g, "    "); cg_types::push_temp(g, r);
            if fw < tw {
                cg_types::emit(g, "= zext ");
            } else {
                cg_types::emit(g, "= trunc ");
            }
            cg_types::emit_type(g, from_ty, p);
            cg_types::emit(g, " ");
            cg_types::push_reg(g, from_reg);
            cg_types::emit(g, " to ");
            cg_types::emit_type(g, to_ty, p);
            cg_types::newline(g);
            return r;
        }
    }
    return from_reg;
}

export fn codegen_stmt(g: @cg_types::Codegen, p: @resolver::Project, stmt: ast::Stmt, source: @array::Array<char>) {
    if (*g).block_terminated { return; }

    if stmt.kind == 10 {
        codegen_expr(g, p, stmt.expr_id, source);
    } else if stmt.kind == 1 {
        var init_reg = -1;
        var init_ty = semantic::type_int();
        var ty = semantic::type_int();
        if stmt.var_decl.has_init {
            init_reg = codegen_expr(g, p, stmt.var_decl.init_expr_id, source);
            init_ty = cg_types::get_last(g);
            ty = init_ty;
        }
        if stmt.var_decl.has_type_hint {
            var errors: array::Array<semantic::SemanticError> = array::Array();
            var summary = semantic::make_empty_summary();
            ty = semantic::resolve_type_ref(p, stmt.var_decl.type_ref, @errors, @summary);
        }
        if init_reg >= 0 {
            init_reg = coerce_type(g, p, init_reg, init_ty, ty);
        }
        var reg = cg_types::next_temp(g);
        if ty >= 1000 or ty >= 2000 or ty >= 3000 or ty >= 4000 {
            cg_types::emit_alloca_typed(g, reg, ty, p);
        } else {
            cg_types::emit_alloca(g, reg, ty, p);
        }
        if init_reg >= 0 {
            if ty >= 1000 or ty >= 2000 or ty >= 3000 or ty >= 4000 {
                cg_types::emit_store_typed(g, init_reg, reg, ty, p);
            } else {
                cg_types::emit_store(g, init_reg, reg, ty, p);
            }
        } else {
            cg_types::emit_default_store(g, reg, ty, p);
        }
        cg_types::register_local(g, p, stmt.var_decl.name_span, ty, reg);
        if ty >= 4000 { cg_types::register_cleanup(g, reg, ty); }
    } else if stmt.kind == 2 {
        var init_reg = codegen_expr(g, p, stmt.const_decl.init_expr_id, source);
        var init_ty = cg_types::get_last(g);
        var ty = init_ty;
        if stmt.const_decl.has_type_hint {
            var errors: array::Array<semantic::SemanticError> = array::Array();
            var summary = semantic::make_empty_summary();
            ty = semantic::resolve_type_ref(p, stmt.const_decl.type_ref, @errors, @summary);
        }
        init_reg = coerce_type(g, p, init_reg, init_ty, ty);
        var reg = cg_types::next_temp(g);
        if ty >= 1000 or ty >= 2000 or ty >= 3000 or ty >= 4000 {
            cg_types::emit_alloca_typed(g, reg, ty, p);
        } else {
            cg_types::emit_alloca(g, reg, ty, p);
        }
        if init_reg >= 0 {
            if ty >= 1000 or ty >= 2000 or ty >= 3000 or ty >= 4000 {
                cg_types::emit_store_typed(g, init_reg, reg, ty, p);
            } else {
                cg_types::emit_store(g, init_reg, reg, ty, p);
            }
        }
        cg_types::register_local(g, p, stmt.const_decl.name_span, ty, reg);
        if ty >= 4000 { cg_types::register_cleanup(g, reg, ty); }
    } else if stmt.kind == 4 {
        var cleanup_count = (*g).cleanup_regs.len;
        cg_types::push_scope(g);
        codegen_block_flat(g, p, stmt.block_id, source);
        if !(*g).block_terminated {
            cg_types::emit_cleanups_to_depth(g, p, (*g).scope_depth);
        }
        cg_types::truncate_cleanups(g, cleanup_count);
        cg_types::pop_scope(g);
    } else if stmt.kind == 3 {
        var value_reg = codegen_expr(g, p, stmt.assign_stmt.value_expr_id, source);
        var value_ty = cg_types::get_last(g);
        var assignment_target_expr = (*(*p).arena).exprs[stmt.assign_stmt.target_expr_id];
        if assignment_target_expr.kind == 5 and assignment_target_expr.op_kind == 74 and assignment_target_expr.child_len > 1 {
            var map_base_expr_id = (*(*p).arena).expr_refs[assignment_target_expr.child_start];
            var map_base_ptr = codegen_lvalue(g, p, map_base_expr_id, source);
            var map_base_ty = cg_types::get_last(g);
            if map_base_ptr >= 0 and cg_types::class_name_is(p, map_base_ty, "HashMap") {
                var map_key_expr_id = (*(*p).arena).expr_refs[assignment_target_expr.child_start + 1];
                var map_key_reg = codegen_expr(g, p, map_key_expr_id, source);
                var map_key_ty = cg_types::get_last(g);
                var map_slot_ptr = cg_types::emit_hashmap_slot_ptr(g, p, map_base_ptr, map_base_ty, map_key_reg, map_key_ty);
                cg_types::emit_store_typed(g, value_reg, map_slot_ptr, semantic::type_int(), p);
                var map_len_ptr = cg_types::next_temp(g);
                cg_types::emit_gep(g, map_len_ptr, map_base_ty, p, map_base_ptr, 0, 1);
                var old_map_len = cg_types::next_temp(g);
                cg_types::emit_load_typed(g, old_map_len, map_len_ptr, semantic::type_int(), p);
                var map_one = cg_types::next_temp(g);
                cg_types::emit(g, "    "); cg_types::push_temp(g, map_one); cg_types::emit(g, "= add i64 0, 1"); cg_types::newline(g);
                var new_map_len = cg_types::next_temp(g);
                cg_types::emit_binop(g, new_map_len, "add", semantic::type_int(), old_map_len, map_one, p);
                cg_types::emit_store_typed(g, new_map_len, map_len_ptr, semantic::type_int(), p);
                return;
            }
        }
        var target_ptr = codegen_lvalue(g, p, stmt.assign_stmt.target_expr_id, source);
        var target_ty = cg_types::get_last(g);
        if target_ptr >= 0 and value_reg >= 0 {
            value_reg = coerce_type(g, p, value_reg, value_ty, target_ty);
            cg_types::emit_store_typed(g, value_reg, target_ptr, target_ty, p);
            return;
        }
        var is_deref = false;
        var is_deref_member = false;
        if p.source.data[stmt.assign_stmt.span.start] == '*' { is_deref = true; }
        if p.source.data[stmt.assign_stmt.span.start] == '(' { is_deref_member = true; }
        if is_deref_member {
            var si = stmt.assign_stmt.target_name_span.start + 2;
            var name_end = si;
            while name_end < stmt.assign_stmt.target_name_span.end and p.source.data[name_end] != ')' { name_end = name_end + 1; }
            var inner_name = span::make(si, name_end);
            var dot_idx = name_end + 1;
            while dot_idx < stmt.assign_stmt.target_name_span.end and p.source.data[dot_idx] != '.' { dot_idx = dot_idx + 1; }
            var field_name_start = dot_idx + 1;
            var field_name_end = stmt.assign_stmt.target_name_span.end;
            var field_name_span = span::make(field_name_start, field_name_end);
            var ptr_reg = cg_types::lookup_local(g, p, inner_name);
            if ptr_reg >= 0 and value_reg >= 0 {
                var ty = cg_types::lookup_local_type(g, p, inner_name);
                var loaded_ptr = cg_types::next_temp(g);
                cg_types::emit_load(g, loaded_ptr, ptr_reg, ty, p);
                var field_idx = find_struct_field_index_for_codegen(p, field_name_span);
                if field_idx >= 0 {
                    var base_ty = semantic::type_int();
                    var si2 = 0;
                    while si2 < (*(*p).arena).structs.len {
                        var st = (*(*p).arena).structs[si2];
                        var fi = 0;
                        while fi < st.field_len {
                            var f = (*(*p).arena).struct_fields[st.field_start + fi];
                            if semantic::name_equals(p.source.data, f.name_span, field_name_span) { base_ty = 1000 + si2; break; }
                            fi = fi + 1;
                        }
                        si2 = si2 + 1;
                    }
                    var ci3 = 0;
                    while ci3 < (*(*p).arena).classes.len {
                        var cl = (*(*p).arena).classes[ci3];
                        var fi2 = 0;
                        while fi2 < cl.field_len {
                            var f2 = (*(*p).arena).class_fields[cl.field_start + fi2];
                            if semantic::name_equals(p.source.data, f2.name_span, field_name_span) { base_ty = 4000 + ci3; break; }
                            fi2 = fi2 + 1;
                        }
                        ci3 = ci3 + 1;
                    }
                    var field_ptr = cg_types::next_temp(g);
                    cg_types::emit_gep(g, field_ptr, base_ty, p, loaded_ptr, 0, field_idx);
                    var assigned_field_ty = semantic::type_int();
                    if cg_types::span_ends_with(p, field_name_span, "is_used") {
                        assigned_field_ty = semantic::type_bool();
                    }
                    cg_types::emit_store(g, value_reg, field_ptr, assigned_field_ty, p);
                }
            }
        } else if is_deref {
            var name_start_deref = stmt.assign_stmt.target_name_span.start + 1;
            var name_end_deref = stmt.assign_stmt.target_name_span.end;
            var deref_name_span = span::make(name_start_deref, name_end_deref);
            var ptr_reg = cg_types::lookup_local(g, p, deref_name_span);
            if ptr_reg >= 0 and value_reg >= 0 {
                var ty = cg_types::lookup_local_type(g, p, deref_name_span);
                var loaded_ptr = cg_types::next_temp(g);
                cg_types::emit_load(g, loaded_ptr, ptr_reg, ty, p);
                var deref_ty = semantic::type_int();
                cg_types::emit_store(g, value_reg, loaded_ptr, deref_ty, p);
            }
        } else {
        var target_reg = cg_types::lookup_local(g, p, stmt.assign_stmt.target_name_span);
        if target_reg >= 0 and value_reg >= 0 {
            var ty = cg_types::lookup_local_type(g, p, stmt.assign_stmt.target_name_span);
            var value_ty = cg_types::get_last(g);
            value_reg = coerce_type(g, p, value_reg, value_ty, ty);
            if ty >= 1000 or ty >= 2000 or ty >= 3000 or ty >= 4000 {
                cg_types::emit_store_typed(g, value_reg, target_reg, ty, p);
            } else {
                cg_types::emit_store(g, value_reg, target_reg, ty, p);
            }
        }
        }
    } else if stmt.kind == 9 {
        if stmt.return_stmt.has_value {
            var keep_reg = -1;
            var return_expr = (*(*p).arena).exprs[stmt.return_stmt.value_expr_id];
            if return_expr.kind == 1 {
                keep_reg = cg_types::lookup_local(g, p, return_expr.name_span);
            }
            var ret_reg = codegen_expr(g, p, stmt.return_stmt.value_expr_id, source);
            var ret_ty = cg_types::get_last(g);
            var expected_ret_ty = (*g).fn_return_type;
            ret_reg = coerce_type(g, p, ret_reg, ret_ty, expected_ret_ty);
            cg_types::emit_all_cleanups_except(g, p, keep_reg);
            cg_types::emit_ret(g, ret_reg, expected_ret_ty, p);
        } else {
            cg_types::emit_all_cleanups(g, p);
            cg_types::emit_ret(g, -1, (*g).fn_return_type, p);
        }
    } else if stmt.kind == 5 {
        var cond_reg = codegen_expr(g, p, stmt.if_stmt.condition_expr_id, source);
        var then_label = cg_types::next_label(g);
        var else_label = cg_types::next_label(g);
        var end_label = cg_types::next_label(g);
        cg_types::emit_cond_br(g, cond_reg, then_label, else_label);

        (*g).block_terminated = false;
        cg_types::emit_label(g, then_label);
        var then_cleanup_count = (*g).cleanup_regs.len;
        cg_types::push_scope(g);
        codegen_block_flat(g, p, stmt.if_stmt.then_block_id, source);
        if !(*g).block_terminated {
            cg_types::emit_cleanups_to_depth(g, p, (*g).scope_depth);
            cg_types::emit_br(g, end_label);
        }
        cg_types::truncate_cleanups(g, then_cleanup_count);
        cg_types::pop_scope(g);

        (*g).block_terminated = false;
        cg_types::emit_label(g, else_label);
        var else_cleanup_count = (*g).cleanup_regs.len;
        cg_types::push_scope(g);
        if stmt.if_stmt.has_else_block {
            codegen_block_flat(g, p, stmt.if_stmt.else_block_id, source);
        }
        if !(*g).block_terminated {
            cg_types::emit_cleanups_to_depth(g, p, (*g).scope_depth);
            cg_types::emit_br(g, end_label);
        }
        cg_types::truncate_cleanups(g, else_cleanup_count);
        cg_types::pop_scope(g);

        (*g).block_terminated = false;
        cg_types::emit_label(g, end_label);
    } else if stmt.kind == 6 {
        var cond_label = cg_types::next_label(g);
        var body_label = cg_types::next_label(g);
        var end_label = cg_types::next_label(g);

        var old_break = (*g).loop_break;
        var old_continue = (*g).loop_continue;
        var old_loop_cleanup_depth = (*g).loop_cleanup_depth;
        cg_types::push_loop(g, end_label, cond_label);

        cg_types::emit_br(g, cond_label);
        cg_types::emit_label(g, cond_label);
        var cond_reg = codegen_expr(g, p, stmt.while_stmt.condition_expr_id, source);
        cg_types::emit_cond_br(g, cond_reg, body_label, end_label);

        (*g).block_terminated = false;
        cg_types::emit_label(g, body_label);
        var body_cleanup_count = (*g).cleanup_regs.len;
        cg_types::push_scope(g);
        codegen_block_flat(g, p, stmt.while_stmt.body_block_id, source);
        if !(*g).block_terminated {
            cg_types::emit_cleanups_to_depth(g, p, (*g).scope_depth);
            cg_types::emit_br(g, cond_label);
        }
        cg_types::truncate_cleanups(g, body_cleanup_count);
        cg_types::pop_scope(g);

        (*g).block_terminated = false;
        cg_types::emit_label(g, end_label);
        cg_types::pop_loop(g, old_break, old_continue, old_loop_cleanup_depth);
    } else if stmt.kind == 7 {
        if (*g).loop_break >= 0 {
            cg_types::emit_cleanups_to_depth(g, p, (*g).loop_cleanup_depth);
            cg_types::emit_br(g, (*g).loop_break);
            (*g).block_terminated = true;
        }
    } else if stmt.kind == 8 {
        if (*g).loop_continue >= 0 {
            cg_types::emit_cleanups_to_depth(g, p, (*g).loop_cleanup_depth);
            cg_types::emit_br(g, (*g).loop_continue);
            (*g).block_terminated = true;
        }
    } else if stmt.kind == 11 {
        var val_reg = codegen_expr(g, p, stmt.match_stmt.value_expr_id, source);
        var val_ty = cg_types::get_last(g);
        var end_label = cg_types::next_label(g);
        var tag_reg = val_reg;
        if val_ty >= 3000 and val_ty < 4000 {
            tag_reg = cg_types::next_temp(g);
            cg_types::emit(g, "    ");
            cg_types::push_temp(g, tag_reg);
            cg_types::emit(g, "= extractvalue ");
            cg_types::emit_type(g, val_ty, p);
            cg_types::emit(g, " ");
            cg_types::push_reg(g, val_reg);
            cg_types::emit(g, ", 0");
            cg_types::newline(g);
        }
        var i = 0;
        while i < stmt.match_stmt.arm_len {
            var arm = (*(*p).arena).match_arms[stmt.match_stmt.arm_start + i];
            var arm_label = cg_types::next_label(g);
            var next_check_label = cg_types::next_label(g);
            var is_wildcard = arm.variant_span.start == 0 and arm.type_span.start == 0;
            var is_single_underscore = arm.variant_span.start > 0 and arm.type_span.start == 0 and arm.variant_span.end - arm.variant_span.start == 1 and source.data[arm.variant_span.start] == '_';
            if is_wildcard or is_single_underscore {
                (*g).block_terminated = false;
                cg_types::emit_br(g, arm_label);
            } else if arm.variant_span.start > 0 and arm.type_span.start == 0 {
                var lit_val = cg_types::next_temp(g);
                cg_types::emit(g, "    ");
                cg_types::push_temp(g, lit_val);
                cg_types::emit(g, "= add i64 0, ");
                var li = arm.variant_span.start;
                while li < arm.variant_span.end {
                    (*g).output.push(source.data[li]);
                    li = li + 1;
                }
                cg_types::newline(g);
                var cmp_reg = cg_types::next_temp(g);
                cg_types::emit_icmp(g, cmp_reg, "eq", semantic::type_int(), val_reg, lit_val, p);
                cg_types::emit_cond_br(g, cmp_reg, arm_label, next_check_label);
            } else if arm.variant_span.start > 0 {
                var disc = cg_types::next_temp(g);
                cg_types::emit(g, "    ");
                cg_types::push_temp(g, disc);
                cg_types::emit(g, "= add i64 0, ");
                cg_types::emit_int(g, i);
                cg_types::newline(g);
                var cmp_reg = cg_types::next_temp(g);
                cg_types::emit_icmp(g, cmp_reg, "eq", semantic::type_int(), tag_reg, disc, p);
                cg_types::emit_cond_br(g, cmp_reg, arm_label, next_check_label);
            } else {
                cg_types::emit_br(g, next_check_label);
            }
            (*g).block_terminated = false;
            cg_types::emit_label(g, arm_label);
            var arm_cleanup_count = (*g).cleanup_regs.len;
            cg_types::push_scope(g);
            if val_ty >= 3000 and val_ty < 4000 and arm.has_binding {
                var payload_raw = cg_types::next_temp(g);
                cg_types::emit(g, "    ");
                cg_types::push_temp(g, payload_raw);
                cg_types::emit(g, "= extractvalue ");
                cg_types::emit_type(g, val_ty, p);
                cg_types::emit(g, " ");
                cg_types::push_reg(g, val_reg);
                cg_types::emit(g, ", 1");
                cg_types::newline(g);
                var binding_alloca = cg_types::next_temp(g);
                cg_types::emit_alloca(g, binding_alloca, semantic::type_int(), p);
                cg_types::emit_store(g, payload_raw, binding_alloca, semantic::type_int(), p);
                cg_types::register_local(g, p, arm.binding_span, semantic::type_int(), binding_alloca);
            }
            codegen_block_flat(g, p, arm.block_id, source);
            if !(*g).block_terminated {
                cg_types::emit_cleanups_to_depth(g, p, (*g).scope_depth);
                cg_types::emit_br(g, end_label);
            }
            cg_types::truncate_cleanups(g, arm_cleanup_count);
            cg_types::pop_scope(g);
            (*g).block_terminated = false;
            cg_types::emit_label(g, next_check_label);
            i = i + 1;
        }
        cg_types::emit_br(g, end_label);
        (*g).block_terminated = false;
        cg_types::emit_label(g, end_label);
    }
}

export fn codegen_block_flat(g: @cg_types::Codegen, p: @resolver::Project, block_id: int, source: @array::Array<char>) {
    if block_id < 0 { return; }
    var block = (*(*p).arena).blocks[block_id];
    var i = 0;
    while i < block.stmt_ref_len {
        if (*g).block_terminated { break; }
        var stmt = (*(*p).arena).stmts[(*(*p).arena).stmt_refs[block.stmt_ref_start + i]];
        codegen_stmt(g, p, stmt, source);
        i = i + 1;
    }
}

export fn codegen_function(g: @cg_types::Codegen, p: @resolver::Project, fn_id: int, source: @array::Array<char>) {
    var fn_info = (*(*p).arena).functions[fn_id];
    (*g).temp_counter = 0;
    (*g).label_counter = 0;
    (*g).cleanup_regs.len = 0;
    (*g).cleanup_classes.len = 0;
    (*g).cleanup_depths.len = 0;
    (*g).loop_break = -1;
    (*g).loop_continue = -1;
    (*g).loop_cleanup_depth = -1;
    (*g).scope_depth = 0;
    (*g).local_count = 0;
    (*g).local_names.len = 0;
    (*g).local_regs.len = 0;
    (*g).local_types.len = 0;

    // DEBUG TRACE
    cg_types::emit(g, "; DEBUG: codegen_function for ");
    var ni2 = fn_info.name_span.start;
    while ni2 < fn_info.name_span.end {
        (*g).output.push(source.data[ni2]);
        ni2 = ni2 + 1;
    }
    cg_types::emit(g, ", generic_param_len: "); cg_types::emit_int(g, fn_info.generic_param_len);
    cg_types::emit(g, ", body_block_id: "); cg_types::emit_int(g, fn_info.body_block_id);
    cg_types::newline(g);

    var ret_ty: int;
    ret_ty = semantic::type_void();
    if fn_info.has_return_type {
        var errors: array::Array<semantic::SemanticError> = array::Array();
        var summary = semantic::make_empty_summary();
        ret_ty = cg_types::resolve_type_simple(p, fn_info.return_type_ref);
    }

    if fn_info.body_block_id < 0 {
        var is_variadic = false;
        {
            var param_end = fn_info.span.end;
            var scan = fn_info.name_span.end;
            while scan < param_end - 1 {
                if source.data[scan] == '.' and source.data[scan+1] == '.' and source.data[scan+2] == '.' {
                    is_variadic = true;
                    break;
                }
                scan = scan + 1;
            }
        }
        if cg_types::is_extern_emitted(g, p, fn_info.name_span) {
            return;
        }
        cg_types::record_extern_emitted(g, fn_info.name_span);
        (*g).fn_is_main = cg_types::span_ends_with(p, fn_info.name_span, "main");
        cg_types::emit(g, "declare ");
        if (*g).fn_is_main and ret_ty == semantic::type_int() {
            cg_types::emit(g, "i32");
        } else {
            cg_types::emit_type(g, ret_ty, p);
        }
        cg_types::emit(g, " @\"");
        var declaration_name: array::Array<char> = array::Array();
        cg_types::append_function_symbol(@declaration_name, p, fn_id);
        var declaration_i = 0;
        while declaration_i < declaration_name.len {
            (*g).output.push(declaration_name[declaration_i]);
            declaration_i = declaration_i + 1;
        }
        cg_types::emit(g, "\"(");
        var pi = 0;
        while pi < fn_info.param_len {
            var param = (*(*p).arena).params[fn_info.param_start + pi];
            var pty = semantic::type_int();
            if param.has_type_hint {
                var errors: array::Array<semantic::SemanticError> = array::Array();
                var summary = semantic::make_empty_summary();
                pty = cg_types::resolve_type_simple(p, param.type_ref);
            }
            if pi > 0 { cg_types::emit(g, ", "); }
            cg_types::emit_type(g, pty, p);
            pi = pi + 1;
        }
        if is_variadic { cg_types::emit(g, ", ..."); }
        cg_types::emit(g, ")");
        cg_types::newline(g);
        cg_types::newline(g);
        return;
    }

    (*g).fn_is_main = cg_types::span_ends_with(p, fn_info.name_span, "main");
    cg_types::emit(g, "define ");
    if (*g).fn_is_main and ret_ty == semantic::type_int() {
        cg_types::emit(g, "i32");
    } else {
        cg_types::emit_type(g, ret_ty, p);
    }
    cg_types::emit(g, " @\"");
    var ci2 = 0;
    while ci2 < (*(*p).arena).classes.len {
        var cl2 = (*(*p).arena).classes[ci2];
        var mi2 = 0;
        while mi2 < cl2.method_len {
            var cm2 = (*(*p).arena).class_methods[cl2.method_start + mi2];
            if cm2.function_id == fn_id {
                break;
            }
            mi2 = mi2 + 1;
        }
        if mi2 < cl2.method_len { break; }
        ci2 = ci2 + 1;
    }
    var definition_name: array::Array<char> = array::Array();
    cg_types::append_function_symbol(@definition_name, p, fn_id);
    var definition_i = 0;
    while definition_i < definition_name.len {
        (*g).output.push(definition_name[definition_i]);
        definition_i = definition_i + 1;
    }
    cg_types::emit(g, "\"(");
    var pi = 0;
    while pi < fn_info.param_len {
        var param = (*(*p).arena).params[fn_info.param_start + pi];
        var pty = semantic::type_int();
        if param.has_type_hint {
            var errors: array::Array<semantic::SemanticError> = array::Array();
            var summary = semantic::make_empty_summary();
            pty = cg_types::resolve_type_simple(p, param.type_ref);
        } else if pi == 0 and ci2 < (*(*p).arena).classes.len {
            pty = semantic::type_pointer(4000 + ci2, false);
        }
        if pi > 0 { cg_types::emit(g, ", "); }
        cg_types::emit_type(g, pty, p);
        cg_types::emit(g, " %");
        var pj = param.name_span.start;
        while pj < param.name_span.end {
            (*g).output.push(source.data[pj]);
            pj = pj + 1;
        }
        pi = pi + 1;
    }
    cg_types::emit(g, ") {");
    cg_types::newline(g);
    cg_types::emit(g, "entry:");
    cg_types::newline(g);

    pi = 0;
    while pi < fn_info.param_len {
        var param = (*(*p).arena).params[fn_info.param_start + pi];
        var pty = semantic::type_int();
        if param.has_type_hint {
            var errors: array::Array<semantic::SemanticError> = array::Array();
            var summary = semantic::make_empty_summary();
            pty = cg_types::resolve_type_simple(p, param.type_ref);
        } else if pi == 0 and ci2 < (*(*p).arena).classes.len {
            pty = semantic::type_pointer(4000 + ci2, false);
        }
        var alloca_reg = 10000 + pi;
        if pty >= 1000 or pty >= 2000 or pty >= 3000 or pty >= 4000 {
            cg_types::emit_alloca_typed(g, alloca_reg, pty, p);
        } else {
            cg_types::emit_alloca(g, alloca_reg, pty, p);
        }
        cg_types::register_local(g, p, param.name_span, pty, alloca_reg);
        if pty >= 1000 or pty >= 2000 or pty >= 3000 or pty >= 4000 {
            cg_types::emit(g, "    store ");
            cg_types::emit_type(g, pty, p);
            cg_types::emit(g, " %");
            var pj = param.name_span.start;
            while pj < param.name_span.end {
                (*g).output.push(source.data[pj]);
                pj = pj + 1;
            }
            cg_types::emit(g, ", ptr ");
            cg_types::push_reg(g, alloca_reg);
            cg_types::newline(g);
        } else {
        var load_reg = cg_types::next_temp(g);
        cg_types::emit(g, "    ");
        cg_types::push_temp(g, load_reg);
        if semantic::is_float_type(pty) {
            cg_types::emit(g, "= fadd ");
            cg_types::emit_type(g, pty, p);
            cg_types::emit(g, " 0.0, %");
        } else {
            cg_types::emit(g, "= add ");
            cg_types::emit_type(g, pty, p);
            cg_types::emit(g, " 0, %");
        }
        var pj = param.name_span.start;
        while pj < param.name_span.end {
            (*g).output.push(source.data[pj]);
            pj = pj + 1;
        }
        cg_types::newline(g);
        if pty >= 1000 or pty >= 2000 or pty >= 3000 or pty >= 4000 {
            cg_types::emit_store_typed(g, load_reg, alloca_reg, pty, p);
        } else {
            cg_types::emit_store(g, load_reg, alloca_reg, pty, p);
        }
        }
        pi = pi + 1;
    }

    (*g).current_fn_id = fn_id;
    (*g).fn_return_type = ret_ty;
    (*g).block_terminated = false;
    (*g).local_count = 0;
    (*g).local_names.len = 0;
    (*g).local_regs.len = 0;
    (*g).local_types.len = 0;
    codegen_block_flat(g, p, fn_info.body_block_id, source);
    if !(*g).block_terminated {
        cg_types::emit_all_cleanups(g, p);
        if ret_ty == cg_types::type_void_val() {
            cg_types::emit_ret_void(g);
        } else {
            cg_types::emit_ret(g, -1, ret_ty, p);
        }
    }
    cg_types::emit(g, "}");
    cg_types::newline(g);
    cg_types::newline(g);
}

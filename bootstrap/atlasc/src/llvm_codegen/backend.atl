import array;
import ast;
import monomorphizer;
import resolver;
import semantic;
import span;
import string;
import token;
import cg_types;

fn concrete_choice_for_codegen(p: @resolver::Project, choice_idx: int): int {
    if choice_idx < 0 or choice_idx >= (*(*p).arena).choices.len {
        return choice_idx;
    }
    var generic = (*(*p).arena).choices[choice_idx];
    var source = p.source.data;
    var generic_len = generic.name_span.end - generic.name_span.start;
    var i = (*(*p).arena).choices.len - 1;
    while i >= 0 {
        var candidate = (*(*p).arena).choices[i];
        var candidate_len = candidate.name_span.end - candidate.name_span.start;
        if candidate_len > generic_len {
            var matches = true;
            var j = 0;
            while j < generic_len {
                if source[candidate.name_span.start + j] != source[generic.name_span.start + j] {
                    matches = false;
                }
                j = j + 1;
            }
            if matches and source[candidate.name_span.start + generic_len] == '_' {
                return i;
            }
        }
        i = i - 1;
    }
    return choice_idx;
}

fn concrete_class_type_arg(p: @resolver::Project, class_ty: int): int {
    if !semantic::is_class_type(class_ty) {
        return semantic::type_unknown();
    }
    var class_id = class_ty - 4000;
    if class_id < 0 or class_id >= (*(*p).arena).classes.len {
        return semantic::type_unknown();
    }
    var name = (*(*p).arena).classes[class_id].name_span;
    var source = p.source.data;
    var separator = name.start;
    while separator < name.end and source[separator] != '_' {
        separator = separator + 1;
    }
    if separator >= name.end - 1 {
        return semantic::type_unknown();
    }
    var arg_name = span::make(separator + 1, name.end);
    var arg_len = arg_name.end - arg_name.start;
    if arg_len == 4 and source[arg_name.start] == 'c' and source[arg_name.start + 1] == 'h' and source[arg_name.start + 2] == 'a' and source[arg_name.start + 3] == 'r' {
        return semantic::type_char();
    }
    var numeric = semantic::resolve_numeric_alias(p, arg_name);
    if numeric != semantic::type_unknown() {
        return numeric;
    }
    return semantic::resolve_type_ref_from_name(p, arg_name);
}

fn current_class_element_type(g: @cg_types::Codegen, p: @resolver::Project): int {
    if (*g).current_fn_id >= 0 and (*g).current_fn_id < (*(*p).arena).functions.len {
        var current_fn = (*(*p).arena).functions[(*g).current_fn_id];
        if current_fn.has_return_type {
            var return_ty = cg_types::resolve_type_simple(p, current_fn.return_type_ref);
            if return_ty != semantic::type_void() and return_ty != semantic::type_unknown() {
                return return_ty;
            }
        }
        var pi = current_fn.param_len - 1;
        while pi > 0 {
            var param = (*(*p).arena).params[current_fn.param_start + pi];
            if param.has_type_hint {
                var param_ty = cg_types::resolve_type_simple(p, param.type_ref);
                if param_ty != semantic::type_unknown() {
                    return param_ty;
                }
            }
            pi = pi - 1;
        }
    }

    var ci = 0;
    while ci < (*(*p).arena).classes.len {
        var class_info = (*(*p).arena).classes[ci];
        var mi = 0;
        while mi < class_info.method_len {
            var method = (*(*p).arena).class_methods[class_info.method_start + mi];
            if method.function_id == (*g).current_fn_id and class_info.field_len > 0 {
                var field = (*(*p).arena).class_fields[class_info.field_start];
                var field_ty = cg_types::resolve_type_simple(p, field.type_ref);
                if semantic::is_pointer_type(field_ty) {
                    return semantic::type_dereference(field_ty);
                }
                return field_ty;
            }
            mi = mi + 1;
        }
        ci = ci + 1;
    }
    return semantic::type_unknown();
}

fn resolve_field_type_for_codegen(p: @resolver::Project, type_ref: ast::TypeRef, declaration_span: span::Span): int {
    var field_ty = cg_types::resolve_type_simple(p, type_ref);
    if semantic::is_class_type(field_ty) {
        var class_id = field_ty - 4000;
        if class_id >= 0 and class_id < (*(*p).arena).classes.len {
            var class_info = (*(*p).arena).classes[class_id];
            if class_info.generic_param_len > 0 {
                var arg_start = -1;
                var arg_end = -1;
                var scan_start = declaration_span.start;
                if type_ref.name_span.start < scan_start or scan_start == declaration_span.end {
                    scan_start = type_ref.name_span.start;
                }
                var scan_end = declaration_span.end;
                if scan_end <= type_ref.name_span.end {
                    scan_end = type_ref.name_span.end + 128;
                    if scan_end > p.source.len {
                        scan_end = p.source.len;
                    }
                }
                var i = scan_start;
                while i < scan_end and p.source.data[i] != ';' {
                    if p.source.data[i] == '<' {
                        arg_start = i + 1;
                    } else if p.source.data[i] == '>' and arg_start >= 0 {
                        arg_end = i;
                        break;
                    }
                    i = i + 1;
                }
                if arg_start >= 0 and arg_end > arg_start {
                    var concrete_id = monomorphizer::instantiate_class(p, class_id, span::make(arg_start, arg_end));
                    if concrete_id >= 0 {
                        return 4000 + concrete_id;
                    }
                }
            }
        }
    }
    return field_ty;
}

export fn codegen_expr(g: @cg_types::Codegen, p: @resolver::Project, expr_id: int, source: @array::Array<char>): int {
    if expr_id < 0 { return -1; }
    var expr = (*(*p).arena).exprs[expr_id];

    if expr.kind == 2 {
        var int_ty = cg_types::literal_type(p, expr.span, false);
        var r = cg_types::next_temp(g);
        cg_types::emit(g, "    ");
        cg_types::push_temp(g, r);
        cg_types::emit(g, "= add ");
        cg_types::emit_type(g, int_ty, p);
        cg_types::emit(g, " 0, ");
        cg_types::emit_int_value(g, expr.int_value);
        cg_types::newline(g);
        cg_types::set_last(g, int_ty);
        return r;
    }

    if expr.kind == 3 {
        var r = cg_types::next_temp(g);
        cg_types::emit(g, "    ");
        cg_types::push_temp(g, r);
        cg_types::emit(g, "= add i1 0, ");
        cg_types::emit(g, cg_types::bool_str(expr.bool_value));
        cg_types::newline(g);
        cg_types::set_last(g, semantic::type_bool());
        return r;
    }

    if expr.kind == 12 {
        var float_ty = cg_types::literal_type(p, expr.span, true);
        var r = cg_types::next_temp(g);
        cg_types::emit(g, "    ");
        cg_types::push_temp(g, r);
        cg_types::emit(g, "= fadd ");
        cg_types::emit_type(g, float_ty, p);
        cg_types::emit(g, " 0.0, ");
        var fi = expr.span.start;
        while fi < expr.span.end {
            var ch = p.source.data[fi];
            if (ch >= '0' and ch <= '9') or ch == '.' {
                (*g).output.push(ch);
            }
            fi = fi + 1;
        }
        cg_types::newline(g);
        cg_types::set_last(g, float_ty);
        return r;
    }

    if expr.kind == 13 {
        if expr.child_len == 0 {
            var r = cg_types::next_temp(g);
            cg_types::emit(g, "    ");
            cg_types::push_temp(g, r);
            cg_types::emit(g, "= add i64 0, 0");
            cg_types::newline(g);
            cg_types::set_last(g, semantic::type_int());
            return r;
        }
        var elem_type = semantic::type_int();
        {
            var errors: array::Array<semantic::SemanticError> = array::Array();
            var summary = semantic::make_empty_summary();
            var first_child = (*(*p).arena).exprs[(*(*p).arena).expr_refs[expr.child_start]];
            if first_child.kind == 2 { elem_type = semantic::type_int(); }
            else if first_child.kind == 3 { elem_type = semantic::type_bool(); }
            else if first_child.kind == 7 { elem_type = semantic::type_char(); }
            else if first_child.kind == 12 { elem_type = semantic::type_float(); }
        }
        var arr_ptr = cg_types::next_temp(g);
        cg_types::emit_alloca(g, arr_ptr, elem_type, p);
        var i = 0;
        while i < expr.child_len {
            var elem_reg = codegen_expr(g, p, (*(*p).arena).expr_refs[expr.child_start + i], source);
            var elem_ptr = cg_types::next_temp(g);
            cg_types::emit_gep(g, elem_ptr, elem_type, p, arr_ptr, 0, i);
            if elem_type >= 1000 {
                cg_types::emit_store_typed(g, elem_reg, elem_ptr, elem_type, p);
            } else {
                cg_types::emit_store(g, elem_reg, elem_ptr, elem_type, p);
            }
            i = i + 1;
        }
        cg_types::set_last(g, elem_type);
        return arr_ptr;
    }

    if expr.kind == 14 {
        if expr.child_len == 0 {
            return -1;
        }
        var receiver_expr_id = (*(*p).arena).expr_refs[expr.child_start];
        var receiver_expr = (*(*p).arena).exprs[receiver_expr_id];
        var receiver_reg = -1;
        var receiver_ty = semantic::type_unknown();
        if receiver_expr.kind == 1 {
            var receiver_slot = cg_types::lookup_local(g, p, receiver_expr.name_span);
            receiver_ty = cg_types::lookup_local_type(g, p, receiver_expr.name_span);
            if semantic::is_pointer_type(receiver_ty) {
                receiver_reg = cg_types::next_temp(g);
                cg_types::emit_load_typed(g, receiver_reg, receiver_slot, receiver_ty, p);
            } else {
                receiver_reg = receiver_slot;
            }
        } else {
            receiver_reg = codegen_lvalue(g, p, receiver_expr_id, source);
            receiver_ty = cg_types::get_last(g);
            if receiver_reg < 0 {
                receiver_reg = codegen_expr(g, p, receiver_expr_id, source);
                receiver_ty = cg_types::get_last(g);
            }
            if receiver_expr.kind == 9 and semantic::is_pointer_type(receiver_ty) {
                var loaded_member_pointer = cg_types::next_temp(g);
                cg_types::emit_load_typed(g, loaded_member_pointer, receiver_reg, receiver_ty, p);
                receiver_reg = loaded_member_pointer;
            }
            if receiver_reg >= 0 and !semantic::is_pointer_type(receiver_ty) {
                var receiver_slot2 = cg_types::next_temp(g);
                var receiver_is_lvalue = receiver_expr.kind == 4 or receiver_expr.kind == 5 or receiver_expr.kind == 9;
                if !receiver_is_lvalue {
                    cg_types::emit_alloca_typed(g, receiver_slot2, receiver_ty, p);
                    cg_types::emit_store_typed(g, receiver_reg, receiver_slot2, receiver_ty, p);
                    receiver_reg = receiver_slot2;
                }
            }
        }
        var target_ty = receiver_ty;
        if semantic::is_pointer_type(target_ty) {
            target_ty = semantic::type_dereference(target_ty);
        }
        var method_fn_id = -1;
        var found_class_id = -1;
        if semantic::is_class_type(target_ty) {
            found_class_id = target_ty - 4000;
        }
        if cg_types::class_name_is(p, target_ty, "HashMap") {
            if cg_types::span_ends_with(p, expr.name_span, "length") {
                var map_len_ptr = cg_types::next_temp(g);
                cg_types::emit_gep(g, map_len_ptr, target_ty, p, receiver_reg, 0, 1);
                var map_len = cg_types::next_temp(g);
                cg_types::emit_load_typed(g, map_len, map_len_ptr, semantic::type_int(), p);
                cg_types::set_last(g, semantic::type_int());
                return map_len;
            }
            if expr.child_len > 1 and
               (cg_types::span_ends_with(p, expr.name_span, "get") or
                cg_types::span_ends_with(p, expr.name_span, "contains") or
                cg_types::span_ends_with(p, expr.name_span, "remove")) {
                var map_key = codegen_expr(g, p, (*(*p).arena).expr_refs[expr.child_start + 1], source);
                var map_key_ty = cg_types::get_last(g);
                var map_slot = cg_types::emit_hashmap_slot_ptr(g, p, receiver_reg, target_ty, map_key, map_key_ty);
                if cg_types::span_ends_with(p, expr.name_span, "get") {
                    cg_types::set_last(g, semantic::type_pointer(semantic::type_int(), true));
                    return map_slot;
                }
                var map_value = cg_types::next_temp(g);
                cg_types::emit_load_typed(g, map_value, map_slot, semantic::type_int(), p);
                var map_zero = cg_types::next_temp(g);
                cg_types::emit(g, "    "); cg_types::push_temp(g, map_zero); cg_types::emit(g, "= add i64 0, 0"); cg_types::newline(g);
                var map_present = cg_types::next_temp(g);
                cg_types::emit_icmp(g, map_present, "ne", semantic::type_int(), map_value, map_zero, p);
                if cg_types::span_ends_with(p, expr.name_span, "remove") {
                    cg_types::emit_store_typed(g, map_zero, map_slot, semantic::type_int(), p);
                    var remove_len_ptr = cg_types::next_temp(g);
                    cg_types::emit_gep(g, remove_len_ptr, target_ty, p, receiver_reg, 0, 1);
                    var remove_len = cg_types::next_temp(g);
                    cg_types::emit_load_typed(g, remove_len, remove_len_ptr, semantic::type_int(), p);
                    var one = cg_types::next_temp(g);
                    cg_types::emit(g, "    "); cg_types::push_temp(g, one); cg_types::emit(g, "= add i64 0, 1"); cg_types::newline(g);
                    var new_len = cg_types::next_temp(g);
                    cg_types::emit_binop(g, new_len, "sub", semantic::type_int(), remove_len, one, p);
                    cg_types::emit_store_typed(g, new_len, remove_len_ptr, semantic::type_int(), p);
                }
                cg_types::set_last(g, semantic::type_bool());
                return map_present;
            }
        }
        if found_class_id >= 0 and found_class_id < (*(*p).arena).classes.len {
            var cl = (*(*p).arena).classes[found_class_id];
            var mi = 0;
            while mi < cl.method_len {
                var cm = (*(*p).arena).class_methods[cl.method_start + mi];
                var mfunc = (*p).arena.functions[cm.function_id];
                var method_matches = semantic::name_equals(p.source.data, mfunc.name_span, expr.name_span);
                if !method_matches and cl.concrete_arg_len > 0 {
                    var requested_len = expr.name_span.end - expr.name_span.start;
                    var function_len = mfunc.name_span.end - mfunc.name_span.start;
                    if function_len > requested_len and
                       p.source.data[mfunc.name_span.start + requested_len] == '_' {
                        method_matches = true;
                        var method_char_i = 0;
                        while method_char_i < requested_len {
                            if p.source.data[mfunc.name_span.start + method_char_i] !=
                               p.source.data[expr.name_span.start + method_char_i] {
                                method_matches = false;
                                break;
                            }
                            method_char_i = method_char_i + 1;
                        }
                    }
                }
                if method_matches {
                    method_fn_id = cm.function_id;
                    break;
                }
                mi = mi + 1;
            }
        }

        if method_fn_id < 0 {
            if cg_types::span_ends_with(p, expr.name_span, "equals") and expr.child_len > 1 {
                var receiver_value = cg_types::next_temp(g);
                cg_types::emit_load_typed(g, receiver_value, receiver_reg, target_ty, p);
                var equals_arg = codegen_expr(g, p, (*(*p).arena).expr_refs[expr.child_start + 1], source);
                var equals_reg = cg_types::next_temp(g);
                if semantic::is_float_type(target_ty) {
                    cg_types::emit_fcmp(g, equals_reg, "oeq", target_ty, receiver_value, equals_arg, p);
                } else {
                    cg_types::emit_icmp(g, equals_reg, "eq", target_ty, receiver_value, equals_arg, p);
                }
                cg_types::set_last(g, semantic::type_bool());
                return equals_reg;
            }
            if cg_types::span_ends_with(p, expr.name_span, "hash") {
                var hash_value = cg_types::next_temp(g);
                cg_types::emit_load_typed(g, hash_value, receiver_reg, target_ty, p);
                if cg_types::integer_width(target_ty) < 64 {
                    var widened_hash = cg_types::next_temp(g);
                    cg_types::emit(g, "    ");
                    cg_types::push_temp(g, widened_hash);
                    cg_types::emit(g, "= zext ");
                    cg_types::emit_type(g, target_ty, p);
                    cg_types::emit(g, " ");
                    cg_types::push_reg(g, hash_value);
                    cg_types::emit(g, " to i64");
                    cg_types::newline(g);
                    hash_value = widened_hash;
                }
                cg_types::set_last(g, semantic::type_int());
                return hash_value;
            }
            if cg_types::span_ends_with(p, expr.name_span, "format") {
                var string_class_id = -1;
                var string_i = 0;
                while string_i < (*(*p).arena).classes.len {
                    var string_class = (*(*p).arena).classes[string_i];
                    if cg_types::span_ends_with(p, string_class.name_span, "String") {
                        string_class_id = string_i;
                        break;
                    }
                    string_i = string_i + 1;
                }
                if string_class_id >= 0 {
                    var empty_string_ptr = cg_types::next_temp(g);
                    cg_types::emit(g, "    ");
                    cg_types::push_temp(g, empty_string_ptr);
                    cg_types::emit(g, "= insertvalue ");
                    cg_types::emit_type(g, 4000 + string_class_id, p);
                    cg_types::emit(g, " undef, ptr null, 0");
                    cg_types::newline(g);
                    var empty_string = cg_types::next_temp(g);
                    cg_types::emit(g, "    ");
                    cg_types::push_temp(g, empty_string);
                    cg_types::emit(g, "= insertvalue ");
                    cg_types::emit_type(g, 4000 + string_class_id, p);
                    cg_types::emit(g, " ");
                    cg_types::push_reg(g, empty_string_ptr);
                    cg_types::emit(g, ", i64 0, 1");
                    cg_types::newline(g);
                    cg_types::set_last(g, 4000 + string_class_id);
                    return empty_string;
                }
            }
            return -1;
        }

        var method_info = (*p).arena.functions[method_fn_id];

        var param_regs: array::Array<int> = array::Array();
        var param_tys: array::Array<int> = array::Array();
        param_regs.push(receiver_reg);
        param_tys.push(semantic::type_pointer(target_ty, false));

        var ai = 1;
        while ai < expr.child_len {
            var arg_reg = codegen_expr(g, p, (*(*p).arena).expr_refs[expr.child_start + ai], source);
            param_regs.push(arg_reg);
            param_tys.push(cg_types::get_last(g));
            ai = ai + 1;
        }

        var ret_ty = semantic::type_void();
        if method_info.has_return_type {
            var errors: array::Array<semantic::SemanticError> = array::Array();
            var summary = semantic::make_empty_summary();
            ret_ty = semantic::resolve_type_ref(p, method_info.return_type_ref, @errors, @summary);
            if cg_types::span_ends_with(p, expr.name_span, "pop") {
                var concrete_ret_ty = concrete_class_type_arg(p, target_ty);
                if concrete_ret_ty != semantic::type_unknown() {
                    ret_ty = concrete_ret_ty;
                }
            }
        }

        var ret_reg = cg_types::next_temp(g);
        var fn_chars: array::Array<char> = array::Array();
        cg_types::append_function_symbol(@fn_chars, p, method_fn_id);
        cg_types::emit_call(g, ret_reg, fn_chars.data, fn_chars.len, ret_ty, @param_regs, @param_tys, p);
        cg_types::set_last(g, ret_ty);
        return ret_reg;
    }

    if expr.kind == 15 {
        if expr.child_len == 0 { return -1; }
        var src_reg = codegen_expr(g, p, (*(*p).arena).expr_refs[expr.child_start], source);
        var from_ty = cg_types::get_last(g);
        var to_ty = cg_types::resolve_type_simple(p, ast::make_type_ref(6, expr.name_span.start, expr.name_span.end));
        if to_ty == semantic::type_unknown() {
            to_ty = semantic::type_int();
        }
        var r = cg_types::next_temp(g);
        var cast_op = "trunc";
        var from_is_float = (from_ty == semantic::type_float() or from_ty == semantic::type_float64() or from_ty == semantic::type_float32());
        var to_is_float = (to_ty == semantic::type_float() or to_ty == semantic::type_float64() or to_ty == semantic::type_float32());
        var from_is_ptr = semantic::is_pointer_type(from_ty);
        var to_is_ptr = semantic::is_pointer_type(to_ty);

        if from_is_float and !to_is_float {
            cast_op = "fptosi";
        } else if !from_is_float and to_is_float {
            cast_op = "sitofp";
        } else if from_is_float and to_is_float {
            if from_ty == semantic::type_float32() and (to_ty == semantic::type_float64() or to_ty == semantic::type_float()) {
                cast_op = "fpext";
            } else {
                cast_op = "fptrunc";
            }
        } else if from_is_ptr and !to_is_ptr {
            cast_op = "ptrtoint";
        } else if !from_is_ptr and to_is_ptr {
            cast_op = "inttoptr";
        } else {
            cast_op = "trunc";
        }

        cg_types::emit(g, "    ");
        cg_types::push_temp(g, r);
        cg_types::emit(g, "= ");
        cg_types::emit(g, cast_op);
        cg_types::emit(g, " ");
        cg_types::emit_type(g, from_ty, p);
        cg_types::emit(g, " ");
        cg_types::push_reg(g, src_reg);
        cg_types::emit(g, " to ");
        cg_types::emit_type(g, to_ty, p);
        cg_types::newline(g);
        cg_types::set_last(g, to_ty);
        return r;
    }

    if expr.kind == 16 {
        var ty = cg_types::resolve_type_simple(p, ast::make_type_ref(6, expr.name_span.start, expr.name_span.end));
        var size = cg_types::type_size(ty, p);
        var r = cg_types::next_temp(g);
        cg_types::emit(g, "    ");
        cg_types::push_temp(g, r);
        cg_types::emit(g, "= add i64 0, ");
        cg_types::emit_int(g, size);
        cg_types::newline(g);
        cg_types::set_last(g, semantic::type_int());
        return r;
    }

    if expr.kind == 17 {
        if expr.child_len == 0 { return -1; }
        var target_reg = codegen_expr(g, p, (*(*p).arena).expr_refs[expr.child_start], source);
        var ty = cg_types::resolve_type_simple(p, ast::make_type_ref(6, expr.name_span.start, expr.name_span.end));
        cg_types::emit(g, "    call void @\"");
        {
            var errors: array::Array<semantic::SemanticError> = array::Array();
            var summary = semantic::make_empty_summary();
        }
        var ni = expr.name_span.start;
        while ni < expr.name_span.end {
            (*g).output.push(source.data[ni]);
            ni = ni + 1;
        }
        cg_types::emit(g, ".destroy\"(ptr ");

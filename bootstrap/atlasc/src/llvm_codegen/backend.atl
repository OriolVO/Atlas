            cg_types::emit_load_typed(g, loaded, elem_ptr, base_ty, p);
            cg_types::set_last(g, base_ty);
            return loaded;
        }
        if op == 55 or op == 56 or op == 53 or op == 54 {
            if cg_types::integer_width(lhs_ty) > cg_types::integer_width(rhs_ty) {
                var zr3 = cg_types::next_temp(g);
                cg_types::emit(g, "    "); cg_types::push_temp(g, zr3); cg_types::emit(g, "= zext ");
                cg_types::emit_type(g, rhs_ty, p); cg_types::emit(g, " "); cg_types::push_reg(g, rhs_reg);
                cg_types::emit(g, " to "); cg_types::emit_type(g, lhs_ty, p); cg_types::newline(g);
                rhs_reg = zr3;
                rhs_ty = lhs_ty;
            } else if cg_types::integer_width(rhs_ty) > cg_types::integer_width(lhs_ty) {
                var zl3 = cg_types::next_temp(g);
                cg_types::emit(g, "    "); cg_types::push_temp(g, zl3); cg_types::emit(g, "= zext ");
                cg_types::emit_type(g, lhs_ty, p); cg_types::emit(g, " "); cg_types::push_reg(g, lhs_reg);
                cg_types::emit(g, " to "); cg_types::emit_type(g, rhs_ty, p); cg_types::newline(g);
                lhs_reg = zl3;
                lhs_ty = rhs_ty;
            }
            var cmp = "slt";
            if op == 55 { cmp = "slt"; }
            if op == 56 { cmp = "sgt"; }
            if op == 53 { cmp = "sle"; }
            if op == 54 { cmp = "sge"; }
            var cmp_ty = cg_types::get_last(g);
            if cmp_ty == semantic::type_float() or cmp_ty == semantic::type_float64() {
                if op == 55 { cmp = "olt"; }
                if op == 56 { cmp = "ogt"; }
                if op == 53 { cmp = "ole"; }
                if op == 54 { cmp = "oge"; }

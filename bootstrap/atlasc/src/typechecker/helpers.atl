export fn find_class_by_name(p: @resolver::Project, name_span: span::Span): int {
    var mod_count = (*p).modules.len;
    var m = 0;
    while m < mod_count {
        var mod_iface = (*p).modules[m];
        var file_info = (*p).arena.file_infos[mod_iface.file_info_id];
        var i = 0;
        while i < file_info.item_len {
            var item = (*p).arena.items[file_info.item_start + i];
            if item.kind == 6 {
                var c = (*p).arena.classes[item.class_id];
                if c.name_span.start == name_span.start and c.name_span.end == name_span.end {
                    return item.class_id;
                }
            }
            i = i + 1;
        }
        m = m + 1;
    }
    return -1;
}

import ast;
import array;
import error;
import io;
import lexer;
import llvm_codegen.native;
import parser;
import span;
import resolver;
import semantic;
import token;

fn pushstr(arr: @array::Array<char>, s: []char) {
    var i = 0;
    while i < s.len {
        (*arr).push(s[i]);
        i = i + 1;
    }
}

fn build_and_run(src: @array::Array<char>): int {
    var arena = ast::make_empty_arena();
    var tokens: array::Array<token::Token> = array::Array();
    var lex_errors: array::Array<error::LexError> = array::Array();
    lexer::tokenize(src, 0, @tokens, @lex_errors);
    if lex_errors.len > 0 { return 1; }
    var file_info = ast::make_empty_file_info();
    var parse_errors: array::Array<ast::ParseError> = array::Array();
    if !parser::parse_file(@arena, tokens.data, tokens.len, @file_info, @parse_errors) { return 2; }
    var fid = arena.file_infos.len; arena.file_infos.push(file_info);
    var modules: array::Array<resolver::ModuleInterface> = array::Array();
    modules.push(resolver::ModuleInterface { name_span: span::make(0, 0), file_info_id: fid });
    var proj = resolver::Project { arena: @arena, source: src, modules: @modules };
    resolver::resolve_names(@proj, @parse_errors);
    var summary = semantic::make_empty_summary();
    var sem_errs: array::Array<semantic::SemanticError> = array::Array();
    semantic::analyze_file(@proj, file_info, @summary, @sem_errs);
    if sem_errs.len > 0 { return 3; }
    var cg = llvm_codegen.native::make_empty_codegen();
    var proj2 = resolver::Project { arena: @arena, source: src, modules: @modules };
    llvm_codegen.native::generate(@cg, @proj2);
    var ci = 0;
    while ci < cg.output.len { io::print_char(cg.output.data[ci]); ci = ci + 1; }
    return 0;
}

fn print_chars(s: []char) {
    var i = 0;
    while i < s.len {
        io::print_char(s[i]);
        i = i + 1;
    }
}

fn main(): int {
    var src1: array::Array<char> = array::Array();
    pushstr(@src1, "fn main(): int {\n    var x = 10;\n    { var x = 30; return x; }\n    return x;\n}\n");
    if build_and_run(@src1) != 0 { return 1; }

    var src2: array::Array<char> = array::Array();
    pushstr(@src2, "fn main(): int {\n    var x = -5;\n    return -x;\n}\n");
    if build_and_run(@src2) != 0 { return 2; }

    var src3: array::Array<char> = array::Array();
    pushstr(@src3, "struct Point { x: int; y: int; }\nfn main(): int {\n    var p = Point { x: 10, y: 20 };\n    return p.x + p.y;\n}\n");
    if build_and_run(@src3) != 0 { return 3; }

    var src4: array::Array<char> = array::Array();
    pushstr(@src4, "fn main(): int {\n    var x = 3.14;\n    var y = 2.71;\n    if x > y { return 1; }\n    return 0;\n}\n");
    if build_and_run(@src4) != 0 { return 4; }

    var src5: array::Array<char> = array::Array();
    pushstr(@src5, "fn main(): int {\n    var a = 5;\n    var b = 10;\n    if a < b { return 1; }\n    return 0;\n}\n");
    if build_and_run(@src5) != 0 { return 5; }

    return 0;
}

import array;
import ast;
import string;
import io;
import span;
import resolver;
import monomorphizer;
import semantic;

fn infer_struct_constructor_type(
    p: @resolver::Project,
    expr: ast::Expr,
    locals: @span::Span?,
    depths: @int?,
    local_types: @int?,
    local_count: int,
    
    
    
    
    depth: int,
    errors: @array::Array<semantic::SemanticError>,
    summary: @semantic::Summary
): int {
    var struct_index = semantic::find_struct_index(p, expr.callee_span);
    if struct_index < 0 {
        return semantic::type_unknown();
    }

    var struct_info = (*(*p).arena).structs[struct_index];
    if expr.child_len != struct_info.field_len {
        errors.push(semantic::make_error(7, expr.span.start, expr.span.end));
        (*summary).wrong_arg_count_count = (*summary).wrong_arg_count_count + 1;
    }

    var i = 0;
    while i < expr.child_len {
        var arg_type = infer_expr_type(
            p,
            (*(*p).arena).expr_refs[expr.child_start + i],
            locals,
            depths,
            local_types,
            local_count,
            
            
            
            
            depth,
            errors,
            summary
        );
        if i < struct_info.field_len {
            var field = (*(*p).arena).struct_fields[struct_info.field_start + i];
            semantic::expect_type(p, 
                semantic::resolve_type_ref(p, field.type_ref, errors, summary),
                arg_type,
                8,
                expr.span,
                errors,
                summary
            );
        }
        i = i + 1;
    }

    return 1000 + struct_index;
}

fn infer_struct_literal_type(
    p: @resolver::Project,
    expr: ast::Expr,
    locals: @span::Span?,
    depths: @int?,
    local_types: @int?,
    local_count: int,
    
    
    
    
    depth: int,
    errors: @array::Array<semantic::SemanticError>,
    summary: @semantic::Summary
): int {
    var struct_index = semantic::find_struct_index(p, expr.callee_span);
    if struct_index < 0 {
        errors.push(semantic::make_error(10, expr.callee_span.start, expr.callee_span.end));
        (*summary).unknown_type_count = (*summary).unknown_type_count + 1;
        return semantic::type_unknown();
    }

    var struct_id = struct_index;
    var struct_info = (*(*p).arena).structs[struct_id];

    var i = 0;
    while i < expr.child_len {
        var field_name = (*(*p).arena).name_refs[expr.name_ref_start + i];
        var prev = 0;
        while prev < i {
            if semantic::name_equals(p.source.data, (*(*p).arena).name_refs[expr.name_ref_start + prev], field_name) {
                errors.push(semantic::make_error(15, field_name.start, field_name.end));
                (*summary).duplicate_field_init_count = (*summary).duplicate_field_init_count + 1;
            }
            prev = prev + 1;
        }
        var value_type = infer_expr_type(
            p,
            (*(*p).arena).expr_refs[expr.child_start + i],
            locals,
            depths,
            local_types,
            local_count,
            
            
            
            
            depth,
            errors,
            summary
        );
        var field_index = semantic::find_struct_field_index(p, struct_id, field_name);
        if field_index < 0 {
            errors.push(semantic::make_error(12, field_name.start, field_name.end));
            (*summary).unknown_field_count = (*summary).unknown_field_count + 1;
        } else {
            var field = (*(*p).arena).struct_fields[struct_info.field_start + field_index];
            var expected_type = semantic::resolve_type_ref(p, field.type_ref, errors, summary);
            semantic::expect_type(p, expected_type, value_type, 8, field_name, errors, summary);
        }
        i = i + 1;
    }

    i = 0;
    while i < struct_info.field_len {
        var expected_name = (*(*p).arena).struct_fields[struct_info.field_start + i].name_span;
        var seen = false;
        var provided = 0;
        while provided < expr.child_len {
            if semantic::name_equals(p.source.data, (*(*p).arena).name_refs[expr.name_ref_start + provided], expected_name) {
                seen = true;
            }
            provided = provided + 1;
        }
        if !seen {
            errors.push(semantic::make_error(14, expected_name.start, expected_name.end));
            (*summary).missing_field_count = (*summary).missing_field_count + 1;
        }
        i = i + 1;
    }

    return 1000 + struct_index;
}

fn infer_qualified_choice_call(
    p: @resolver::Project,
    expr: ast::Expr,
    locals: @span::Span?,
    depths: @int?,
    local_types: @int?,
    local_count: int,
    depth: int,
    errors: @array::Array<semantic::SemanticError>,
    summary: @semantic::Summary
): int {
    var callee = expr.callee_span;
    var src = p.source.data;
    var start = callee.start;
    var end = callee.end;
    var sep = start;
    while sep < end - 1 {
        if src[sep] == ':' and src[sep + 1] == ':' {
            break;
        }
        sep = sep + 1;
    }
    if sep >= end - 1 {
        return semantic::type_unknown();
    }
    var type_name_span = span::make(start, sep);
    var variant_name_span = span::make(sep + 2, end);
    var choice_idx = semantic::find_choice_index(p, type_name_span);
    if choice_idx < 0 {
        return semantic::type_unknown();
    }
    choice_idx = concrete_choice_index(p, choice_idx);
    var variant_idx = semantic::find_choice_variant_index(p, choice_idx, variant_name_span);
    if variant_idx < 0 {
        errors.push(semantic::make_error(16, variant_name_span.start, variant_name_span.end));
        (*summary).unknown_field_count = (*summary).unknown_field_count + 1;
        return 3000 + choice_idx;
    }
    var choice_info = (*(*p).arena).choices[choice_idx];
    var variant = (*(*p).arena).choice_variants[choice_info.variant_start + variant_idx];
    if variant.has_payload {
        if expr.child_len != 1 {
            errors.push(semantic::make_error(7, expr.span.start, expr.span.end));
            (*summary).wrong_arg_count_count = (*summary).wrong_arg_count_count + 1;
        } else {
            var payload_type = infer_expr_type(p, (*(*p).arena).expr_refs[expr.child_start], locals, depths, local_types, local_count, depth, errors, summary);
            semantic::expect_type(p, semantic::resolve_type_ref(p, variant.payload_type_ref, errors, summary), payload_type, 8, expr.span, errors, summary);
        }
    } else if expr.child_len != 0 {
        errors.push(semantic::make_error(7, expr.span.start, expr.span.end));
        (*summary).wrong_arg_count_count = (*summary).wrong_arg_count_count + 1;
    }
    return 3000 + choice_idx;
}

fn concrete_choice_index(p: @resolver::Project, choice_idx: int): int {
    if choice_idx < 0 or choice_idx >= (*(*p).arena).choices.len {
        return choice_idx;
    }
    var generic = (*(*p).arena).choices[choice_idx];
    var src = p.source.data;
    var generic_len = generic.name_span.end - generic.name_span.start;
    var i = (*(*p).arena).choices.len - 1;
    while i >= 0 {
        var candidate = (*(*p).arena).choices[i];
        var candidate_len = candidate.name_span.end - candidate.name_span.start;
        if candidate_len > generic_len {
            var matches = true;
            var j = 0;
            while j < generic_len {
                if src[candidate.name_span.start + j] != src[generic.name_span.start + j] {
                    matches = false;
                }
                j = j + 1;
            }
            if matches and src[candidate.name_span.start + generic_len] == '_' {
                return i;
            }
        }
        i = i - 1;
    }
    return choice_idx;
}

fn concrete_class_index(p: @resolver::Project, class_idx: int): int {
    if class_idx < 0 or class_idx >= (*(*p).arena).classes.len {
        return class_idx;
    }
    var generic = (*(*p).arena).classes[class_idx];
    if generic.concrete_arg_len > 0 {
        return class_idx;
    }
    var src = p.source.data;
    var generic_len = generic.name_span.end - generic.name_span.start;
    var i = (*(*p).arena).classes.len - 1;
    while i >= 0 {
        var candidate = (*(*p).arena).classes[i];
        var candidate_len = candidate.name_span.end - candidate.name_span.start;
        if candidate_len > generic_len {
            var matches = true;
            var j = 0;
            while j < generic_len {
                if src[candidate.name_span.start + j] != src[generic.name_span.start + j] {
                    matches = false;
                }
                j = j + 1;
            }
            if matches and src[candidate.name_span.start + generic_len] == '_' {
                return i;
            }
        }
        i = i - 1;
    }
    return class_idx;
}

fn class_name_starts_with(p: @resolver::Project, class_type: int, name: []char): bool {
    if !semantic::is_class_type(class_type) {
        return false;
    }
    var class_idx = class_type - 4000;
    if class_idx < 0 or class_idx >= (*(*p).arena).classes.len {
        return false;
    }
    var class_name = (*(*p).arena).classes[class_idx].name_span;
    if class_name.end - class_name.start < name.len {
        return false;
    }
    var i = 0;
    while i < name.len {
        if p.source.data[class_name.start + i] != name[i] {
            return false;
        }
        i = i + 1;
    }
    return true;
}

fn find_nullable_refined_local(
    p: @resolver::Project,
    cond_expr_id: int,
    locals: @span::Span?,
    depths: @int?,
    local_types: @int?,
    local_count: int,
    depth: int
): int {
    if cond_expr_id < 0 {
        return -1;
    }
    var cond = (*(*p).arena).exprs[cond_expr_id];
    if cond.kind != 5 {
        return -1;
    }
    if cond.op_kind != 51 and cond.op_kind != 52 {
        return -1;
    }
    if cond.child_len < 2 {
        return -1;
    }
    var lhs_id = (*(*p).arena).expr_refs[cond.child_start];
    var rhs_id = (*(*p).arena).expr_refs[cond.child_start + 1];
    var lhs = (*(*p).arena).exprs[lhs_id];
    var rhs = (*(*p).arena).exprs[rhs_id];
    var var_span = span::make(0, 0);
    var has_var = false;
    var rhs_is_null = false;
    var lhs_is_null = false;
    var src = p.source.data;
    if rhs.kind == 1 and rhs.name_span.end - rhs.name_span.start == 4 {
        if src[rhs.name_span.start] == 'n' and src[rhs.name_span.start + 1] == 'u' and src[rhs.name_span.start + 2] == 'l' and src[rhs.name_span.start + 3] == 'l' {
            rhs_is_null = true;
        }
    }
    if lhs.kind == 1 and lhs.name_span.end - lhs.name_span.start == 4 {
        if src[lhs.name_span.start] == 'n' and src[lhs.name_span.start + 1] == 'u' and src[lhs.name_span.start + 2] == 'l' and src[lhs.name_span.start + 3] == 'l' {
            lhs_is_null = true;
        }
    }
    if rhs_is_null and lhs.kind == 1 {
        var_span = lhs.name_span;
        has_var = true;
    } else if lhs_is_null and rhs.kind == 1 {
        var_span = rhs.name_span;
        has_var = true;
    }
    if !has_var {
        return -1;
    }
    var idx = semantic::find_visible_name_index(p.source.data, locals, depths, local_count, var_span, depth);
    if idx < 0 {
        return -1;
    }
    if !semantic::is_nullable_pointer(local_types[idx]) {
        return -1;
    }
    return idx;
}

fn resolve_index_read_method_type(p: @resolver::Project, class_id: int, errors: @array::Array<semantic::SemanticError>, summary: @semantic::Summary): int {
    var class_info = (*(*p).arena).classes[class_id];
    if class_info.concrete_arg_len > 0 and class_info.concrete_arg_start >= 0 and class_info.concrete_arg_start < (*(*p).arena).concrete_type_args.len {
        return (*(*p).arena).concrete_type_args[class_info.concrete_arg_start];
    }
    class_id = concrete_class_index(p, class_id);
    class_info = (*(*p).arena).classes[class_id];
    if class_info.concrete_arg_len > 0 and class_info.concrete_arg_start >= 0 and class_info.concrete_arg_start < (*(*p).arena).concrete_type_args.len {
        return (*(*p).arena).concrete_type_args[class_info.concrete_arg_start];
    }
    var direct_name_len = class_info.name_span.end - class_info.name_span.start;
    var direct_source = p.source.data;
    var class_suffix_start = class_info.name_span.start;
    var class_name_i = class_info.name_span.start;
    while class_name_i < class_info.name_span.end {
        if direct_source[class_name_i] == '_' {
            class_suffix_start = class_name_i + 1;
            break;
        }
        class_name_i = class_name_i + 1;
    }
    if direct_name_len >= 5 {
        var direct_suffix = class_info.name_span.end - 4;
        if direct_source[direct_suffix] == 'c' and direct_source[direct_suffix + 1] == 'h' and direct_source[direct_suffix + 2] == 'a' and direct_source[direct_suffix + 3] == 'r' {
            return semantic::type_char();
        }
    }
    var m = 0;
    while m < class_info.method_len {
        var method = (*(*p).arena).class_methods[class_info.method_start + m];
        var method_info = (*(*p).arena).functions[method.function_id];
        var m_name = method_info.name_span;
        var src = p.source.data;
        if m_name.end - m_name.start >= 10 {
            if src[m_name.start] == 'o' and src[m_name.start+1] == 'p' and src[m_name.start+2] == 'e' and src[m_name.start+3] == 'r' and src[m_name.start+4] == 'a' and src[m_name.start+5] == 't' and src[m_name.start+6] == 'o' and src[m_name.start+7] == 'r' and src[m_name.start+8] == '[' and src[m_name.start+9] == ']' {
                if m_name.end - m_name.start == 10 or src[m_name.start + 10] == '_' {
                    if method_info.has_return_type {
                    return semantic::resolve_type_ref(p, method_info.return_type_ref, errors, summary);
                    }
                }
            }
        }
        m = m + 1;
    }
    var fi = (*(*p).arena).functions.len - 1;
    while fi >= 0 {
        var function_info = (*(*p).arena).functions[fi];
        var function_name = function_info.name_span;
        var function_name_len = function_name.end - function_name.start;
        var source = p.source.data;
        if function_name_len >= 10 and function_info.param_len > 0 {
            if source[function_name.start] == 'o' and source[function_name.start+1] == 'p' and source[function_name.start+2] == 'e' and source[function_name.start+3] == 'r' and source[function_name.start+4] == 'a' and source[function_name.start+5] == 't' and source[function_name.start+6] == 'o' and source[function_name.start+7] == 'r' and source[function_name.start+8] == '[' and source[function_name.start+9] == ']' {
                if function_name_len > 11 and source[function_name.start + 10] == '_' and class_suffix_start > class_info.name_span.start {
                    var function_suffix_start = function_name.start + 11;
                    var class_suffix_len = class_info.name_span.end - class_suffix_start;
                    if function_name.end - function_suffix_start == class_suffix_len {
                        var suffix_matches = true;
                        var suffix_i = 0;
                        while suffix_i < class_suffix_len {
                            if source[function_suffix_start + suffix_i] != source[class_suffix_start + suffix_i] {
                                suffix_matches = false;
                            }
                            suffix_i = suffix_i + 1;
                        }
                        if suffix_matches and function_info.has_return_type {
                            return semantic::resolve_type_ref(p, function_info.return_type_ref, errors, summary);
                        }
                    }
                }
                var self_param = (*(*p).arena).params[function_info.param_start];
                var self_type = semantic::resolve_type_ref(p, self_param.type_ref, errors, summary);
                if semantic::is_pointer_type(self_type) {
                    self_type = semantic::type_dereference(self_type);
                }
                if self_type == 4000 + class_id and function_info.has_return_type {
                    return semantic::resolve_type_ref(p, function_info.return_type_ref, errors, summary);
                }
            }
        }
        fi = fi - 1;
    }
    var class_name = class_info.name_span;
    var underscore = class_name.start;
    var class_source = p.source.data;
    while underscore < class_name.end and class_source[underscore] != '_' {
        underscore = underscore + 1;
    }
    if underscore < class_name.end - 1 {
        var element_name = span::make(underscore + 1, class_name.end);
        var element_name_len = element_name.end - element_name.start;
        if element_name_len == 4 and class_source[element_name.start] == 'c' and class_source[element_name.start + 1] == 'h' and class_source[element_name.start + 2] == 'a' and class_source[element_name.start + 3] == 'r' {
            return semantic::type_char();
        }
        var numeric_element_type = semantic::resolve_numeric_alias(p, element_name);
        if numeric_element_type != semantic::type_unknown() {
            return numeric_element_type;
        }
        var element_type = semantic::resolve_type_ref_from_name(p, element_name);
        if element_type != semantic::type_unknown() {
            return element_type;
        }
    }
    var field_index = 0;
    while field_index < class_info.field_len {
        var field = (*(*p).arena).class_fields[class_info.field_start + field_index];
        if semantic::span_equals_text(p, field.name_span, "data") {
            var data_type = semantic::resolve_type_ref(p, field.type_ref, errors, summary);
            if semantic::is_pointer_type(data_type) {
                return semantic::type_dereference(data_type);
            }
        }
        field_index = field_index + 1;
    }
    return semantic::type_unknown();
}

fn find_static_class_method(p: @resolver::Project, candidate: span::Span): int {
    var method_name = semantic::last_path_segment_name(p.source, candidate);
    if method_name.start == candidate.start or method_name.start < candidate.start + 2 {
        return -1;
    }
    var class_path = span::make(candidate.start, method_name.start - 2);
    var class_id = semantic::find_class_index(p, class_path);
    if class_id < 0 or class_id >= (*(*p).arena).classes.len {
        return -1;
    }
    var class_info = (*(*p).arena).classes[class_id];
    var i = 0;
    while i < class_info.method_len {
        var method = (*(*p).arena).class_methods[class_info.method_start + i];
        var function_info = (*(*p).arena).functions[method.function_id];
        if semantic::name_equals(p.source.data, function_info.name_span, method_name) {
            return method.function_id;
        }
        i = i + 1;
    }
    return -1;
}

export fn infer_expr_type(
    p: @resolver::Project,
    expr_id: int,
    locals: @span::Span?,
    depths: @int?,
    local_types: @int?,
    local_count: int,
    
    
    
    
    depth: int,
    errors: @array::Array<semantic::SemanticError>,
    summary: @semantic::Summary
): int {
    if expr_id < 0 {
        return semantic::type_unknown();
    }

    var expr = (*(*p).arena).exprs[expr_id];
    if expr.kind == 1 {
        var null_span = span::make(0, 0);
        var null_name = span::make(expr.name_span.start, expr.name_span.end);
        if expr.name_span.end > expr.name_span.start {
            var null_len = 4;
            if expr.name_span.end - expr.name_span.start == null_len {
                var nn = p.source.data;
                if nn[expr.name_span.start] == 'n' and nn[expr.name_span.start + 1] == 'u' and nn[expr.name_span.start + 2] == 'l' and nn[expr.name_span.start + 3] == 'l' {
                    return semantic::type_null();
                }
            }
        }
        var local_index = semantic::find_visible_name_index(p.source.data, locals, depths, local_count, expr.name_span, depth);
        if local_index < 0 {
            errors.push(semantic::make_error(4, expr.name_span.start, expr.name_span.end));
            (*summary).unknown_variable_count = (*summary).unknown_variable_count + 1;
            return semantic::type_unknown();
        }
        if local_types == null {
            return semantic::type_unknown();
        }
        return local_types[local_index];
    }

    if expr.kind == 2 {
        var s = p.source.data;
        var end = expr.span.end;
        var start = expr.span.start;
        var si = start;
        while si < end {
            var ch = s[si];
            if ch >= '0' and ch <= '9' { si = si + 1; continue; }
            break;
        }
        if si == end { return semantic::type_untyped_int(); }
        var suffix_name = span::make(si, end);
        return semantic::resolve_numeric_alias(p, suffix_name);
    }

    if expr.kind == 3 {
        return semantic::type_bool();
    }

    if expr.kind == 7 {
        return semantic::type_char();
    }

    if expr.kind == 8 {
        return semantic::type_string_literal();
    }

    if expr.kind == 12 {
        var s = p.source.data;
        var end = expr.span.end;
        var start = expr.span.start;
        var si = start;
        while si < end {
            var ch = s[si];
            if (ch >= '0' and ch <= '9') or ch == '.' { si = si + 1; continue; }
            break;
        }
        if si == end { return semantic::type_float(); }
        var suffix_name = span::make(si, end);
        return semantic::resolve_numeric_alias(p, suffix_name);
    }

    if expr.kind == 13 {
        var elem_type = semantic::type_unknown();
        var i = 0;
        while i < expr.child_len {
            var child_type = infer_expr_type(p, (*(*p).arena).expr_refs[expr.child_start + i], locals, depths, local_types, local_count, depth, errors, summary);
            if elem_type == semantic::type_unknown() {
                elem_type = child_type;
            } else if child_type != semantic::type_unknown() and !semantic::compatible_type(elem_type, child_type) {
                errors.push(semantic::make_error(8, expr.span.start, expr.span.end));
                (*summary).type_mismatch_count = (*summary).type_mismatch_count + 1;
            }
            i = i + 1;
        }
        if elem_type == semantic::type_unknown() {
            return semantic::type_int();
        }
        return elem_type;
    }

    if expr.kind == 14 {
        if expr.child_len < 1 {
            return semantic::type_unknown();
        }
        var receiver_type = infer_expr_type(p, (*(*p).arena).expr_refs[expr.child_start], locals, depths, local_types, local_count, depth, errors, summary);
        var arg_count = expr.child_len - 1;

        var target_type = receiver_type;
        if semantic::is_pointer_type(receiver_type) {
            if semantic::is_nullable_pointer(receiver_type) {
                errors.push(semantic::make_error(17, expr.span.start, expr.span.end));
                (*summary).type_mismatch_count = (*summary).type_mismatch_count + 1;
                target_type = semantic::type_dereference(receiver_type);
            } else {
                target_type = semantic::type_dereference(receiver_type);
            }
        }

        if target_type >= 4000 {
            if semantic::span_equals_text(p, expr.name_span, "destroy") {
                errors.push(semantic::make_error(8, expr.span.start, expr.span.end));
                (*summary).type_mismatch_count = (*summary).type_mismatch_count + 1;
            }
            var class_idx = target_type - 4000;
            if class_idx < (*(*p).arena).classes.len {
                var class_info = (*(*p).arena).classes[class_idx];

                    }
                }
            }
            errors.push(semantic::make_error(8, expr.span.start, expr.span.end));
            (*summary).type_mismatch_count = (*summary).type_mismatch_count + 1;
            return semantic::type_unknown();
        }
        if expr.op_kind == 74 {
            var lhs_is_class = semantic::is_class_type(lhs_type);
            if semantic::is_pointer_type(lhs_type) and semantic::is_class_type(semantic::type_dereference(lhs_type)) {
                lhs_is_class = true;
            }
            if !lhs_is_class {
                if !semantic::is_integer_type(rhs_type) and rhs_type != semantic::type_untyped_int() and rhs_type != semantic::type_unknown() {
                    errors.push(semantic::make_error(8, expr.span.start, expr.span.end));
                    (*summary).type_mismatch_count = (*summary).type_mismatch_count + 1;
                }
            }
            if semantic::is_class_type(lhs_type) {
                var class_idx = lhs_type - 4000;
                var method_return_type = resolve_index_read_method_type(p, class_idx, errors, summary);
                if method_return_type == semantic::type_unknown() {
                    errors.push(semantic::make_error(13, expr.span.start, expr.span.end));
                    (*summary).unknown_field_count = (*summary).unknown_field_count + 1;
                }
                return method_return_type;
            }
            if semantic::is_pointer_type(lhs_type) {
                var pointee_type = semantic::type_dereference(lhs_type);
                if semantic::is_class_type(pointee_type) {
                    var class_idx = pointee_type - 4000;
                    var method_return_type = resolve_index_read_method_type(p, class_idx, errors, summary);
                    if method_return_type == semantic::type_unknown() {
                        errors.push(semantic::make_error(13, expr.span.start, expr.span.end));
                        (*summary).unknown_field_count = (*summary).unknown_field_count + 1;
                    }
                    return method_return_type;
                }
                return pointee_type;
            }
            return semantic::type_unknown();
        }
        if expr.op_kind == 58 or expr.op_kind == 27 {
            if is_unary {
                semantic::expect_type(p, semantic::type_bool(), lhs_type, 9, expr.span, errors, summary);
                return semantic::type_bool();
            }
        }
        return semantic::type_unknown();
    }

    if expr.kind == 6 {
        var class_idx = -1;
        if expr.resolved_def_id >= 0 and expr.resolved_def_id < (*(*p).arena).items.len {
            var resolved_item = (*(*p).arena).items[expr.resolved_def_id];
            if resolved_item.kind == 6 {
                class_idx = resolved_item.class_id;
            }
        }
        if class_idx < 0 {
            class_idx = semantic::find_class_index(p, expr.callee_span);
        }
        if class_idx >= 0 {
            return 4000 + class_idx;
        }

        var fn_index = -1;
        if expr.resolved_def_id >= 0 and expr.resolved_def_id < (*(*p).arena).items.len {
            var resolved_item = (*(*p).arena).items[expr.resolved_def_id];
            if resolved_item.kind == 1 {
                fn_index = resolved_item.function_id;
            }
        }
        if fn_index < 0 {
            fn_index = semantic::find_function_index(p, expr.callee_span);
        }
        if fn_index < 0 {
            fn_index = find_static_class_method(p, expr.callee_span);
        }
        var i = 0;
        if fn_index < 0  {
            var ctor_type = infer_struct_constructor_type(
                p,
                expr,
                locals,
                depths,
                local_types,
                local_count,
                
                
                
                
                depth,
                errors,
                summary
            );
            if ctor_type != semantic::type_unknown() {
                return ctor_type;
            }
            var qualified_choice_type = infer_qualified_choice_call(p, expr, locals, depths, local_types, local_count, depth, errors, summary);
            if qualified_choice_type != semantic::type_unknown() {
                return qualified_choice_type;
            }
            errors.push(semantic::make_error(5, expr.callee_span.start, expr.callee_span.end));
            (*summary).unknown_function_count = (*summary).unknown_function_count + 1;
            while i < expr.child_len {
                infer_expr_type(p, (*(*p).arena).expr_refs[expr.child_start + i], locals, depths, local_types, local_count,     depth, errors, summary);
                i = i + 1;
            }
            return semantic::type_unknown();
        }

        var function_info = (*(*p).arena).functions[fn_index];
        var is_generic = function_info.generic_param_len > 0;

        if is_generic {
            if expr.child_len > 0 and function_info.param_len > 0 {
                var arg_type = infer_expr_type(p, (*(*p).arena).expr_refs[expr.child_start], locals, depths, local_types, local_count, depth, errors, summary);
                if arg_type != semantic::type_unknown() {
                    (*(*p).arena).exprs[expr_id].resolved_def_id = fn_index;
                    var ai2 = 0;
                    while ai2 < expr.child_len {
                        infer_expr_type(p, (*(*p).arena).expr_refs[expr.child_start + ai2], locals, depths, local_types, local_count, depth, errors, summary);
                        ai2 = ai2 + 1;
                    }
                    if function_info.has_return_type {
                        return semantic::resolve_type_ref(p, function_info.return_type_ref, errors, summary);
                    }
                    return semantic::type_unknown();
                }
            }
            while i < expr.child_len {
                infer_expr_type(p, (*(*p).arena).expr_refs[expr.child_start + i], locals, depths, local_types, local_count, depth, errors, summary);
                i = i + 1;
            }
            if function_info.has_return_type {
                return semantic::resolve_type_ref(p, function_info.return_type_ref, errors, summary);
            }
            return semantic::type_unknown();
        }

        if !function_info.is_variadic and expr.child_len != function_info.param_len {
            errors.push(semantic::make_error(7, expr.span.start, expr.span.end));
            (*summary).wrong_arg_count_count = (*summary).wrong_arg_count_count + 1;
        }

        while i < expr.child_len {
            var arg_type = infer_expr_type(p, (*(*p).arena).expr_refs[expr.child_start + i], locals, depths, local_types, local_count,     depth, errors, summary);
            if i < function_info.param_len {
                var param = (*(*p).arena).params[function_info.param_start + i];
                if param.has_type_hint {
                    semantic::expect_type(p, semantic::resolve_type_ref(p, param.type_ref, errors, summary), arg_type, 8, expr.span, errors, summary);
                }
            }
            i = i + 1;
        }

        if function_info.has_return_type {
            return semantic::resolve_type_ref(p, function_info.return_type_ref, errors, summary);
        }
        return semantic::type_unknown();
    }

    return semantic::type_unknown();
}

fn analyze_match_stmt(
    p: @resolver::Project,
    match_stmt: ast::MatchStmt,
    locals: @array::Array<span::Span>,
    local_depths: @array::Array<int>,
    local_types: @array::Array<int>,
    
    
    
    
    depth: int,
    has_return_type: bool,
    return_type_kind: int,
    in_loop: bool,
    errors: @array::Array<semantic::SemanticError>,
    summary: @semantic::Summary
) {
    var target_type = infer_expr_type(p, match_stmt.value_expr_id, locals.data, local_depths.data, local_types.data, locals.len,     depth, errors, summary);
    var arm_depth = depth + 1;
    var i = 0;
    while i < match_stmt.arm_len {
        var arm = (*(*p).arena).match_arms[match_stmt.arm_start + i];
        var arm_type_ref = ast::make_type_ref(6, arm.type_span.start, arm.type_span.end);
        var arm_type = semantic::resolve_type_ref(p, arm_type_ref, errors, summary);
        if target_type >= 3000 and arm_type >= 3000 {
            var target_choice_idx = target_type - 3000;
            var arm_choice_idx = arm_type - 3000;
            if concrete_choice_index(p, arm_choice_idx) == target_choice_idx {
                arm_type = target_type;
            }
        }
        semantic::expect_type(p, target_type, arm_type, 8, arm.type_span, errors, summary);

        var before_locals = (*locals).len;
        var before_depths = (*local_depths).len;
        var before_types = (*local_types).len;

        if arm_type >= 2000 and arm_type < 3000  {
            var enum_index = arm_type - 2000;
            if enum_index >= 0 and enum_index < (*(*p).arena).enums.len {
                if semantic::find_enum_variant_index(p, enum_index, arm.variant_span) < 0 {
                    errors.push(semantic::make_error(16, arm.variant_span.start, arm.variant_span.end));
                    (*summary).unknown_field_count = (*summary).unknown_field_count + 1;
                }
                if arm.has_binding {
                    errors.push(semantic::make_error(7, arm.binding_span.start, arm.binding_span.end));
                    (*summary).wrong_arg_count_count = (*summary).wrong_arg_count_count + 1;
                }
            }
        } else if arm_type >= 3000  {
            var choice_index = arm_type - 3000;
            if choice_index >= 0 and choice_index < (*(*p).arena).choices.len {
                var variant_index = semantic::find_choice_variant_index(p, choice_index, arm.variant_span);
                if variant_index < 0 {
                    errors.push(semantic::make_error(16, arm.variant_span.start, arm.variant_span.end));
                    (*summary).unknown_field_count = (*summary).unknown_field_count + 1;
                } else {
                    var choice_info = (*(*p).arena).choices[choice_index];
                    var variant = (*(*p).arena).choice_variants[choice_info.variant_start + variant_index];
                    if variant.has_payload {
                        if arm.has_binding {
                            var binding_type = semantic::resolve_type_ref(p, variant.payload_type_ref, errors, summary);
                            semantic::record_name(locals, local_depths, local_types, arm.binding_span, arm_depth, binding_type);
                        }
                    } else if arm.has_binding {
                        errors.push(semantic::make_error(7, arm.binding_span.start, arm.binding_span.end));
                        (*summary).wrong_arg_count_count = (*summary).wrong_arg_count_count + 1;
                    }
                }
            }
        }

        analyze_block(p, arm.block_id, locals, local_depths, local_types,     arm_depth, has_return_type, return_type_kind, in_loop, errors, summary);

        (*locals).len = before_locals;
        (*local_depths).len = before_depths;
        (*local_types).len = before_types;
        i = i + 1;
    }

    if target_type >= 2000 and target_type < 3000 {
        var enum_index = target_type - 2000;
        if enum_index >= 0 and enum_index < (*(*p).arena).enums.len {
            var enum_info = (*(*p).arena).enums[enum_index];
            var v = 0;
            while v < enum_info.variant_len {
                var variant = (*(*p).arena).enum_variants[enum_info.variant_start + v];
                var covered = false;
                var a = 0;
                while a < match_stmt.arm_len {
                    var arm = (*(*p).arena).match_arms[match_stmt.arm_start + a];
                    if semantic::name_equals(p.source.data, arm.variant_span, variant.name_span) {
                        covered = true;
                    }
                    a = a + 1;
                }
                if !covered {
                    errors.push(semantic::make_error(16, variant.name_span.start, variant.name_span.end));
                    (*summary).unknown_field_count = (*summary).unknown_field_count + 1;
                }
                v = v + 1;
            }
        }
    } else if target_type >= 3000 {
        var choice_index = target_type - 3000;
        if choice_index >= 0 and choice_index < (*(*p).arena).choices.len {
            var choice_info = (*(*p).arena).choices[choice_index];
            var v = 0;
            while v < choice_info.variant_len {
                var variant = (*(*p).arena).choice_variants[choice_info.variant_start + v];
                var covered = false;
                var a = 0;
                while a < match_stmt.arm_len {
                    var arm = (*(*p).arena).match_arms[match_stmt.arm_start + a];
                    if semantic::name_equals(p.source.data, arm.variant_span, variant.name_span) {
                        covered = true;
                    }
                    a = a + 1;
                }
                if !covered {
                    errors.push(semantic::make_error(16, variant.name_span.start, variant.name_span.end));
                    (*summary).unknown_field_count = (*summary).unknown_field_count + 1;
                }
                v = v + 1;
            }
        }
    }
}

fn analyze_block(
    p: @resolver::Project,
    block_id: int,
    locals: @array::Array<span::Span>,
    local_depths: @array::Array<int>,
    local_types: @array::Array<int>,
    
    
    
    
    depth: int,
    has_return_type: bool,
    return_type_kind: int,
    in_loop: bool,
    errors: @array::Array<semantic::SemanticError>,
    summary: @semantic::Summary
) {
    if block_id < 0 {
        return;
    }

    var saved_local_count = (*locals).len;
    var saved_depth_count = (*local_depths).len;
    var saved_type_count = (*local_types).len;
    var block = (*(*p).arena).blocks[block_id];
    var i = 0;
    while i < block.stmt_ref_len {
        var stmt = (*(*p).arena).stmts[(*(*p).arena).stmt_refs[block.stmt_ref_start + i]];
        if stmt.kind == 1 {
            if semantic::find_name_index_in_scope(p.source.data, locals.data, local_depths.data, locals.len, stmt.var_decl.name_span, depth) >= 0 {
                errors.push(semantic::make_error(2, stmt.var_decl.name_span.start, stmt.var_decl.name_span.end));
                (*summary).duplicate_local_count = (*summary).duplicate_local_count + 1;
            } else {
                var local_type = semantic::type_unknown();
                if stmt.var_decl.has_init {
                    local_type = infer_expr_type(p, stmt.var_decl.init_expr_id, locals.data, local_depths.data, local_types.data, locals.len,     depth, errors, summary);
                    if semantic::is_class_type(local_type) {
                        var init_expr = (*(*p).arena).exprs[stmt.var_decl.init_expr_id];
                        if init_expr.kind == 1 {
                            errors.push(semantic::make_error(8, stmt.var_decl.span.start, stmt.var_decl.span.end));
                            (*summary).type_mismatch_count = (*summary).type_mismatch_count + 1;
                        }
                    }
                }
                if stmt.var_decl.has_type_hint {
                    if stmt.var_decl.has_init {
                        var hinted_type = semantic::resolve_type_ref(p, stmt.var_decl.type_ref, errors, summary);
                        if hinted_type >= 3000 and hinted_type < 4000 {
                            hinted_type = 3000 + concrete_choice_index(p, hinted_type - 3000);
                        }
                        var init_matches_hinted_class = false;
                        if semantic::is_class_type(hinted_type) {
                            var hinted_class_id = hinted_type - 4000;
                            if hinted_class_id >= 0 and hinted_class_id < (*(*p).arena).classes.len {
                                var hinted_class = (*(*p).arena).classes[hinted_class_id];
                                if hinted_class.generic_base_id >= 0 {
                                    hinted_class_id = hinted_class.generic_base_id;
                                }
                            }
                            var init_expr = (*(*p).arena).exprs[stmt.var_decl.init_expr_id];
                            if init_expr.kind == 6 or init_expr.kind == 20 {
                                var init_class_id = -1;
                                if init_expr.resolved_def_id >= 0 and init_expr.resolved_def_id < (*(*p).arena).items.len {
                                    var resolved_item = (*(*p).arena).items[init_expr.resolved_def_id];
                                    if resolved_item.kind == 6 {
                                        init_class_id = resolved_item.class_id;
                                    }
                                }
                                if init_class_id < 0 {
                                    init_class_id = semantic::find_class_index(p, init_expr.callee_span);
                                }
                                if init_class_id >= 0 and init_class_id < (*(*p).arena).classes.len {
                                    var init_class = (*(*p).arena).classes[init_class_id];
                                    if init_class.generic_base_id >= 0 {
                                        init_class_id = init_class.generic_base_id;
                                    }
                                }
                                if init_class_id == hinted_class_id {
                                    init_matches_hinted_class = true;
                                }
                            }
                        }
                        if init_matches_hinted_class {
                            local_type = hinted_type;
                        } else if semantic::is_class_type(hinted_type) and semantic::is_class_type(local_type) {
                            local_type = hinted_type;
                        }
                        semantic::expect_type(p, hinted_type, local_type, 8, stmt.var_decl.span, errors, summary);
                    }
                    local_type = semantic::resolve_type_ref(p, stmt.var_decl.type_ref, errors, summary);
                }
                if local_type == semantic::type_untyped_int() {
                    local_type = semantic::type_int();
                }
                semantic::record_name(locals, local_depths, local_types, stmt.var_decl.name_span, depth, local_type);
            }
        } else if stmt.kind == 2 {
            if semantic::find_name_index_in_scope(p.source.data, locals.data, local_depths.data, locals.len, stmt.const_decl.name_span, depth) >= 0 {
                errors.push(semantic::make_error(2, stmt.const_decl.name_span.start, stmt.const_decl.name_span.end));
                (*summary).duplicate_local_count = (*summary).duplicate_local_count + 1;
            } else {
                var const_type = infer_expr_type(p, stmt.const_decl.init_expr_id, locals.data, local_depths.data, local_types.data, locals.len,     depth, errors, summary);
                if stmt.const_decl.has_type_hint {
                    semantic::expect_type(p, semantic::resolve_type_ref(p, stmt.const_decl.type_ref, errors, summary), const_type, 8, stmt.const_decl.span, errors, summary);
                    const_type = semantic::resolve_type_ref(p, stmt.const_decl.type_ref, errors, summary);
                }
                if const_type == semantic::type_untyped_int() {
                    const_type = semantic::type_int();
                }
                semantic::record_name(locals, local_depths, local_types, stmt.const_decl.name_span, depth, const_type);
            }
        } else if stmt.kind == 3 {
            var value_type = infer_expr_type(p, stmt.assign_stmt.value_expr_id, locals.data, local_depths.data, local_types.data, locals.len, depth, errors, summary);
            var target_expr = (*(*p).arena).exprs[stmt.assign_stmt.target_expr_id];
            var handled_index_setter = false;
            if target_expr.kind == 5 and target_expr.op_kind == 74 and target_expr.child_len >= 2 {
                var base_type = infer_expr_type(p, (*(*p).arena).expr_refs[target_expr.child_start], locals.data, local_depths.data, local_types.data, locals.len, depth, errors, summary);
                if class_name_starts_with(p, base_type, "HashMap") or class_name_starts_with(p, base_type, "hashmap.HashMap") {
                    infer_expr_type(p, (*(*p).arena).expr_refs[target_expr.child_start + 1], locals.data, local_depths.data, local_types.data, locals.len, depth, errors, summary);
                    semantic::expect_type(p, semantic::type_int(), value_type, 8, stmt.assign_stmt.span, errors, summary);
                    handled_index_setter = true;
                }
            }
            if !handled_index_setter {
                var target_type = infer_expr_type(p, stmt.assign_stmt.target_expr_id, locals.data, local_depths.data, local_types.data, locals.len, depth, errors, summary);
                semantic::expect_type(p, target_type, value_type, 8, stmt.assign_stmt.span, errors, summary);
            }
        } else if stmt.kind == 4 {
            analyze_block(p, stmt.block_id, locals, local_depths, local_types,     depth + 1, has_return_type, return_type_kind, in_loop, errors, summary);
        } else if stmt.kind == 5 {
            var if_type = infer_expr_type(p, stmt.if_stmt.condition_expr_id, locals.data, local_depths.data, local_types.data, locals.len,     depth, errors, summary);
            if !semantic::compatible_type(semantic::type_bool(), if_type) {
                errors.push(semantic::make_error(9, stmt.if_stmt.span.start, stmt.if_stmt.span.end));
                (*summary).bad_condition_count = (*summary).bad_condition_count + 1;
            }
            var refined_local_idx = find_nullable_refined_local(p, stmt.if_stmt.condition_expr_id, locals.data, local_depths.data, local_types.data, locals.len, depth);
            var original_type = semantic::type_unknown();
            if refined_local_idx >= 0 {
                original_type = (*local_types)[refined_local_idx];
                (*local_types)[refined_local_idx] = semantic::type_pointer(semantic::type_dereference(original_type), false);
            }
            analyze_block(p, stmt.if_stmt.then_block_id, locals, local_depths, local_types,     depth + 1, has_return_type, return_type_kind, in_loop, errors, summary);
            if refined_local_idx >= 0 {
                (*local_types)[refined_local_idx] = original_type;
            }
            if stmt.if_stmt.has_else_block {
                analyze_block(p, stmt.if_stmt.else_block_id, locals, local_depths, local_types,     depth + 1, has_return_type, return_type_kind, in_loop, errors, summary);
            }
        } else if stmt.kind == 6 {
            var while_type = infer_expr_type(p, stmt.while_stmt.condition_expr_id, locals.data, local_depths.data, local_types.data, locals.len,     depth, errors, summary);
            if !semantic::compatible_type(semantic::type_bool(), while_type) {
                errors.push(semantic::make_error(9, stmt.while_stmt.span.start, stmt.while_stmt.span.end));
                (*summary).bad_condition_count = (*summary).bad_condition_count + 1;
            }
            analyze_block(p, stmt.while_stmt.body_block_id, locals, local_depths, local_types,     depth + 1, has_return_type, return_type_kind, true, errors, summary);
        } else if stmt.kind == 7 {
            if !in_loop {
                errors.push(semantic::make_error(18, stmt.span.start, stmt.span.end));
                (*summary).type_mismatch_count = (*summary).type_mismatch_count + 1;
            }
        } else if stmt.kind == 8 {
            if !in_loop {
                errors.push(semantic::make_error(19, stmt.span.start, stmt.span.end));
                (*summary).type_mismatch_count = (*summary).type_mismatch_count + 1;
            }
        } else if stmt.kind == 11 {
            analyze_match_stmt(p, stmt.match_stmt, locals, local_depths, local_types,     depth, has_return_type, return_type_kind, in_loop, errors, summary);
        } else if stmt.kind == 9 {
            if stmt.return_stmt.has_value {
                var return_type = infer_expr_type(p, stmt.return_stmt.value_expr_id, locals.data, local_depths.data, local_types.data, locals.len,     depth, errors, summary);
                if !has_return_type {
                    errors.push(semantic::make_error(6, stmt.return_stmt.span.start, stmt.return_stmt.span.end));
                    (*summary).bad_return_count = (*summary).bad_return_count + 1;
                } else if !semantic::compatible_type(return_type_kind, return_type) {
                    errors.push(semantic::make_error(6, stmt.return_stmt.span.start, stmt.return_stmt.span.end));
                    (*summary).bad_return_count = (*summary).bad_return_count + 1;
                }
            } else if has_return_type {
                errors.push(semantic::make_error(6, stmt.return_stmt.span.start, stmt.return_stmt.span.end));
                (*summary).bad_return_count = (*summary).bad_return_count + 1;
            }
        } else if stmt.kind == 10 {
            infer_expr_type(p, stmt.expr_id, locals.data, local_depths.data, local_types.data, locals.len,     depth, errors, summary);
        }
        i = i + 1;
    }
    (*locals).len = saved_local_count;
    (*local_depths).len = saved_depth_count;
    (*local_types).len = saved_type_count;
}

export fn analyze_file(p: @resolver::Project, file_info: ast::FileInfo, summary: @semantic::Summary, errors: @array::Array<semantic::SemanticError>) {
    (*summary) = semantic::make_empty_summary();

    var fn_names: array::Array<span::Span> = array::Array();
    var fn_ids: array::Array<int> = array::Array();
    var struct_names: array::Array<span::Span> = array::Array();
    var struct_ids: array::Array<int> = array::Array();
    var enum_names: array::Array<span::Span> = array::Array();
    var enum_ids: array::Array<int> = array::Array();
    var choice_names: array::Array<span::Span> = array::Array();
    var choice_ids: array::Array<int> = array::Array();
    var class_names: array::Array<span::Span> = array::Array();
    var class_ids: array::Array<int> = array::Array();

    var i = 0;
    while i < file_info.item_len {
        var item = (*(*p).arena).items[file_info.item_start + i];
        if item.kind == 1 {
            (*summary).function_count = (*summary).function_count + 1;
            var function_info = (*(*p).arena).functions[item.function_id];
            if semantic::find_name_index(p.source.data, fn_names.data, fn_names.len, function_info.name_span) >= 0 {
                errors.push(semantic::make_error(1, function_info.name_span.start, function_info.name_span.end));
                (*summary).duplicate_function_count = (*summary).duplicate_function_count + 1;
            } else {
                fn_names.push(function_info.name_span);
                fn_ids.push(item.function_id);
            }
        } else if item.kind == 2 {
            (*summary).struct_count = (*summary).struct_count + 1;
            var struct_info = (*(*p).arena).structs[item.struct_id];
            if semantic::find_name_index(p.source.data, struct_names.data, struct_names.len, struct_info.name_span) >= 0 {
                errors.push(semantic::make_error(11, struct_info.name_span.start, struct_info.name_span.end));
                (*summary).duplicate_type_count = (*summary).duplicate_type_count + 1;
            } else {
                struct_names.push(struct_info.name_span);
                struct_ids.push(item.struct_id);
            }
        } else if item.kind == 3 {
            (*summary).enum_count = (*summary).enum_count + 1;
            var enum_info = (*(*p).arena).enums[item.enum_id];
            if semantic::find_name_index(p.source.data, enum_names.data, enum_names.len, enum_info.name_span) >= 0 {
                errors.push(semantic::make_error(11, enum_info.name_span.start, enum_info.name_span.end));
                (*summary).duplicate_type_count = (*summary).duplicate_type_count + 1;
            } else {
                enum_names.push(enum_info.name_span);
                enum_ids.push(item.enum_id);
            }
        } else if item.kind == 4 {
            (*summary).choice_count = (*summary).choice_count + 1;
            var choice_info = (*(*p).arena).choices[item.choice_id];
            if semantic::find_name_index(p.source.data, choice_names.data, choice_names.len, choice_info.name_span) >= 0 {
                errors.push(semantic::make_error(11, choice_info.name_span.start, choice_info.name_span.end));
                (*summary).duplicate_type_count = (*summary).duplicate_type_count + 1;
            } else {
                choice_names.push(choice_info.name_span);
                choice_ids.push(item.choice_id);
            }
        } else if item.kind == 6 {
            var class_info = (*(*p).arena).classes[item.class_id];
            if semantic::find_name_index(p.source.data, class_names.data, class_names.len, class_info.name_span) >= 0 {
                errors.push(semantic::make_error(11, class_info.name_span.start, class_info.name_span.end));
                (*summary).duplicate_type_count = (*summary).duplicate_type_count + 1;
            } else {
                class_names.push(class_info.name_span);
                class_ids.push(item.class_id);
            }
        }
        i = i + 1;
    }

    i = 0;
    while i < struct_ids.len {
        var struct_info = (*(*p).arena).structs[struct_ids[i]];
        if struct_info.generic_param_len > 0 {
            i = i + 1;
            continue;
        }
        var f = 0;
        while f < struct_info.field_len {
            var field = (*(*p).arena).struct_fields[struct_info.field_start + f];
            var field_type = semantic::resolve_type_ref(p, field.type_ref, errors, summary);
            if field_type == 1000 + struct_ids[i] {
                errors.push(semantic::make_error(8, field.name_span.start, field.name_span.end));
                (*summary).type_mismatch_count = (*summary).type_mismatch_count + 1;
            }
            f = f + 1;
        }
        i = i + 1;
    }

    i = 0;
    while i < choice_ids.len {
        i = i + 1;
    }

    i = 0;
    while i < file_info.item_len {
        var item = (*(*p).arena).items[file_info.item_start + i];
        if item.kind == 1 {
            var function_info = (*(*p).arena).functions[item.function_id];

            if function_info.has_return_type {
                semantic::resolve_type_ref(p, function_info.return_type_ref, errors, summary);
            }
            var validate_param_i = 0;
            while validate_param_i < function_info.param_len {
                var param = (*(*p).arena).params[function_info.param_start + validate_param_i];
                if param.has_type_hint {
                    semantic::resolve_type_ref(p, param.type_ref, errors, summary);
                }
                validate_param_i = validate_param_i + 1;
            }

            if function_info.generic_param_len > 0 {
                i = i + 1;
                continue;
            }
            var locals: array::Array<span::Span> = array::Array();
            var local_depths: array::Array<int> = array::Array();
            var local_types: array::Array<int> = array::Array();
            var param_i = 0;
            while param_i < function_info.param_len {
                var param = (*(*p).arena).params[function_info.param_start + param_i];
                if semantic::find_name_index(p.source.data, locals.data, locals.len, param.name_span) >= 0 {
                    errors.push(semantic::make_error(3, param.name_span.start, param.name_span.end));
                    (*summary).duplicate_param_count = (*summary).duplicate_param_count + 1;
                } else {
                    var param_type = semantic::type_unknown();
                    if param.has_type_hint {
                        param_type = semantic::resolve_type_ref(p, param.type_ref, errors, summary);
                    }
                    semantic::record_name(@locals, @local_depths, @local_types, param.name_span, 1, param_type);
                }
                param_i = param_i + 1;
            }
            analyze_block(
                p,
                function_info.body_block_id,
                @locals,
                @local_depths,
                @local_types,
                
                
                
                
                1,
                function_info.has_return_type,
                semantic::resolve_type_ref(p, function_info.return_type_ref, errors, summary),
                false,
                errors,
                summary
            );
        } else if item.kind == 6 {
            var class_info = (*(*p).arena).classes[item.class_id];
            if class_info.generic_param_len > 0 {
                i = i + 1;
                continue;
            }
            var f = 0;
            while f < class_info.field_len {
                var field = (*(*p).arena).class_fields[class_info.field_start + f];
                semantic::resolve_type_ref(p, field.type_ref, errors, summary);
                f = f + 1;
            }
            var m = 0;
            while m < class_info.method_len {
                var method = (*(*p).arena).class_methods[class_info.method_start + m];
                var method_info = (*(*p).arena).functions[method.function_id];
                if class_info.generic_param_len > 0 or method_info.generic_param_len > 0 {
                    m = m + 1;
                    continue;
                }
                var is_operator_index = false;
                var name_len = method_info.name_span.end - method_info.name_span.start;
                if name_len >= 10 {
                    var name_data = p.source.data;
                    var ns = method_info.name_span.start;
                    if name_data[ns+name_len-2] == '[' and name_data[ns+name_len-1] == ']' { is_operator_index = true; }
                }
                if is_operator_index {
                    var explicit_params = method_info.param_len;
                    if explicit_params > 0 {
                        var first_param = (*(*p).arena).params[method_info.param_start];
                        var fn_len = first_param.name_span.end - first_param.name_span.start;
                        var src_data = p.source.data;
                        var fps = first_param.name_span.start;
                        if fn_len == 4 and src_data[fps] == 's' and src_data[fps+1] == 'e' and src_data[fps+2] == 'l' and src_data[fps+3] == 'f' {
                            explicit_params = explicit_params - 1;
                        }
                    }
                    if explicit_params != 1 {
                        errors.push(semantic::make_error(8, method_info.name_span.start, method_info.name_span.end));
                        (*summary).type_mismatch_count = (*summary).type_mismatch_count + 1;
                    }
                }
                var locals: array::Array<span::Span> = array::Array();
                var local_depths: array::Array<int> = array::Array();
                var local_types: array::Array<int> = array::Array();
                var param_i = 0;
                while param_i < method_info.param_len {
                    var param = (*(*p).arena).params[method_info.param_start + param_i];
                    if semantic::find_name_index(p.source.data, locals.data, locals.len, param.name_span) >= 0 {
                        errors.push(semantic::make_error(3, param.name_span.start, param.name_span.end));
                        (*summary).duplicate_param_count = (*summary).duplicate_param_count + 1;
                    } else {
                        var param_type = semantic::type_unknown();
                        if param.has_type_hint {
                            param_type = semantic::resolve_type_ref(p, param.type_ref, errors, summary);
                        } else {
                            var sspan = param.name_span;
                            if sspan.end - sspan.start == 4 {
                                var src = p.source.data;
                                if src[sspan.start] == 's' and src[sspan.start+1] == 'e' and src[sspan.start+2] == 'l' and src[sspan.start+3] == 'f' {
                                    param_type = semantic::type_pointer(4000 + item.class_id, false);
                                }
                            }
                        }
                        semantic::record_name(@locals, @local_depths, @local_types, param.name_span, 1, param_type);
                    }
                    param_i = param_i + 1;
                }
                analyze_block(
                    p,
                    method_info.body_block_id,
                    @locals,
                    @local_depths,
                    @local_types,
                    
                    
                    
                    
                    1,
                    method_info.has_return_type,
                    semantic::resolve_type_ref(p, method_info.return_type_ref, errors, summary),
                    false,
                    errors,
                    summary
                );
                m = m + 1;
            }
        }
        i = i + 1;
    }
}

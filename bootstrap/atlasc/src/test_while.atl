import ast;
import array;
import error;
import io;
import lexer;
import llvm_codegen.native;
import parser;
import span;
import resolver;
import semantic;
import token;

fn main(): int {
    var arena = ast::make_empty_arena();
    var src_arr: array::Array<char> = array::Array();
    src_arr.push('f');
    src_arr.push('n');
    src_arr.push(' ');
    src_arr.push('m');
    src_arr.push('a');
    src_arr.push('i');
    src_arr.push('n');
    src_arr.push('(');
    src_arr.push(')');
    src_arr.push(':');
    src_arr.push(' ');
    src_arr.push('i');
    src_arr.push('n');
    src_arr.push('t');
    src_arr.push(' ');
    src_arr.push('{');
    src_arr.push(' ');
    src_arr.push('v');
    src_arr.push('a');
    src_arr.push('r');
    src_arr.push(' ');
    src_arr.push('s');
    src_arr.push('u');
    src_arr.push('m');
    src_arr.push(' ');
    src_arr.push('=');
    src_arr.push(' ');
    src_arr.push('0');
    src_arr.push(';');
    src_arr.push(' ');
    src_arr.push('v');
    src_arr.push('a');
    src_arr.push('r');
    src_arr.push(' ');
    src_arr.push('i');
    src_arr.push(' ');
    src_arr.push('=');
    src_arr.push(' ');
    src_arr.push('1');
    src_arr.push(';');
    src_arr.push(' ');
    src_arr.push('w');
    src_arr.push('h');
    src_arr.push('i');
    src_arr.push('l');
    src_arr.push('e');
    src_arr.push(' ');
    src_arr.push('i');
    src_arr.push(' ');
    src_arr.push('<');
    src_arr.push('=');
    src_arr.push(' ');
    src_arr.push('1');
    src_arr.push('0');
    src_arr.push(' ');
    src_arr.push('{');
    src_arr.push(' ');
    src_arr.push('s');
    src_arr.push('u');
    src_arr.push('m');
    src_arr.push(' ');
    src_arr.push('=');
    src_arr.push(' ');
    src_arr.push('s');
    src_arr.push('u');
    src_arr.push('m');
    src_arr.push(' ');
    src_arr.push('+');
    src_arr.push(' ');
    src_arr.push('i');
    src_arr.push(';');
    src_arr.push(' ');
    src_arr.push('i');
    src_arr.push(' ');
    src_arr.push('=');
    src_arr.push(' ');
    src_arr.push('i');
    src_arr.push(' ');
    src_arr.push('+');
    src_arr.push(' ');
    src_arr.push('1');
    src_arr.push(';');
    src_arr.push(' ');
    src_arr.push('}');
    src_arr.push(' ');
    src_arr.push('r');
    src_arr.push('e');
    src_arr.push('t');
    src_arr.push('u');
    src_arr.push('r');
    src_arr.push('n');
    src_arr.push(' ');
    src_arr.push('s');
    src_arr.push('u');
    src_arr.push('m');
    src_arr.push(';');
    src_arr.push(' ');
    src_arr.push('}');
    var tokens: array::Array<token::Token> = array::Array();
    var lex_errors: array::Array<error::LexError> = array::Array();
    lexer::tokenize(@src_arr, 0, @tokens, @lex_errors);
    if lex_errors.len > 0 { return 1; }
    var file_info = ast::make_empty_file_info();
    var parse_errors: array::Array<ast::ParseError> = array::Array();
    if !parser::parse_file(@arena, tokens.data, tokens.len, @file_info, @parse_errors) { return 2; }
    var fid = arena.file_infos.len;
    arena.file_infos.push(file_info);
    var modules: array::Array<resolver::ModuleInterface> = array::Array();
    modules.push(resolver::ModuleInterface { name_span: span::make(0, 0), file_info_id: fid });
    var proj = resolver::Project { arena: @arena, source: @src_arr, modules: @modules };
    resolver::resolve_names(@proj, @parse_errors);
    var summary = semantic::make_empty_summary();
    var sem_errs: array::Array<semantic::SemanticError> = array::Array();
    semantic::analyze_file(@proj, file_info, @summary, @sem_errs);
    if sem_errs.len > 0 { return 3; }
    var cg = llvm_codegen.native::make_empty_codegen();
    var proj2 = resolver::Project { arena: @arena, source: @src_arr, modules: @modules };
    llvm_codegen.native::generate(@cg, @proj2);
    var ci = 0;
    while ci < cg.output.len { io::print_char(cg.output.data[ci]); ci = ci + 1; }
    return 0;
}

import resolver;
import ast;
import array;
import string;
import io;
import fs;
import lexer;
import error;
import token;
import parser;
import span;

fn print_range(source: []char, start: int, end: int) {
    var i = start;
    while i < end {
        io::print_char(source[i]);
        i = i + 1;
    }
}

fn print_chars(chars: []char) {
    var i = 0;
    while i < chars.len {
        io::print_char(chars[i]);
        i = i + 1;
    }
}

fn get_item_name_span(arena: @ast::Arena, item: ast::Item): span::Span {
    if item.kind == 1 { return (*arena).functions[item.function_id].name_span; }
    if item.kind == 2 { return (*arena).structs[item.struct_id].name_span; }
    if item.kind == 3 { return (*arena).enums[item.enum_id].name_span; }
    if item.kind == 4 { return (*arena).choices[item.choice_id].name_span; }
    if item.kind == 6 { return (*arena).classes[item.class_id].name_span; }
    if item.kind == 5 { return (*arena).imports[item.import_id].name_span; }
    return span::make(0, 0);
}

fn main(): int {
    var source: array::Array<char> = array::Array();
    if !fs::read_file("stdlib/string.atl", @source) {
        print_chars("read_fail\n");
        return 1;
    }
    var tokens: array::Array<token::Token> = array::Array();
    var lex_errors: array::Array<error::LexError> = array::Array();
    lexer::tokenize(@source, 0, @tokens, @lex_errors);
    
    var arena = ast::make_empty_arena();
    var parse_errors: array::Array<ast::ParseError> = array::Array();
    var file_info = ast::make_empty_file_info();
    parser::parse_file(@arena, tokens.data, tokens.len, @file_info, @parse_errors);
    
    var i = file_info.item_start;
    while i < file_info.item_start + file_info.item_len {
        var item = (arena).items[i];
        if item.kind == 5 {
            var name_span = get_item_name_span(@arena, item);
            print_chars("import name='");
            print_range("", name_span.start, name_span.end);
            print_chars("'\n");
        }
        i = i + 1;
    }
    
    return 0;
}

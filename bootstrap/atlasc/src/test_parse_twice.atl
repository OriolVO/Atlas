import resolver;
import ast;
import array;
import string;
import io;
import lexer;
import error;
import token;
import parser;

fn print_chars(chars: []char) {
    var i = 0;
    while i < chars.len {
        io::print_char(chars[i]);
        i = i + 1;
    }
}

fn main(): int {
    var source: array::Array<char> = array::Array();
    var s = "var a = 10; var b = 32;";
    var si = 0;
    while si < s.len {
        source.push(s[si]);
        si = si + 1;
    }
    var tokens: array::Array<token::Token> = array::Array();
    var lex_errors: array::Array<error::LexError> = array::Array();
    lexer::tokenize(@source, 0, @tokens, @lex_errors);
    
    var arena = ast::make_empty_arena();
    var parse_errors: array::Array<ast::ParseError> = array::Array();
    var index = 0;
    
    var stmt1 = -1;
    var ok1 = parser::parse_first_stmt(@arena, tokens.data, tokens.len, @index, @stmt1, @parse_errors);
    print_chars("stmt1 ok=");
    io::print(ok1);
    print_chars(" index=");
    io::print(index);
    print_chars(" stmts=");
    io::print((arena).stmts.len);
    print_chars("\n");
    
    var stmt2 = -1;
    var ok2 = parser::parse_first_stmt(@arena, tokens.data, tokens.len, @index, @stmt2, @parse_errors);
    print_chars("stmt2 ok=");
    io::print(ok2);
    print_chars(" index=");
    io::print(index);
    print_chars(" stmts=");
    io::print((arena).stmts.len);
    print_chars("\n");
    
    return 0;
}

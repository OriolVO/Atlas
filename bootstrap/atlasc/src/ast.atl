export fn make_empty_stmt(): Stmt {
    return Stmt {
        kind: 0,
        var_decl: make_empty_var_decl(),
        const_decl: make_empty_const_decl(),
        assign_stmt: make_empty_assign_stmt(),
        expr_id: -1,
        block_id: -1,
        if_stmt: make_empty_if_stmt(),
        while_stmt: make_empty_while_stmt(),
        match_stmt: make_empty_match_stmt(),
        return_stmt: make_empty_return_stmt(),
        span: span::make(0, 0)
    };
}

export fn make_var_stmt(var_decl: VarDecl): Stmt {
    var stmt = make_empty_stmt();
    stmt.kind = 1;
    stmt.var_decl = var_decl;
    stmt.span = var_decl.span;
    return stmt;
}

export fn make_const_stmt(const_decl: ConstDecl): Stmt {
    var stmt = make_empty_stmt();
    stmt.kind = 2;
    stmt.const_decl = const_decl;
    stmt.span = const_decl.span;
    return stmt;
}

export fn make_assign_only_stmt(assign_stmt: AssignStmt): Stmt {
    var stmt = make_empty_stmt();
    stmt.kind = 3;
    stmt.assign_stmt = assign_stmt;
    stmt.span = assign_stmt.span;
    return stmt;
}

export fn make_block_stmt(block_id: int, block_span: span::Span): Stmt {
    var stmt = make_empty_stmt();
    stmt.kind = 4;
    stmt.block_id = block_id;
    stmt.span = block_span;
    return stmt;
}

export fn make_if_only_stmt(if_stmt: IfStmt): Stmt {
    var stmt = make_empty_stmt();
    stmt.kind = 5;
    stmt.if_stmt = if_stmt;
    stmt.span = if_stmt.span;
    return stmt;
}

export fn make_while_only_stmt(while_stmt: WhileStmt): Stmt {
    var stmt = make_empty_stmt();
    stmt.kind = 6;
    stmt.while_stmt = while_stmt;
    stmt.span = while_stmt.span;
    return stmt;
}

export fn make_match_only_stmt(match_stmt: MatchStmt): Stmt {
    var stmt = make_empty_stmt();
    stmt.kind = 11;
    stmt.match_stmt = match_stmt;
    stmt.span = match_stmt.span;
    return stmt;
}

export fn make_break_stmt(start: int, end: int): Stmt {
    var stmt = make_empty_stmt();
    stmt.kind = 7;
    stmt.span = span::make(start, end);
    return stmt;
}

export fn make_continue_stmt(start: int, end: int): Stmt {
    var stmt = make_empty_stmt();
    stmt.kind = 8;
    stmt.span = span::make(start, end);
    return stmt;
}

export fn make_return_only_stmt(return_stmt: ReturnStmt): Stmt {
    var stmt = make_empty_stmt();
    stmt.kind = 9;
    stmt.return_stmt = return_stmt;
    stmt.span = return_stmt.span;
    return stmt;

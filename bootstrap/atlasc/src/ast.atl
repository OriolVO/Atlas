export fn make_empty_item(): Item {
    return Item {
        is_export: false,
        kind: 0,
        function_id: -1,
        struct_id: -1,
        class_id: -1,
        enum_id: -1,
        choice_id: -1,
        import_id: -1,
        span: span::make(0, 0)
    };
}


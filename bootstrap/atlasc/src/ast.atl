export fn push_generic_param(arena: @Arena, param: GenericParam): int {
    var id = (*arena).generic_params.len;
    (*arena).generic_params.push(param);
    return id;
}

export fn push_constraint_signature(arena: @Arena, sig: ConstraintSignature): int {
    var id = (*arena).constraint_signatures.len;
    (*arena).constraint_signatures.push(sig);
    return id;
}

export fn push_where_clause(arena: @Arena, clause: WhereClause): int {
    var id = (*arena).where_clauses.len;
    (*arena).where_clauses.push(clause);
    return id;
}

export fn push_class_field(arena: @Arena, field: ClassField): int {
    var id = (*arena).class_fields.len;
    (*arena).class_fields.push(field);
    return id;
}

export fn push_class_method(arena: @Arena, method: ClassMethod): int {
    var id = (*arena).class_methods.len;
    (*arena).class_methods.push(method);
    return id;
}

export fn push_class_struct(arena: @Arena, struct_info: ClassStruct): int {
    var id = (*arena).class_structs.len;
    (*arena).class_structs.push(struct_info);
    return id;
}

export fn push_class(arena: @Arena, class_info: ClassInfo): int {
    var id = (*arena).classes.len;
    (*arena).classes.push(class_info);
    return id;
}

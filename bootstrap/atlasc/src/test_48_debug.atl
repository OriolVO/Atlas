import ast;
import array;
import error;
import io;
import lexer;
import parser;
import resolver;
import span;
import token;

fn pushstr(arr: @array::Array<char>, s: []char) {
    var i = 0;
    while i < s.len {
        (*arr).push(s[i]);
        i = i + 1;
    }
}

fn main(): int {
    var src: array::Array<char> = array::Array();
    pushstr(@src, "i");
    pushstr(@src, "m");
    pushstr(@src, "p");
    pushstr(@src, "o");
    pushstr(@src, "r");
    pushstr(@src, "t");
    pushstr(@src, " ");
    pushstr(@src, "s");
    pushstr(@src, "t");
    pushstr(@src, "r");
    pushstr(@src, "i");
    pushstr(@src, "n");
    pushstr(@src, "g");
    pushstr(@src, ";");
    pushstr(@src, " ");
    pushstr(@src, "f");
    pushstr(@src, "n");
    pushstr(@src, " ");
    pushstr(@src, "m");
    pushstr(@src, "a");
    pushstr(@src, "i");
    pushstr(@src, "n");
    pushstr(@src, "(");
    pushstr(@src, ")");
    pushstr(@src, ":");
    pushstr(@src, " ");
    pushstr(@src, "i");
    pushstr(@src, "n");
    pushstr(@src, "t");
    pushstr(@src, " ");
    pushstr(@src, "{");
    pushstr(@src, " ");
    pushstr(@src, "v");
    pushstr(@src, "a");
    pushstr(@src, "r");
    pushstr(@src, " ");
    pushstr(@src, "s");
    pushstr(@src, ":");
    pushstr(@src, " ");
    pushstr(@src, "s");
    pushstr(@src, "t");
    pushstr(@src, "r");
    pushstr(@src, "i");
    pushstr(@src, "n");
    pushstr(@src, "g");
    pushstr(@src, ":");
    pushstr(@src, ":");
    pushstr(@src, "S");
    pushstr(@src, "t");
    pushstr(@src, "r");
    pushstr(@src, "i");
    pushstr(@src, "n");
    pushstr(@src, "g");
    pushstr(@src, " ");
    pushstr(@src, "=");
    pushstr(@src, " ");
    pushstr(@src, "\"");
    pushstr(@src, "H");
    pushstr(@src, "i");
    pushstr(@src, "\"");
    pushstr(@src, ";");
    pushstr(@src, " ");
    pushstr(@src, "s");
    pushstr(@src, ".");
    pushstr(@src, "l");
    pushstr(@src, "e");
    pushstr(@src, "n");
    pushstr(@src, "g");
    pushstr(@src, "t");
    pushstr(@src, "h");
    pushstr(@src, "(");
    pushstr(@src, ")");
    pushstr(@src, ";");
    pushstr(@src, " ");
    pushstr(@src, "r");
    pushstr(@src, "e");
    pushstr(@src, "t");
    pushstr(@src, "u");
    pushstr(@src, "r");
    pushstr(@src, "n");
    pushstr(@src, " ");
    pushstr(@src, "0");
    pushstr(@src, ";");
    pushstr(@src, " ");
    pushstr(@src, "}");

    var tokens: array::Array<token::Token> = array::Array();
    var lex_errors: array::Array<error::LexError> = array::Array();
    lexer::tokenize(@src, 0, @tokens, @lex_errors);
    if lex_errors.len > 0 { return 101; }
    
    var arena = ast::make_empty_arena();
    var file_info = ast::make_empty_file_info();
    var parse_errors: array::Array<ast::ParseError> = array::Array();
    if !parser::parse_file(@arena, tokens.data, tokens.len, @file_info, @parse_errors) { return 102; }
    
    var fid = arena.file_infos.len; arena.file_infos.push(file_info);
    var modules: array::Array<resolver::ModuleInterface> = array::Array();
    modules.push(resolver::ModuleInterface { name_span: span::make(0, 0), file_info_id: fid, import_module_indices: array::Array() });
    var proj = resolver::Project { arena: @arena, source: @src, modules: @modules, prelude_count: 0 };
    resolver::resolve_names(@proj, @parse_errors);
    return 0;
}

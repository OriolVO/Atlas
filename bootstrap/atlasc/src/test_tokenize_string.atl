import lexer;
import array;
import error;
import token;
import io;
import fs;

fn print_chars(chars: []char) {
    var i = 0;
    while i < chars.len {
        io::print_char(chars[i]);
        i = i + 1;
    }
}

fn main(): int {
    var source: array::Array<char> = array::Array();
    if !fs::read_file("stdlib/string.atl", @source) {
        return 1;
    }
    var tokens: array::Array<token::Token> = array::Array();
    var lex_errors: array::Array<error::LexError> = array::Array();
    lexer::tokenize(@source, 0, @tokens, @lex_errors);
    
    var i = 0;
    while i < 5 {
        var tok = tokens[i];
        print_chars("kind=");
        io::print(tok.kind);
        print_chars(" at=");
        io::print(tok.span.start);
        print_chars(":");
        io::print(tok.span.end);
        print_chars("\n");
        i = i + 1;
    }
    
    return 0;
}

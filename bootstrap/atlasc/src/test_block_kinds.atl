import resolver;
import ast;
import array;
import string;
import io;
import lexer;
import error;
import token;
import parser;

fn print_chars(chars: []char) {
    var i = 0;
    while i < chars.len {
        io::print_char(chars[i]);
        i = i + 1;
    }
}

fn main(): int {
    var source: array::Array<char> = array::Array();
    var s = "fn main(): int { var a = 10; var b = 32; return a + b; }";
    var si = 0;
    while si < s.len {
        source.push(s[si]);
        si = si + 1;
    }
    var tokens: array::Array<token::Token> = array::Array();
    var lex_errors: array::Array<error::LexError> = array::Array();
    lexer::tokenize(@source, 0, @tokens, @lex_errors);
    var arena = ast::make_empty_arena();
    var parse_errors: array::Array<ast::ParseError> = array::Array();
    var file_info = ast::make_empty_file_info();
    parser::parse_file(@arena, tokens.data, tokens.len, @file_info, @parse_errors);
    
    var item = (arena).items[0];
    var fn_info = (arena).functions[item.function_id];
    var block = (arena).blocks[fn_info.body_block_id];
    
    print_chars("token count=");
    io::print(tokens.len);
    print_chars("\nblock stmts=");
    io::print(block.stmt_ref_len);
    print_chars("\n");
    
    var i = 0;
    while i < block.stmt_ref_len {
        var stmt_id = (arena).stmt_refs[block.stmt_ref_start + i];
        var stmt = (arena).stmts[stmt_id];
        print_chars("  stmt kind=");
        io::print(stmt.kind);
        if stmt.kind == 1 {
            print_chars(" name='");
            var si2 = stmt.var_decl.name_span.start;
            var ei2 = stmt.var_decl.name_span.end;
            while si2 < ei2 { io::print_char(source.data[si2]); si2 = si2 + 1; }
            print_chars("'");
        }
        print_chars("\n");
        i = i + 1;
    }
    return 0;
}

class Vec2 {
    public x: int;
    public y: int;

    public fn init(self: @Vec2, x: int, y: int) {
        (*self).x = x;
        (*self).y = y;
    }

    public fn operator+(self: @Vec2, other: @Vec2): Vec2 {
        var res = Vec2((*self).x + (*other).x, (*self).y + (*other).y);
        return res;
    }
}

fn main(): int {
    var a = Vec2(10, 20);
    var b = Vec2(5, 5);
    var c = a + b;
    return c.x + c.y; // Should be 40
}

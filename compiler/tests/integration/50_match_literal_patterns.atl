// Exit Code: 0
fn classify(n: int): int {
    match n {
        0 => { return 10; }
        1 => { return 20; }
        _ => { return 30; }
    };
    return 99;
}

fn main(): int {
    if classify(0) != 10 {
        return 1;
    }
    if classify(1) != 20 {
        return 2;
    }
    if classify(7) != 30 {
        return 3;
    }
    return 0;
}

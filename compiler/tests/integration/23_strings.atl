// Exit Code: 7

extern "C" fn malloc(size: int): @char;
extern "C" fn free(ptr: @char);

class MyString {
    public data: @char;
    public len: int;

    fn init(self: @MyString) {
        (*self).data = malloc(1);
        (*self).data[0] = '\0';
        (*self).len = 0;
    }

    fn destroy(self: @MyString) {
        free((*self).data);
    }

    fn length(self: @MyString): int {
        return (*self).len;
    }

    fn c_str(self: @MyString): @char {
        return (*self).data;
    }

    fn from(chars: []char): MyString {
        var s = MyString();
        free(s.data);

        var n = chars.len;
        s.len = n;
        s.data = malloc(n + 1);

        var i = 0;
        while i < n {
            s.data[i] = chars[i];
            i = i + 1;
        }
        s.data[n] = '\0';

        return s;
    }
}

fn main(): int {
    var s: MyString = "hello";
    return s.length() + 2;
}

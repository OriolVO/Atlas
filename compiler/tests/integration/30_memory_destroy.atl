// Exit Code: 42
// Expected Output: 42
extern "C" fn putchar(c: int32): int32;

struct GlobalState {
    value: int;
}

fn print_char(c: int32) {
    putchar(c);
}

fn main(): int {
    // Primitive destroy remains a no-op.
    var x = 100;
    memory::destroy<int>(x);

    // Struct destroy remains a no-op.
    var s = GlobalState(1);
    memory::destroy<GlobalState>(s);

    print_char(52i32); // 4
    print_char(50i32); // 2
    print_char(10i32); // \n
    return 42;
}
